# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
NODE_ENV=development
APP_NAME=InterDev
APP_PORT=3000
APP_URL=https://localhost:3000
PUBLIC_API_URL=https://localhost:3000
BACKEND_URL=https://localhost:3000
FRONTEND_URL=https://localhost:5173
CLIENT_URL=https://localhost:5173

# PayPal Sandbox checkout for milestone funding.
# Use `sb` for the generic sandbox shortcut or paste your own sandbox app client id.
PAYPAL_CLIENT_ID=sb
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_SUBSCRIPTION_CURRENCY=USD
PAYPAL_SUBSCRIPTION_VND_RATE=25000

# Optional dedicated credentials for PayPal Payouts cashout flow.
# If omitted, the backend falls back to PAYPAL_CLIENT_ID / PAYPAL_CLIENT_SECRET.
PAYPAL_PAYOUTS_CLIENT_ID=
PAYPAL_PAYOUTS_CLIENT_SECRET=
PAYPAL_PAYOUTS_ENV=sandbox

# Stripe test-mode card checkout for milestone funding.
# Use a test secret key such as sk_test_...
STRIPE_SECRET_KEY=

# Startup fails if DB schema readiness is not satisfied.
# Recommended: true in staging/prod, optional in local dev.
STARTUP_READINESS_FAIL_FAST=false

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# Using Supabase PostgreSQL
DB_HOST=aws-1-ap-south-1.pooler.supabase.com
# Port 6543 = PgBouncer Transaction mode (recommended)
# Port 5432 = Session mode
DB_PORT=6543
DB_USERNAME=postgres.your-project-ref
DB_PASSWORD=your-db-password
DB_DATABASE=postgres
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_POOL_MAX=20
DB_POOL_IDLE_MS=30000
DB_POOL_CONN_TIMEOUT_MS=10000
DB_POOL_MAX_USES=10000
DB_POOL_ALLOW_EXIT_ON_IDLE=true
DB_QUERY_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000

# ==============================================
# BACKGROUND JOBS CONFIGURATION
# ==============================================
HEARING_REMINDER_CRON_ENABLED=false
HEARING_AUTO_START_ENABLED=false
DISPUTE_MEDIATION_TIMEOUT_CRON_ENABLED=false

# ==============================================
# REDIS CONFIGURATION
# ==============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
SOCKET_REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# ==============================================
# JWT CONFIGURATION
# ==============================================
# Generate secure values: openssl rand -hex 64
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# ==============================================
# COOKIE/CORS CONFIGURATION
# ==============================================
CORS_ORIGIN=https://localhost:5173
CORS_CREDENTIALS=true
# none | lax | strict
AUTH_COOKIE_SAME_SITE=lax
# true | false (optional override; if omitted, server auto-decides from topology)
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=
# AUTH_COOKIE_PATH=/

# ==============================================
# API DOCUMENTATION
# ==============================================
SWAGGER_ENABLED=true
SWAGGER_PATH=/api-docs

# ==============================================
# SUPABASE STORAGE
# ==============================================
SUPABASE_URL=https://your-project-ref.supabase.co
# Either one is accepted by code. Prefer SERVICE_ROLE_KEY.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_SERVICE_KEY=
SUPABASE_KYC_BUCKET=kyc-documents
SUPABASE_PROJECT_REQUESTS_BUCKET=project-request-attachments
SUPABASE_REQUEST_CHAT_BUCKET=request-chat-attachments

# ==============================================
# ENCRYPTION KEYS
# ==============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KYC_ENCRYPTION_KEY=replace-with-base64-32-byte-key
DOCUMENT_HASH_SALT=replace-with-base64-32-byte-salt

# ==============================================
# EMAIL CONFIGURATION (SMTP)
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
FROM_EMAIL=InterDev <no-reply@interdev.local>
FROM_NAME=InterDev Platform

# ==============================================
# GOOGLE OAUTH 2.0 CONFIGURATION
# ==============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://localhost:3000/auth/google/callback

# ==============================================
# HUNTER.IO EMAIL VERIFICATION
# ==============================================
HUNTER_API_KEY=
HUNTER_ENABLED=false

# ==============================================
# GOOGLE reCAPTCHA CONFIGURATION
# ==============================================
RECAPTCHA_ENABLED=false
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ==============================================
# ADMIN SEEDER
# ==============================================
ADMIN_EMAIL=admin@interdev.local
ADMIN_SEED_SECRET=replace-with-random-seed-secret

# ==============================================
# EVIDENCE/SECURITY INTEGRATIONS
# ==============================================
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_API_URL=https://www.virustotal.com/api/v3
GITHUB_API_TOKEN=

# ==============================================
# FPT.AI eKYC
# ==============================================
FPT_AI_ENABLED=false
FPT_AI_API_KEY=
# Default in code: https://api.fpt.ai/vision/idr/vnm
FPT_AI_API_URL=https://api.fpt.ai/vision/idr/vnm
FPT_AI_AUTO_APPROVE_THRESHOLD=0.95
FPT_AI_ADMIN_REVIEW_THRESHOLD=0.70

# ==============================================
# AI MATCHING ENGINE
# ==============================================
GEMINI_API_KEY=
GROQ_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
MATCHING_AI_ENABLED=true
MATCHING_AI_TOP_N=3
