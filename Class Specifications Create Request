<tr><td>02</td><td>optionId</td><td>string (optional)</td><td>@IsOptional()</td><td>UUID of the selected WizardOption (for SELECT/RADIO type questions). Optional.</td></tr>
<tr><td>03</td><td>valueText</td><td>string (optional)</td><td>@IsOptional()</td><td>Free-text answer value (for TEXT type or custom answers). Optional.</td></tr>
</table>

