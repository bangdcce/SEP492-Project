VITE_RECAPTCHA_SITE_KEY=6Le-CT8sAAAAAAnM6SyyXz7Wy1NK8IXJ3wRtQj3Z

# Optional PayPal SDK client id fallback used if the frontend cannot load
# the backend checkout config endpoint during local development.
VITE_PAYPAL_CLIENT_ID=sb

