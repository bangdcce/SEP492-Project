@startuml Delete_Wizard_Question_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
	ArrowColor Black
	LifeLineBorderColor Black
	LifeLineBackgroundColor White

	ParticipantBorderColor Black
	ParticipantBackgroundColor #DDDDDD
	ParticipantFontColor Black

	ActorBorderColor Black
	ActorBackgroundColor White
	ActorFontColor Black

	GroupHeaderFontColor Black
	GroupHeaderBackgroundColor White
	GroupBodyBackgroundColor White
	GroupBorderColor Black
}

title Delete Wizard Question Sequence Diagram

actor Admin
boundary "AdminWizardPage" as Page
participant "apiClient" as API
participant "WizardAdminController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "RolesGuard" as RoleGuard
participant "WizardService" as Service
database "Database" as DB

Admin -> Page : 1. Click "Delete" button
activate Admin
activate Page

Page --> Admin : 2. Display confirmation dialog\n"Are you sure?"

Admin -> Page : 3. Confirm deletion

Page -> API : 4. Send delete request
activate API

API -> Controller : 5. Send delete request
activate Controller

Controller -> JWTGuard : 6. Check sign-in session
activate JWTGuard
JWTGuard --> Controller : 7. Return authenticated user
deactivate JWTGuard

Controller -> RoleGuard : 8. Check role (ADMIN only)
activate RoleGuard
RoleGuard --> Controller : 9. Authorize
deactivate RoleGuard

Controller -> Service : 10. deleteQuestion(id)
activate Service

Service -> DB : 11. Load the question by id
activate DB
DB --> Service : 12. Return question
deactivate DB

Service -> Service : 13. Validate question exists

Service -> Service : 14. Check whether the question is already used

Service -> Service : 15. Delete if unused, otherwise deactivate

Service -> DB : 16. Save changes
activate DB
DB --> Service : 17. Return confirmation
deactivate DB

Service --> Controller : 18. Return success response
deactivate Service

Controller --> API : 19. Return success response
deactivate Controller

API --> Page : 20. Return deletion confirmation
deactivate API

Page --> Admin : 21. Show success toast:\n"Question deleted successfully"

Page -> Page : 22. Refresh questions list

Page --> Admin : 23. Display updated list
deactivate Page

deactivate Admin

@enduml
