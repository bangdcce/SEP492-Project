@startuml Edit_Profile_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Edit Profile Sequence Diagram

actor "User" as Actor
boundary "ProfilePage" as Page
participant "Auth API" as API
participant "AuthController" as Controller
participant "JwtAuthGuard" as Guard
participant "AuthService" as Service
participant "ProfileCtrl" as ProfileController
participant "Storage" as Storage
database "Database" as DB

Actor -> Page : 1. Click "Edit Profile" button
activate Actor
activate Page

Page -> Page : 2. Enter edit mode
activate Page
deactivate Page

Page --> Actor : 3. Display edit mode\n(Enable form fields for editing)

opt [Edit text information]
    Actor -> Page : 4. Edit fullName, phoneNumber, or bio
    Page -> Page : 5. Update form values
    activate Page
    deactivate Page
end

opt [Update avatar preview]
    Actor -> Page : 6. Select avatar image file
    Page -> Page : 7. Validate file type (must be image)
    activate Page
    deactivate Page
    
    alt [Invalid image type]
        Page --> Actor : 8. Show error: "Please select an image file"
    else [Valid image type]
        Page -> Page : 9. Validate file size (max 5MB)
        activate Page
        deactivate Page
        
        alt [Image too large]
            Page --> Actor : 10. Show error: "Image size must not exceed 5MB"
        else [Valid image size]
            Page -> Page : 11. Read the image and prepare a preview
            activate Page
            deactivate Page
            Page --> Actor : 12. Display avatar preview
        end
    end
end

opt [Manage certifications]
    Actor -> Page : 13. Add, edit, or remove certifications
    Page -> Page : 14. Update certification draft values
    activate Page
    deactivate Page
    Page --> Actor : 15. Refresh the certification list in the form
end

Actor -> Page : 16. Click "Save" button

Page -> Page : 17. Start saving
activate Page
deactivate Page

opt [Large avatar preview]
    Page --> Actor : 18. Show warning: "Large avatar size detected"
end

Page -> API : 19. Submit profile update data
activate API

API -> Controller : 20. Send update request
activate Controller

Controller -> Guard : 21. Verify the session token
activate Guard

Guard -> Guard : 22. Read token from cookies
activate Guard
deactivate Guard

Guard -> Guard : 23. Validate the token
activate Guard
deactivate Guard

alt [Not authenticated]
    Guard --> Controller : 24. Reject request: not signed in
    Controller --> API : 25. Return authentication error
  
    API --> Page : 26. Return error response
    Page -> Page : 27. Hide saving indicator
    activate Page
    deactivate Page
    Page --> Actor : 28. Show error toast\nRedirect to sign in
else [Token valid]
    Guard -> Guard : 24. Attach user info to the request
    activate Guard
    deactivate Guard
    
    Guard --> Controller : 25. Allow request
    deactivate Guard

    Controller -> Controller : 26. Validate update data\n(fullName, phoneNumber, bio, avatarUrl, certifications)
    activate Controller
    deactivate Controller

    alt [Invalid input]
        Controller --> API : 27. Return validation errors
   
        API --> Page : 28. Return error response
       
        Page -> Page : 29. Hide saving indicator
        activate Page
        deactivate Page
        Page --> Actor : 30. Show error toast with details
    else [Input valid]
        Controller -> Service : 27. Update the profile
        activate Service

        Service -> Service : 28. Prepare user updates
        activate Service
        deactivate Service

        alt [Has User Data to Update]
            Service -> DB : 29. Save user updates
            activate DB
            DB --> Service : 30. Return update confirmation
            deactivate DB
        end

        Service -> DB : 31. Load existing profile
        activate DB
        DB --> Service : 32. Return profile or null
        deactivate DB

        alt [Profile Not Found]
            Service -> Service : 33. Prepare a new profile
            activate Service
            deactivate Service
            
            Service -> DB : 34. Save the new profile
            activate DB
            DB --> Service : 35. Return saved profile
            deactivate DB
        else [Profile Exists]
            Service -> Service : 33. Prepare profile updates
            activate Service
            deactivate Service
            
            alt [Has Profile Data to Update]
                Service -> DB : 34. Save profile updates
                activate DB
                DB --> Service : 35. Return update confirmation
                deactivate DB
            end
        end

        Service -> Service : 36. Fetch the updated profile
        activate Service
        deactivate Service

        Service -> DB : 37. Load updated user and profile
        activate DB
        DB --> Service : 38. Return user with profile
        deactivate DB

        Service -> Service : 39. Prepare response data
        activate Service
        deactivate Service

        Service --> Controller : 40. Return updated profile data
        deactivate Service

        Controller --> API : 41. Return success response
        deactivate Controller

        API --> Page : 42. Return updated profile data
        deactivate API

        Page -> Page : 43. Finish saving and exit edit mode
        activate Page
        deactivate Page

        Page --> Actor : 44. Show success toast:\n"Profile updated successfully"

        Page -> Page : 45. Reload profile from the server
        activate Page
        deactivate Page

        Page -> Page : 46. Sync updated user data to local storage
        activate Page
        deactivate Page

        Page -> Page : 47. Dispatch userDataUpdated event
        activate Page
        deactivate Page

        Page --> Actor : 48. Display updated profile in view mode
    end
end

opt [User uploads or replaces CV in edit mode]
    Actor -> Page : 49. Choose a CV file
    Page -> Page : 50. Validate file type and size\n(PDF or DOCX, max 5MB)
    activate Page
    deactivate Page

    alt [Invalid CV file]
        Page --> Actor : 51. Show CV validation error
    else [Valid CV file]
        Page -> API : 52. Submit CV file for upload
        activate API
        API -> ProfileController : 53. Send protected CV upload
        activate ProfileController

        ProfileController -> Guard : 54. Verify session
        activate Guard
        Guard --> ProfileController : 55. Allow request
        deactivate Guard

        ProfileController -> Storage : 56. Store CV file
        activate Storage
        Storage --> ProfileController : 57. Return stored file URL
        deactivate Storage

        ProfileController -> DB : 58. Save CV reference in profile
        activate DB
        DB --> ProfileController : 59. Return update confirmation
        deactivate DB

        ProfileController --> API : 60. Return upload success
        deactivate ProfileController
        API --> Page : 61. Return uploaded CV info
        deactivate API

        Page -> Page : 62. Refresh profile data
        activate Page
        deactivate Page

        Page --> Actor : 63. Show "CV uploaded successfully"
deactivate Page
deactivate Actor
    end
end


@enduml
