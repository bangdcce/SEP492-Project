@startuml View_Account_Detail_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title View Account Detail Sequence Diagram

actor "Admin" as Admin
boundary "AdminUsersPage" as Page
participant "apiClient" as API
participant ":UsersController" as Controller
participant ":JwtAuthGuard" as JWTGuard
participant ":RolesGuard" as RoleGuard
participant ":UsersService" as Service
database "Database" as DB
participant ":SupabaseStorage" as Storage
participant ":KycController" as KycController

Admin -> Page : 1. Click "View" button on user row
activate Admin
activate Page

Page -> Page : 2. Open user detail view
activate Page
deactivate Page

Page -> Page : 3. Show detail modal and loading indicator
activate Page
deactivate Page

Page -> API : 4. Request user details
activate API

API -> Controller : 5. Request user detail
activate Controller

Controller -> JWTGuard : 6. Verify the session token
activate JWTGuard

JWTGuard -> JWTGuard : 7. Read token from cookies
activate JWTGuard
deactivate JWTGuard

JWTGuard -> JWTGuard : 8. Validate the token
activate JWTGuard
deactivate JWTGuard

alt [Token Invalid]
    JWTGuard --> Controller : 9. Reject request: not signed in
    Controller --> API : 10. Return authentication error
    API --> Page : 11. Return error response
    Page -> Page : 12. Close the detail modal
    activate Page
    deactivate Page
    Page --> Admin : 13. Show error toast\nRedirect to sign in
else [Token Valid]
    JWTGuard -> JWTGuard : 14. Attach user info to the request
    activate JWTGuard
    deactivate JWTGuard
    
    JWTGuard --> Controller : 15. Allow request
    deactivate JWTGuard

    Controller -> RoleGuard : 16. Check access role
    activate RoleGuard

    RoleGuard -> RoleGuard : 17. Check user role\n(Must be ADMIN or STAFF)
    activate RoleGuard
    deactivate RoleGuard

    alt [Role Not Authorized]
        RoleGuard --> Controller : 18. Reject request: access denied
        Controller --> API : 19. Return forbidden error
        API --> Page : 20. Return error response
        Page --> Admin : 21. Show error toast: "Access denied"
    else [Role Authorized]
        RoleGuard --> Controller : 22. Return true
        deactivate RoleGuard

        Controller -> Service : 23. Fetch user details
        activate Service

        Service -> DB : 24. Load user and profile from database
        activate DB
        DB --> Service : 25. Return user with profile
        deactivate DB

        alt [User Not Found]
            Service --> Controller : 26. Reject request: user not found
            Controller --> API : 27. Return not found error
            API --> Page : 28. Return error response
            Page --> Admin : 29. Show error toast: "User not found"
        else [User Found]
            Service -> DB : 30. Load the latest KYC record
            activate DB
            DB --> Service : 31. Return latest KYC record or null
            deactivate DB

            alt [Has KYC Record]
                Service -> Storage : 32. Create a temporary link for the front document
                activate Storage
                Storage --> Service : 33. Return signed URL for front document
                deactivate Storage

                Service -> Storage : 34. Create a temporary link for the back document
                activate Storage
                Storage --> Service : 35. Return signed URL for back document
                deactivate Storage

                Service -> Service : 36. Prepare KYC info for display
                activate Service
                deactivate Service
            else [No KYC Record]
                Service -> Service : 37. Build kycInfo { status: 'NOT_STARTED' }
                activate Service
                deactivate Service
            end

            Service -> Service : 38. Prepare user detail response
            activate Service
            deactivate Service

            Service --> Controller : 39. Return user detail with KYC info
            deactivate Service

            Controller --> API : 40. Return user detail response
            deactivate Controller

            API --> Page : 41. Return user data
            deactivate API

            Page -> Page : 42. Store user details
            activate Page
            deactivate Page

            alt [Has KYC ID]
                Page -> API : 43. Request watermarked KYC documents
                activate API

                API -> KycController : 44. Request watermarked KYC documents
                activate KycController

                KycController -> Service : 45. Get KYC documents with watermark
                activate Service

                Service -> DB : 46. Load KYC record
                activate DB
                DB --> Service : 47. Return KYC record
                deactivate DB

                Service -> Storage : 48. Create watermarked document links
                activate Storage
                Storage --> Service : 49. Return watermarked URLs
                deactivate Storage

                Service --> KycController : 50. Return KYC with watermarked URLs
                deactivate Service

                KycController --> API : 51. Return watermarked KYC data
                deactivate KycController

                API --> Page : 52. Return watermarked data
                deactivate API

                Page -> Page : 53. Update details with watermarked links
                activate Page
                deactivate Page
            end

            Page -> Page : 54. Hide loading indicator
            activate Page
            deactivate Page

            Page --> Admin : 55. Display user detail modal\n(Email, Full Name, Role, Phone Number,\nCreated At, KYC Status, Trust Score,\nProjects Finished, Disputes Lost,\nBan Status, KYC Documents if available)
        end
    end
end

deactivate Page
deactivate Admin

@enduml
