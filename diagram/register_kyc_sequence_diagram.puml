@startuml Register_KYC_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Register KYC (Identity Verification) Sequence Diagram

actor "User" as Actor
boundary "KYCPage" as Page
participant "WebClient (fetch)" as Http
participant "KycController" as Controller
participant "JwtAuthGuard" as Guard
participant "KycService" as Service
participant "FptAiService" as Ai
participant "Supabase Storage" as Storage
database "Database" as DB

Actor -> Page : 1. Open Identity Verification (KYC) page
activate Actor
activate Page

Page -> Page : 2. Render multi-step form (Personal info, ID photos, Selfie)
activate Page
deactivate Page

Actor -> Page : 3. Enter personal info (name, date of birth, ID number, address)
Actor -> Page : 4. Upload ID card front photo
Actor -> Page : 5. Upload ID card back photo
Actor -> Page : 6. Upload selfie photo

Page -> Page : 7. Validate required fields and file rules (image type, size limit)
activate Page
deactivate Page

alt [Form invalid]
    Page --> Actor : 8. Show validation errors and ask user to fix
else [Form valid]
    Page -> Page : 9. Create multipart form data (text fields + 3 photos)
    activate Page
    deactivate Page

    Page -> Http : 10. POST /kyc (multipart/form-data, include session cookies)
    activate Http

    Http -> Controller : 11. Forward request to backend
    activate Controller

    Controller -> Guard : 12. Check user is logged in (JWT cookie)
    activate Guard

    alt [Not logged in]
        Guard --> Controller : 13. Reject request (401 Unauthorized)
        deactivate Guard
        Controller --> Http : 14. Return error response
        deactivate Controller
        Http --> Page : 15. Show error message
        deactivate Http

    else [Logged in]
        Guard --> Controller : 13. Allow request and provide userId
        deactivate Guard

        Controller -> Service : 14. Submit KYC (userId + form fields + photos)
        activate Service

        Service -> DB : 15. Check latest KYC submission for this user
        activate DB
        DB --> Service : 16. Latest KYC status (if any)
        deactivate DB

        alt [Existing KYC is PENDING]
            Service --> Controller : 17. Reject: "You already have a pending verification"
            deactivate Service
            Controller --> Http : 18. Return 400 Bad Request
            deactivate Controller
            Http --> Page : 19. Show error message
            deactivate Http

        else [Existing KYC is APPROVED]
            Service --> Controller : 17. Reject: "Your KYC is already verified"
            deactivate Service
            Controller --> Http : 18. Return 400 Bad Request
            deactivate Controller
            Http --> Page : 19. Show error message
            deactivate Http

        else [No blocking KYC]
            Service -> Service : 17. Ensure all required photos are present

            alt [Missing any required photo]
                Service --> Controller : 18. Reject: missing documents
                deactivate Service
                Controller --> Http : 19. Return 400 Bad Request
                deactivate Controller
                Http --> Page : 20. Show error message
                deactivate Http

            else [All photos provided]
                Service -> Ai : 18. Verify documents and selfie (AI check)
                activate Ai
                Ai --> Service : 19. Return decision, confidence, extracted fields, issues
                deactivate Ai

                Service -> Service : 20. Compare user input with extracted fields
                Service -> Service : 21. Decide result: APPROVED, REJECTED, or PENDING review

                Service -> Storage : 22. Upload encrypted photos (front, back, selfie)
                activate Storage
                Storage --> Service : 23. Return stored file paths
                deactivate Storage

                Service -> Service : 24. Hash document number (privacy)

                Service -> DB : 25. Save KYC submission (status, file paths, issues)
                activate DB
                DB --> Service : 26. Return saved KYC record
                deactivate DB

                alt [Auto-approved]
                    Service -> DB : 27. Mark user as verified
                    activate DB
                    DB --> Service : 28. User verification updated
                    deactivate DB
                end

                Service -> Storage : 29. Create short-lived signed URLs for response
                activate Storage
                Storage --> Service : 30. Signed URLs
                deactivate Storage

                Service --> Controller : 31. Return KYC result (status + signed URLs + summary)
                deactivate Service

                Controller --> Http : 32. Return success response
                deactivate Controller

                Http --> Page : 33. Receive response
                deactivate Http

                Page -> Page : 34. Show "submitted" message and switch to Processing state
                activate Page
                deactivate Page

                loop Every 5 seconds while status = PENDING
                    Page -> Http : 35. GET /kyc/me (include session cookies)
                    activate Http
                    Http -> Controller : 36. Forward request to backend
                    activate Controller

                    Controller -> Guard : 37. Check user is logged in
                    activate Guard
                    Guard --> Controller : 38. Allow request
                    deactivate Guard

                    Controller -> Service : 39. Get latest KYC status for user
                    activate Service
                    Service -> DB : 40. Load latest KYC record
                    activate DB
                    DB --> Service : 41. KYC record (status + metadata)
                    deactivate DB

                    Service -> Storage : 42. Refresh signed URLs (front/back/selfie)
                    activate Storage
                    Storage --> Service : 43. Signed URLs
                    deactivate Storage

                    Service --> Controller : 44. Return status (APPROVED / REJECTED / PENDING)
                    deactivate Service
                    Controller --> Http : 45. Send response
                    deactivate Controller
                    Http --> Page : 46. Update UI based on status
                    deactivate Http
                end

                alt [Status becomes APPROVED]
                    Page --> Actor : 47. Show success screen (Verification approved)
                else [Status becomes REJECTED]
                    Page --> Actor : 47. Show failure screen and reason (if provided)
                else [Still PENDING]
                    Page -> Page : 47. Keep showing "Verification in progress"
                    activate Page
                    deactivate Page
                end
            end
        end
    end
end

deactivate Page
deactivate Actor

@enduml
