@startuml Approve_Reject_KYC_Request_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Approve/Reject KYC Request Sequence Diagram

actor User
participant "KYCVerificationModal" as Modal
participant "apiClient" as API
participant "KycController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "RolesGuard" as RoleGuard
participant "KycService" as Service
database "Database" as DB

activate User

alt [Approve KYC]
    User -> Modal : 1. Click "Approve"
    activate Modal

    activate Modal
    Modal -> Modal : 2. Show loading state
    deactivate Modal

    Modal -> API : 3. Send approve request
    activate API

    API -> Controller : 4. Forward request to server
    activate Controller

    Controller -> JWTGuard : 5. Check that the user is signed in
    activate JWTGuard
    JWTGuard --> Controller : 6. Return user information
    deactivate JWTGuard

    Controller -> RoleGuard : 7. Check permission (ADMIN or STAFF)
    activate RoleGuard
    RoleGuard --> Controller : 8. Allow request
    deactivate RoleGuard

    Controller -> Service : 9. Ask system to approve the KYC request
    activate Service

    Service -> DB : 10. Find KYC record by id
    activate DB
    DB --> Service : 11. Return KYC record
    deactivate DB

    activate Service
    Service -> Service : 12. Make sure the request is still pending
    Service -> Service : 13. Update status and approval time
    deactivate Service

    Service -> DB : 14. Save updated KYC record
    activate DB
    DB --> Service : 15. Confirm saved
    deactivate DB

    Service -> DB : 16. Mark the user account as verified
    activate DB
    DB --> Service : 17. Confirm update success
    deactivate DB

    Service --> Controller : 18. Return approval result
    deactivate Service

    Controller --> API : 19. Return success response
    deactivate Controller

    API --> Modal : 20. Return success result
    deactivate API

    activate Modal
    Modal -> Modal : 21. Hide loading state
    deactivate Modal

    Modal --> User : 22. Show success message

    activate Modal
    Modal -> Modal : 23. Refresh the list and close the modal
    deactivate Modal

    Modal --> User : 24. List refreshed, modal closed
    deactivate Modal

else [Reject KYC]
    User -> Modal : 25. Click "Reject"
    activate Modal

    Modal --> User : 26. Show rejection reason input

    User -> Modal : 27. Enter reason and click "Confirm"

    activate Modal
    Modal -> Modal : 28. Validate reason is not empty
    Modal -> Modal : 29. Show loading state
    deactivate Modal

    Modal -> API : 30. Send reject request with reason
    activate API

    API -> Controller : 31. Forward request to server
    activate Controller

    Controller -> JWTGuard : 32. Check that the user is signed in
    activate JWTGuard
    JWTGuard --> Controller : 33. Return user information
    deactivate JWTGuard

    Controller -> RoleGuard : 34. Check permission (ADMIN or STAFF)
    activate RoleGuard
    RoleGuard --> Controller : 35. Allow request
    deactivate RoleGuard

    Controller -> Service : 36. Ask system to reject the KYC request
    activate Service

    Service -> DB : 37. Find KYC record by id
    activate DB
    DB --> Service : 38. Return KYC record
    deactivate DB

    activate Service
    Service -> Service : 39. Make sure the request is still pending
    Service -> Service : 40. Make sure the rejection reason is provided

    Service -> Service : 41. Update status, reason, and processed time
    deactivate Service

    Service -> DB : 42. Save updated KYC record
    activate DB
    DB --> Service : 43. Confirm saved
    deactivate DB

    Service --> Controller : 44. Return rejection result
    deactivate Service

    Controller --> API : 45. Return success response
    deactivate Controller

    API --> Modal : 46. Return success result
    deactivate API

    activate Modal
    Modal -> Modal : 47. Hide loading state
    deactivate Modal

    Modal --> User : 48. Show success message

    activate Modal
    Modal -> Modal : 49. Refresh the list and close the modal
    deactivate Modal

    Modal --> User : 50. List refreshed, modal closed
    deactivate Modal
end

deactivate User

@enduml
