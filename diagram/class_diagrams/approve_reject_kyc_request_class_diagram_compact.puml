@startuml Approve_Reject_KYC_Request_Class_Diagram
title Approve or Reject KYC Request - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class RejectKycDto {
    + rejectionReason: string
    --
}

class ApiClient {
    - client: AxiosInstance
    --
    + patch(url: string, data: any): Promise<any>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    + bootstrapSession(): Promise<
    ...
}

class AdminKYCPage {
    - actionLoading: boolean
    --
    + handleApprove(id: string): Promise<void>
    + handleReject(id: string, reason: string): Promise<void>
    + fetchKycs(): Promise<void>
    + closeModal(): void
}

class KYCVerificationModal {
    - rejectReason: string
    - showRejectInput: boolean
    --
    + handleApprove(): void
    + handleReject(): void
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean
}

class RolesGuard {
    --
    + canActivate(context: any): boolean
}

class KycController {
    - kycService: KycService
    --
    + approveKyc(id: string, adminId: string): any
    + rejectKyc(id: string, dto: RejectKycDto, adminId: string): any
    + getMyKyc(@GetUser('id')
    + getKycById(@Param('id', ParseUUIDPipe)
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
    + update(id: string, partial: any): Promise<any>
}

class KycService {
    - kycRepo: Repository
    - userRepo: Repository
    --
    + approveKyc(id: string, adminId: string): KycVerificationEntity
    + rejectKyc(id: string, adminId: string, dto: RejectKycDto): KycVerificationEntity
    + getMyKyc(userId: string)
    + getAllKyc(status?: KycStatus, page = 1, limit = 20)
    + getKycById(id: string)
    + hasVerifiedKyc(userId: string): Promise<boolean>
    - normalizeString(str: string | undefined | null): string
    - levenshteinDistance(str1: string, str2: string): number
    - calculateSimilarity(str1: string, str2: string): number
    - normalizeDateString(dateStr: string | undefined | null): string
}


class KycVerificationEntity {
    + id: string
    + userId: string
    + status: KycStatus
    + rejectionReason: string
    + reviewedBy: string
    + reviewedAt: Date
    + documentType: DocumentType
    + dateOfBirth: Date | null
    + createdAt: Date
    + updatedAt: Date
    --
}

class UserEntity {
    + id: string
    + isVerified: boolean
    + email: string
    + passwordHash: string
    + fullName: string
    + role: UserRole
    + phoneNumber: string
    + timeZone: string
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

AdminKYCPage ..> KYCVerificationModal
AdminKYCPage ..> ApiClient
ApiClient ..> KycController
KycController ..> JwtAuthGuard
KycController ..> RolesGuard
KycController --> KycService
KycController ..> RejectKycDto
KycService --> Repository
KycService ..> KycVerificationEntity
KycService ..> UserEntity
KycVerificationEntity -- KycStatus
@enduml
