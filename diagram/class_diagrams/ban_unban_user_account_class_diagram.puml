@startuml Ban_Unban_User_Account_Class_Diagram
title Ban or Unban User Account - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class BanUserDto {
    + reason: string
}

class UnbanUserDto {
    + reason: string
}

class AdminUsersPage {
    - users: any[]
    - selectedUser: any
    - showBanModal: boolean
    - showUnbanModal: boolean
    - banReason: string
    - unbanReason: string
    - page: number
    - totalPages: number
    - loading: boolean
    - apiUrl: string

    + fetchUsers(): Promise<void>
    + handleBanUser(): Promise<void>
    + handleUnbanUser(): Promise<void>
}

class WebClient {
    + patchJson(url: string, body: any, withCredentials: boolean): Promise<any>
    + getJson(url: string, withCredentials: boolean): Promise<any>
}

class JwtAuthGuard {
    + canActivate(context: any): boolean
}

class RolesGuard {
    + canActivate(context: any): boolean
}

class UsersController {
    - usersService: UsersService

    + banUser(userId: string, dto: BanUserDto, adminId: string): any
    + unbanUser(userId: string, dto: UnbanUserDto, adminId: string): any
}

class Repository {
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
}

class UsersService {
    - userRepo: Repository

    + banUser(userId: string, adminId: string, dto: BanUserDto): any
    + unbanUser(userId: string, adminId: string, dto: UnbanUserDto): any
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + isBanned: boolean
    + banReason: string
    + bannedAt: Date
    + bannedBy: string
}

enum UserRole {
    ADMIN
    STAFF
    BROKER
    CLIENT
    FREELANCER
}

AdminUsersPage ..> WebClient
WebClient ..> UsersController
UsersController ..> JwtAuthGuard
UsersController ..> RolesGuard
UsersController --> UsersService
UsersController ..> BanUserDto
UsersController ..> UnbanUserDto
UsersService --> Repository
UsersService ..> UserEntity
UserEntity -- UserRole
@enduml
