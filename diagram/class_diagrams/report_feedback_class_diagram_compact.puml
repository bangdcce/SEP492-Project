@startuml Report_Feedback_Class_Diagram
title Report Feedback - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ReviewItem {
    - review: Review
    - isReportModalOpen: boolean
    --
    + ReviewItem(props: ReviewItemProps): JSX.Element
}

class ReportAbuseModal {
    - selectedReason: ReportReason | null
    - description: string
    - isLoading: boolean
    - error: string | null
    - isSuccess: boolean
    --
    + ReportAbuseModal(props: ReportAbuseModalProps): JSX.Element
    + handleSubmit(event: React.FormEvent): Promise<void>
    + handleClose(): void
}

class createReport {
    --
    + createReport(payload: CreateReportPayload): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class ReportController {
    - reportService: ReportService
    --
    + create(dto: CreateReportDto, reporterId: string): Promise<any>
    + findOne(@Param('id')
}

class ReportService {
    - reportRepo: Repository<ReportEntity>
    - reviewRepo: Repository<ReviewEntity>
    --
    + create(reporterId: string, dto: CreateReportDto): Promise<ReportEntity>
    - toBoundedPositiveInt(value: number, fallback: number, max: number): number
    + findPending(page: number = 1, limit: number = 20)
    + resolve(reportId: string, dto: ResolveReportDto, adminId: string)
    + findOne(reportId: string)
}

class CreateReportDto {
    + reviewId: string
    + reason: string
    + description?: string
    --
}

class ReportEntity {
    + id: string
    + reporterId: string
    + reviewId: string
    + reason: string
    + description: string | null
    + status: ReportStatus
    + resolvedBy: string
    + adminNote: string
    + createdAt: Date
    + resolvedAt: Date
    ...
    --
}

class ReviewEntity {
    + id: string
    + reviewerId: string
    + targetUserId: string
    + comment: string
    + projectId: string
    + rating: number
    + weight: number
    + createdAt: Date
    + updatedAt: Date
    + deletedAt: Date | null
    ...
    --
}

ReviewItem ..> ReportAbuseModal
ReportAbuseModal ..> createReport
createReport ..> ApiClient
ApiClient ..> ReportController
ReportController --> ReportService
ReportController ..> CreateReportDto

ReportService ..> CreateReportDto
ReportService ..> ReportEntity
ReportService ..> ReviewEntity

@enduml
