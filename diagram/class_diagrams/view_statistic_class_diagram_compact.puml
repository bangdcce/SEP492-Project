@startuml View_Statistic_Class_Diagram
title View Statistic - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class DashboardAdminPage {
    - range: DashboardRange
    - overview: AdminDashboardOverview | null
    - loading: boolean
    - error: string | null
    --
    + DashboardAdminPage(): JSX.Element
}

class getAdminDashboardOverview {
    --
    + getAdminDashboardOverview(range?: DashboardRange): Promise<AdminDashboardOverview>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class AdminDashboardController {
    - adminDashboardService: AdminDashboardService
    --
    + getOverview(range?: "7d" | "30d" | "90d"): Promise<any>
}

class AdminDashboardService {
    - userRepository: Repository<UserEntity>
    - projectRepository: Repository<ProjectEntity>
    - escrowRepository: Repository<EscrowEntity>
    - auditLogRepository: Repository<AuditLogEntity>
    - performanceRepository: Repository<StaffPerformanceEntity>
    - workloadRepository: Repository<StaffWorkloadEntity>
    - disputeRepository: Repository<DisputeEntity>
    - hearingRepository: Repository<DisputeHearingEntity>
    - notificationRepository: Repository<NotificationEntity>
    --
    + getOverview(range?: DashboardRange): Promise<any>
    + buildSeries(range: DashboardRange, start: Date, end: Date, revenuePoints: object[], newUserPoints: object[], completedProjectPoints: object[]): object[]
    + buildAdminTeam(adminUsers: UserEntity[], adminLogs: AuditLogEntity[]): object
    + buildStaffTeam(staffUsers: UserEntity[], performanceRows: StaffPerformanceEntity[], workloadRows: StaffWorkloadEntity[]): object
    + buildCriticalAlerts(input: object): object[]
    + buildRiskMethodology(criticalAlerts: object[]): object
    + buildSystemIncidentHub(systemIncidentLogs: AuditLogEntity[]): object
    - sumRevenueBetween(start: Date, end: Date): Promise<number>
    - countUsersBetween(start: Date, end: Date): Promise<number>
    - countCompletedProjectsBetween(start: Date, end: Date): Promise<number>
    ...
}

class DashboardRange {
    + 7d
    + 30d
    + 90d
    --
}

class AdminDashboardOverview {
    + generatedAt: string
    + range: DashboardRange
    + summary: object
    + series: AdminTrendPoint[]
    + adminTeam: object
    + staffTeam: object
    + riskHighlights: object
    + criticalAlerts: object[]
    + systemIncidentHub: object
    + riskMethodology: object
    --
}

class UserEntity {
    + id: string
    + fullName: string
    + email: string
    + role: UserRole
    + createdAt: Date
    + updatedAt: Date
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ProjectEntity {
    + id: string
    + status: ProjectStatus
    + updatedAt: Date
    + requestId: string
    + clientId: string
    + brokerId: string
    + freelancerId: string
    + staffId: string | null
    + staffInviteStatus: ProjectStaffInviteStatus | null
    + title: string
    ...
    --
}

class EscrowEntity {
    + id: string
    + status: EscrowStatus
    + platformFee: string
    + releasedAt?: Date | null
    + projectId: string
    + developerPercentage: number
    + brokerPercentage: number
    + platformPercentage: number
    + currency: string
    + fundedAt: Date
    ...
    --
}

class AuditLogEntity {
    + id: string
    + actorId: string | null
    + action: string
    + requestId: string | null
    + eventName?: string | null
    + metadata?: Record<string, any> | null
    + createdAt: Date
    + entityType: string
    + entityId: string
    + sessionId: string | null
    ...
    --
}

class StaffPerformanceEntity {
    + id: string
    + staffId: string
    + period: string
    + totalDisputesResolved: number
    + totalAppealed: number
    + totalOverturnedByAdmin: number
    + totalHearingsConducted: number
    + avgResolutionTimeHours: number
    + updatedAt: Date
    + totalDisputesAssigned: number
    ...
    --
}

class StaffWorkloadEntity {
    + id: string
    + staffId: string
    + date: Date
    + utilizationRate: number
    + totalDisputesPending: number
    + updatedAt: Date
    + totalEventsScheduled: number
    + scheduledMinutes: number
    + dailyCapacityMinutes: number
    + isOverloaded: boolean
    ...
    --
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + priority: DisputePriority
    + resolutionDeadline?: Date | null
    + projectId: string
    + milestoneId: string
    + raisedById: string
    + defendantId: string
    + reason: string
    + messages: string
    ...
    --
}

class DisputeHearingEntity {
    + id: string
    + status: HearingStatus
    + endedAt?: Date | null
    + summary?: string | null
    + disputeId: string
    + scheduledAt: Date
    + startedAt: Date
    + endedAt: Date
    + externalMeetingLink: string
    + moderatorId: string
    ...
    --
}

class NotificationEntity {
    + id: string
    + title: string
    + createdAt: Date
    + userId: string
    + body: string
    + isRead: boolean
    + readAt: Date
    + relatedType: string
    + relatedId: string
    + user: any
    --
}

DashboardAdminPage ..> getAdminDashboardOverview
DashboardAdminPage ..> AdminDashboardOverview
DashboardAdminPage ..> DashboardRange

getAdminDashboardOverview ..> ApiClient
getAdminDashboardOverview ..> DashboardRange
getAdminDashboardOverview ..> AdminDashboardOverview
ApiClient ..> AdminDashboardController

AdminDashboardController --> AdminDashboardService
AdminDashboardService ..> DashboardRange
AdminDashboardService ..> AdminDashboardOverview
AdminDashboardService ..> UserEntity
AdminDashboardService ..> ProjectEntity
AdminDashboardService ..> EscrowEntity
AdminDashboardService ..> AuditLogEntity
AdminDashboardService ..> StaffPerformanceEntity
AdminDashboardService ..> StaffWorkloadEntity
AdminDashboardService ..> DisputeEntity
AdminDashboardService ..> DisputeHearingEntity
AdminDashboardService ..> NotificationEntity

@enduml
