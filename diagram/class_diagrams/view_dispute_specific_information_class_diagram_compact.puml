@startuml View_Dispute_Specific_Information_Class_Diagram
title View Dispute Specific Information - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffDisputeBoard {
    - disputes: DisputeSummary[]
    - quickViewDispute: DisputeSummary | null
    --
    + StaffDisputeBoard(props: StaffDisputeBoardProps): JSX.Element
    + openDisputeDetail(dispute: DisputeSummary): void
}

class StaffCaseloadPage {
    - disputeId?: string
    - initialTab?: string
    --
    + StaffCaseloadPage(): JSX.Element
}

class DisputeDetailHub {
    - dispute: DisputeSummary | null
    - activities: DisputeActivity[]
    - complexity: DisputeComplexity | null
    - dossier: DisputeDossier | null
    - loading: boolean
    --
    + DisputeDetailHub(props: DisputeDetailHubProps): JSX.Element
    + fetchDetail(preferCache?: boolean): Promise<void>
    + fetchActivities(preferCache?: boolean): Promise<void>
    + fetchComplexity(preferCache?: boolean): Promise<void>
    + fetchDossier(): Promise<void>
}

class getDisputeDetail {
    --
    + getDisputeDetail(disputeId: string, options?: CacheOptions): Promise<DisputeSummary>
}

class getDisputeActivities {
    --
    + getDisputeActivities(disputeId: string, includeInternal?: boolean, options?: CacheOptions): Promise<DisputeActivity[]>
}

class getDisputeComplexity {
    --
    + getDisputeComplexity(disputeId: string, options?: CacheOptions): Promise<{ data: DisputeComplexity }>
}

class getDisputeDossier {
    --
    + getDisputeDossier(disputeId: string): Promise<DisputeDossier>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + getDetailDisputes(id: string, user: UserEntity): Promise<any>
    + getActivities(id: string, includeInternal: string, user: UserEntity): Promise<DisputeActivityEntity[]>
    + getDisputeDossier(id: string, user: UserEntity): Promise<any>
    + createDisputes(@GetUser()
    + getListDisputes(@GetUser()
    + getMyDisputes(@GetUser()
    + getDisputeStats()
    + getQueueCount(@GetUser()
    + getQueueDisputes(@GetUser()
    + getCaseloadDisputes(@GetUser()
    ...
}

class StaffAssignmentController {
    - staffAssignmentService: StaffAssignmentService
    --
    + estimateComplexity(disputeId: string): Promise<any>
    + estimateComplexityBatch(@Body()
    + getAvailableStaff(@Query('date')
    + autoAssignStaff(@Param('disputeId', ParseUUIDPipe)
    + checkSessionTiming(@Param('eventId', ParseUUIDPipe)
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    - contractRepo: Repository<ContractEntity>
    - activityRepo: Repository<DisputeActivityEntity>
    --
    + getDetail(disputeId: string, userId: string, userRole: UserRole): Promise<any>
    + getActivities(userId: string, userRole: UserRole, disputeId: string, includeInternal?: boolean): Promise<DisputeActivityEntity[]>
    + getDisputeDossier(disputeId: string, userId: string, userRole: UserRole): Promise<any>
    + assertDisputeAccess(dispute: DisputeEntity, userId: string, userRole: UserRole): Promise<void>
    + getVerdict(disputeId: string, userId: string, userRole: UserRole)
    - buildVerdictAcceptanceKey(disputeId: string, verdictId: string): string
    + getPublicRecord(disputeId: string)
    - sanitizePublicText(value: string | null | undefined): string | null
    - toPublicRoleAlias(role: UserRole | null | undefined): string
    - buildPublicCaseNumber(disputeId: string): string
    ...
}

class StaffAssignmentService {
    --
    + estimateDisputeComplexity(disputeId: string): Promise<ComplexityEstimation>
    - getRangeDays(range: '7d' | '30d' | '90d'): number
    - getMedian(values: number[]): number
    - getPeriodsForRange(start: Date, end: Date): string[]
    - buildDashboardBuckets(range: '7d' | '30d' | '90d', start: Date, end: Date)
    - getCategoryComplexityWeight(category: DisputeCategory): number
    - getEvidenceComplexityWeight(evidenceCount: number): number
    - getDescriptionComplexityWeight(descriptionLength: number): number
    - getAmountComplexityScore(amount: number, currency: string, totalBudget?: number): number
    - determineComplexityLevel(totalScore: number): ComplexityLevel
    ...
}

class DisputeSummary {
    + id: string
    + displayCode?: string
    + displayTitle?: string
    + status: DisputeStatus
    + caseStage?: string
    + project?: object
    + participants?: object[]
    + projectId: string
    + milestoneId: string
    + raisedById: string
    ...
    --
}

class DisputeActivity {
    + id: string
    + action: string
    + description?: string
    + timestamp: string
    + isInternal?: boolean
    + actor?: object
    + disputeId: string
    --
}

class DisputeComplexity {
    + level: string
    + confidence: number
    + factors: object[]
    + timeEstimation: object
    --
}

class DisputeDossier {
    + dispute: object
    + projectContext: object
    + contracts: object[]
    + timeline: object[]
    + issues: object[]
    + pendingActions: object[]
    --
}

class DisputeEntity {
    + id: string
    + projectId: string
    + raisedById: string
    + defendantId: string
    + assignedStaffId?: string | null
    + category: DisputeCategory
    + status: DisputeStatus
    + milestoneId: string
    + priority: DisputePriority
    + reason: string
    ...
    --
}

class DisputeActivityEntity {
    + id: string
    + disputeId: string
    + action: string
    + description?: string
    + timestamp: Date
    + isInternal: boolean
    + actorRole: UserRole
    + description: string
    + metadata: Record<string, any>
    + dispute: any
    --
}

class ProjectEntity {
    + id: string
    + title: string
    + clientId: string
    + brokerId?: string | null
    + freelancerId?: string | null
    + requestId: string
    + brokerId: string
    + freelancerId: string
    + staffId: string | null
    + staffInviteStatus: ProjectStaffInviteStatus | null
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ContractEntity {
    + id: string
    + projectId: string
    + title: string
    + contractUrl: string
    + status: ContractStatus
    + createdAt: Date
    + sourceSpecId: string | null
    + archiveStoragePath: string | null
    + archivePersistedAt: Date | null
    + archiveDocumentHash: string | null
    ...
    --
}

