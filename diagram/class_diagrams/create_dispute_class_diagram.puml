@startuml Create_Dispute_Class_Diagram
title Create Dispute - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class CreateDisputeModal {
    - milestoneId: string
    - projectId: string
    - currentUserId: string
    - projectMembers: object[]
    --
    + CreateDisputeModal(props: CreateDisputeModalProps): JSX.Element
}

class CreateDisputeWizard {
    - step: 1 | 2 | 3
    - selectedCategory: DisputeCategory | null
    - customReason: string
    - selectedDefendant: string
    - files: File[]
    - isSubmitting: boolean
    --
    + CreateDisputeWizard(props: CreateDisputeWizardProps): JSX.Element
    + handleSubmit(): Promise<void>
}

class createDispute {
    --
    + createDispute(payload: CreateDisputeDto): Promise<DisputeSummary>
    + uploadDisputeEvidence(disputeId: string, file: File): Promise<any>
    ...
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + createDisputes(user: UserEntity, createDisputes: CreateDisputeDto): Promise<any>
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    - projectRepo: Repository<ProjectEntity>
    - userRepo: Repository<UserEntity>
    --
    + create(raisedBy: string, dto: CreateDisputeDto): Promise<DisputeEntity>
    ...
}

class CreateDisputeDto {
    + milestoneId: string
    + projectId: string
    + reason: string
    + category: DisputeCategory
    + defendantId: string
    + evidence: string[]
    + disputedAmount?: number
    + parentDisputeId?: string
    + disclaimerAccepted: boolean
    + disclaimerVersion?: string
    --
}

class DisputeEntity {
    + id: string
    + projectId: string
    + milestoneId: string
    + raisedById: string
    + defendantId: string
    + category: DisputeCategory
    + reason: string
    + status: DisputeStatus
    --
}

class ProjectEntity {
    + id: string
    + clientId: string
    + brokerId: string | null
    + freelancerId: string | null
    + status: ProjectStatus
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    --
}

CreateDisputeModal ..> CreateDisputeWizard
CreateDisputeWizard ..> createDispute
createDispute ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService
DisputesController ..> CreateDisputeDto

DisputesService ..> CreateDisputeDto
DisputesService ..> DisputeEntity
DisputesService ..> ProjectEntity
DisputesService ..> UserEntity

@enduml
