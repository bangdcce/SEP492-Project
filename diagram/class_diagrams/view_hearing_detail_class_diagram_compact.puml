@startuml View_Hearing_Detail_Class_Diagram
title View Hearing Detail - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffHearingRoomPage {
    --
    + StaffHearingRoomPage(): JSX.Element
}

class HearingRoom {
    - workspace: HearingWorkspaceSummary | null
    - messages: LocalMessage[]
    - loading: boolean
    --
    + HearingRoom(props: HearingRoomProps): JSX.Element
    + refreshWorkspace(silent?: boolean): Promise<void>
}

class getHearingWorkspace {
    --
    + getHearingWorkspace(hearingId: string): Promise<HearingWorkspaceSummary>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class HearingController {
    - hearingService: HearingService
    --
    + getHearingWorkspace(hearingId: string, user: UserEntity): Promise<any>
    - parseLifecycleFilter(raw?: string): HearingLifecycleFilter
    + scheduleHearing(@Body()
    + validateSchedule(@Body()
}

class HearingService {
    - hearingRepository: Repository<DisputeHearingEntity>
    - participantRepository: Repository<HearingParticipantEntity>
    --
    + getHearingWorkspace(hearingId: string, user: UserEntity): Promise<HearingWorkspaceSummary>
    + getHearingById(hearingId: string, user: UserEntity): Promise<any>
    + ensureHearingAccess(hearingId: string, user: UserEntity): Promise<DisputeHearingEntity>
    + onModuleInit(): Promise<void>
    - normalizeMeetingLink(value?: string | null): string | undefined
    - buildDocketForDispute(disputeId: string, disputeStatus?: DisputeStatus | null)
    + isHearingInviteDeclined(hearingId: string, userId: string): Promise<boolean>
    - calculateResponseDeadline(scheduledAt: Date, isEmergency: boolean): Date
    - getMinimumAttendanceMinutes(durationMinutes: number): number
    - getParticipantOnlineMinutes(participant: HearingParticipantEntity, asOf: Date): number
    ...
}

class HearingWorkspaceSummary {
    + hearing: DisputeHearingSummary
    + phase: object
    + evidenceIntake: object
    + dossier: HearingWorkspaceDossier
    + evidence: DisputeEvidence[]
    + messages: DisputeMessage[]
    + statements: HearingStatementSummary[]
    + questions: HearingQuestionSummary[]
    + timeline: HearingTimelineEvent[]
    + attendance: HearingAttendanceSummary | null
    --
}

class DisputeHearingEntity {
    + id: string
    + disputeId: string
    + status: HearingStatus
    + scheduledAt: Date
    + moderatorId?: string | null
    + isChatRoomActive: boolean
    + isEvidenceIntakeOpen: boolean
    + startedAt: Date
    + endedAt: Date
    + externalMeetingLink: string
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

StaffHearingRoomPage ..> HearingRoom
HearingRoom ..> getHearingWorkspace
getHearingWorkspace ..> ApiClient
ApiClient ..> HearingController
HearingController --> HearingService
HearingController ..> UserEntity

HearingRoom ..> HearingWorkspaceSummary
HearingService ..> HearingWorkspaceSummary
HearingService ..> DisputeHearingEntity
HearingService ..> UserEntity

@enduml
