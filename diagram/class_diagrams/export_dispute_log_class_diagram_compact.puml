    + getDisputeStats()
    + getQueueCount(@GetUser()
    + getQueueDisputes(@GetUser()
    + getCaseloadDisputes(@GetUser()
    + getSchedulingWorklist(@GetUser()
    + getDisputeActionCatalog()
    ...
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    - evidenceRepo: Repository<DisputeEvidenceEntity>
    - auditLogsService: AuditLogsService
    --
    + exportDisputeDossier(disputeId: string, userId: string, userRole: UserRole): Promise<{ buffer: Buffer; fileName: string }>
    + getDisputeDossier(disputeId: string, userId: string, userRole: UserRole): Promise<any>
    + getVerdict(disputeId: string, userId: string, userRole: UserRole)
    - buildVerdictAcceptanceKey(disputeId: string, verdictId: string): string
    + getPublicRecord(disputeId: string)
    - sanitizePublicText(value: string | null | undefined): string | null
    - toPublicRoleAlias(role: UserRole | null | undefined): string
    - buildPublicCaseNumber(disputeId: string): string
    - ensureLegacyFlowAllowed(disputeId: string): Promise<void>
    - isFeatureEnabled(name: string, defaultValue: boolean = false): boolean
    ...
}

class AuditLogsService {
    --
    + findAll(filters: object): Promise<any>
    + logLogin(actorId: string, metadata: Record<string, unknown>, req?: RequestContext)
    + logRegistration(actorId: string, metadata: Record<string, unknown>, req?: RequestContext)
    + logLogout(actorId: string, req?: RequestContext)
    + logSystemIncident(input: LogSystemIncidentInput)
    + log(payload: AuditLogPayload, repository?: Repository<AuditLogEntity>)
    + logOrThrow(payload: AuditLogPayload, repository?: Repository<AuditLogEntity>)
    + findOne(id: string)
    + getTimeline(id: string)
    + exportLogs(queryDto: GetAuditLogsDto): Promise<
    ...
}

class DisputeDossier {
    + dispute: object
    + projectContext: object
    + contracts: object[]
    + timeline: object[]
    + contradictionHints: object[]
    + pendingActions: object[]
    + hearings: object[]
    --
}

class DisputeEntity {
    + id: string
    + projectId: string
    + raisedById: string
    + defendantId: string
    + status: DisputeStatus
    + milestoneId: string
    + priority: DisputePriority
    + reason: string
    + messages: string
    + defendantRespondedAt: Date
    ...
    --
}

class DisputeEvidenceEntity {
    + id: string
    + disputeId: string
    + uploaderId: string
    + fileName: string
    + mimeType: string
    + fileSize: number
    + storagePath: string
    + uploadedAt: Date
    + isFlagged: boolean
    + uploaderRole: string
    ...
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    + email: string
    + passwordHash: string
    + fullName: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

DisputeDetailHub ..> exportDisputeDossier
DisputeDetailHub ..> triggerBlobDownload
exportDisputeDossier ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService
DisputesController ..> UserEntity

DisputesService ..> AuditLogsService
DisputesService ..> DisputeDossier
DisputesService ..> DisputeEntity
DisputesService ..> DisputeEvidenceEntity

@enduml
