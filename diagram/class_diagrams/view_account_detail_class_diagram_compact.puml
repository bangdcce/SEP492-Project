@startuml View_Account_Detail_Class_Diagram
title View Account Detail - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ApiClient {
    - client: AxiosInstance
    --
    + get(url: string): Promise<any>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    + bootstrapSession(): Promise<
    ...
}

class AdminUsersPage {
    - selectedUser: any
    - loading: boolean
    --
    + openDetail(userId: string): Promise<void>
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean
}

class RolesGuard {
    --
    + canActivate(context: any): boolean
}

class UsersController {
    - usersService: UsersService
    --
    + getUserDetail(userId: string): any
    + getAllUsers(@Query()
    + getUserStatistics()
}

class UsersService {
    - userRepo: Repository
    - kycRepo: Repository
    --
    + getUserDetail(userId: string): any
    + getAllUsers(filters: UserFilterDto)
    + banUser(userId: string, adminId: string, dto: BanUserDto)
    + unbanUser(userId: string, adminId: string, dto: UnbanUserDto)
    + resetUserPassword(userId: string, adminId: string, dto: ResetUserPasswordDto)
    + getUserStatistics()
}

class KycController {
    - kycService: KycService
    --
    + getKycByIdWithWatermark(id: string, user: any, req: any, reason: string, reasonDetails: string): any
    + getMyKyc(@GetUser('id')
    + getKycById(@Param('id', ParseUUIDPipe)
    + approveKyc(@Param('id', ParseUUIDPipe)
}

class KycService {
    - kycRepo: Repository
    - auditLogRepo: Repository
    --
    + getKycByIdWithWatermark(id: string, reviewerId: string, reviewerEmail: string, reviewerRole: string, ipAddress: string, sessionId: string, userAgent: string, reason: string, reasonDetails: string): any
    + getMyKyc(userId: string)
    + getAllKyc(status?: KycStatus, page = 1, limit = 20)
    + getKycById(id: string)
    + approveKyc(id: string, adminId: string)
    + rejectKyc(id: string, adminId: string, dto: RejectKycDto)
    + hasVerifiedKyc(userId: string): Promise<boolean>
    - normalizeString(str: string | undefined | null): string
    - levenshteinDistance(str1: string, str2: string): number
    - calculateSimilarity(str1: string, str2: string): number
}

class SupabaseStorageUtil {
    --
    + getSignedUrl(storagePath: string, expiresIn: number): Promise<string>
    + downloadWithWatermark(storagePath: string, watermarkOptions: WatermarkOptions): Promise<Buffer>
}

class WatermarkUtil {
    --
    + addWatermark(imageBuffer: Buffer, options: WatermarkOptions): Promise<Buffer>
}

class WatermarkOptions {
    + reviewerEmail: string
    + reviewerRole: string
    + ipAddress: string
    + sessionId: string
    + timestamp: Date
    + kycId: string
    --
}

class Buffer {
    + length: number
    --
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + isBanned: boolean
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ProfileEntity {
    + id: string
    + userId: string
    + phoneNumber: string
    + avatarUrl: string
    + bio: string
    + companyName: string
    + skills: string[]
    + linkedinUrl: string
    + cvUrl: string
    + bankInfo: Record<string, any>
    --
}


class KycVerificationEntity {
    + id: string
    + userId: string
    + status: KycStatus
    + documentFrontUrl: string
    + documentBackUrl: string
    + selfieUrl: string
    + documentType: DocumentType
    + dateOfBirth: Date | null
    + reviewedAt: Date
    + createdAt: Date
    --
}


class AuditLogEntity {
    + id: string
    + actorId: string
    + action: string
    + entityType: string
    + entityId: string
    + ipAddress: string
    + userAgent: string
    + createdAt: Date
    + requestId: string | null
    + sessionId: string | null
    ...
    --
}

AdminUsersPage ..> ApiClient
ApiClient ..> UsersController
UsersController ..> JwtAuthGuard
UsersController ..> RolesGuard
UsersController --> UsersService
UsersService --> Repository
UsersService ..> UserEntity
UsersService ..> ProfileEntity
UsersService ..> KycVerificationEntity
UsersService ..> SupabaseStorageUtil
KycController --> KycService
KycService --> Repository
KycService ..> SupabaseStorageUtil
SupabaseStorageUtil ..> WatermarkUtil
WatermarkUtil ..> WatermarkOptions
SupabaseStorageUtil ..> Buffer
KycService ..> AuditLogEntity
KycVerificationEntity -- KycStatus
UserEntity -- UserRole

@enduml
