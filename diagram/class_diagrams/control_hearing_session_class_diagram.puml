@startuml Control_Hearing_Session_Class_Diagram
title Control Hearing Session - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffHearingRoomPage {
    --
    + StaffHearingRoomPage(): JSX.Element
}

class HearingRoom {
    - workspace: HearingWorkspaceSummary | null
    - speakerUpdating: boolean
    - pauseUpdating: boolean
    - resumeUpdating: boolean
    - ending: boolean
    --
    + HearingRoom(props: HearingRoomProps): JSX.Element
    + onStartSession(): Promise<void>
    + onPauseSession(reason: string): Promise<void>
    + onResumeSession(): Promise<void>
    + onEndSession(data: object): Promise<void>
    + onExtendSession(additionalMinutes: number, reason: string): Promise<void>
    + onUpdateSpeakerControl(role: SpeakerRole): Promise<void>
    + onTransitionPhase(phase: string): Promise<void>
}

class ControlPane {
    - currentSpeakerRole: SpeakerRole | null
    - hearingStatus: string | null
    - canModerate: boolean
    --
    + ControlPane(props: ControlPaneProps): JSX.Element
}

class startHearing {
    --
    + startHearing(hearingId: string): Promise<any>
}

class pauseHearing {
    --
    + pauseHearing(hearingId: string, reason: string): Promise<any>
}

class resumeHearing {
    --
    + resumeHearing(hearingId: string): Promise<any>
}

class endHearing {
    --
    + endHearing(hearingId: string, input: EndHearingInput): Promise<any>
}

class extendHearingDuration {
    --
    + extendHearingDuration(hearingId: string, input: ExtendHearingInput): Promise<any>
}

class updateSpeakerControl {
    --
    + updateSpeakerControl(hearingId: string, speakerRole: SpeakerRole): Promise<any>
}

class transitionHearingPhase {
    --
    + transitionHearingPhase(hearingId: string, phase: string): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class HearingController {
    - hearingService: HearingService
    --
    + startHearing(hearingId: string, user: UserEntity): Promise<any>
    + pauseHearing(hearingId: string, dto: PauseHearingDto, user: UserEntity): Promise<any>
    + resumeHearing(hearingId: string, user: UserEntity): Promise<any>
    + endHearing(hearingId: string, dto: EndHearingDto, user: UserEntity): Promise<any>
    + extendHearing(hearingId: string, dto: ExtendHearingDto, user: UserEntity): Promise<any>
    + updateSpeakerControl(hearingId: string, dto: ModerateHearingDto, user: UserEntity): Promise<any>
    + transitionHearingPhase(hearingId: string, dto: TransitionHearingPhaseDto, user: UserEntity): Promise<any>
}

class HearingService {
    - hearingRepository: Repository<DisputeHearingEntity>
    - disputeRepository: Repository<DisputeEntity>
    --
    + startHearing(hearingId: string, actorId: string): Promise<any>
    + pauseHearing(hearingId: string, actorId: string, reason: string): Promise<any>
    + resumeHearing(hearingId: string, actorId: string): Promise<any>
    + endHearing(input: EndHearingDto, actorId: string): Promise<any>
    + extendHearingDuration(input: ExtendHearingDto, actorId: string): Promise<any>
    + updateSpeakerControl(hearingId: string, userId: string, newRole: SpeakerRole): Promise<any>
    + transitionHearingPhase(hearingId: string, phase: DisputePhase, actorId: string): Promise<any>
    ...
}

class DisputeHearingEntity {
    + id: string
    + disputeId: string
    + status: HearingStatus
    + moderatorId?: string | null
    + currentSpeakerRole?: SpeakerRole | null
    + isChatRoomActive: boolean
    + startedAt?: Date | null
    + pausedAt?: Date | null
    + endedAt?: Date | null
    --
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + phase: DisputePhase
    + assignedStaffId?: string | null
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    --
}

StaffHearingRoomPage ..> HearingRoom
HearingRoom ..> ControlPane

HearingRoom ..> startHearing
HearingRoom ..> pauseHearing
HearingRoom ..> resumeHearing
HearingRoom ..> endHearing
HearingRoom ..> extendHearingDuration
HearingRoom ..> updateSpeakerControl
HearingRoom ..> transitionHearingPhase

startHearing ..> ApiClient
pauseHearing ..> ApiClient
resumeHearing ..> ApiClient
endHearing ..> ApiClient
extendHearingDuration ..> ApiClient
updateSpeakerControl ..> ApiClient
transitionHearingPhase ..> ApiClient

ApiClient ..> HearingController
HearingController --> HearingService
HearingController ..> UserEntity

HearingService ..> UserEntity
HearingService ..> DisputeHearingEntity
HearingService ..> DisputeEntity

@enduml
