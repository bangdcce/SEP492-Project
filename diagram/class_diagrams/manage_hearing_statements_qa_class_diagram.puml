@startuml Manage_Hearing_Statements_QA_Class_Diagram
title Manage Hearing Statements & Q&A - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class HearingRoom {
    - workspace: HearingWorkspaceSummary | null
    - questionSubmitting: boolean
    - statementDialogOpen: boolean
    --
    + HearingRoom(props: HearingRoomProps): JSX.Element
    + onAskQuestion(targetUserId: string, question: string): Promise<void>
    + onAnswerQuestion(questionId: string, answer: string): Promise<void>
    + onSkipQuestion(questionId: string): Promise<void>
    + onSubmitStatement(input: object): Promise<void>
    + refreshWorkspace(silent?: boolean): Promise<void>
}

class MessageComposer {
    - questionOpen: boolean
    - questionTargetId: string
    - questionText: string
    --
    + MessageComposer(props: MessageComposerProps): JSX.Element
    + handleQuestion(): void
}

class StatementSubmissionDialog {
    - selectedType: HearingStatementType
    - sections: StatementSections
    - selectedDraftId: string | null
    --
    + StatementSubmissionDialog(props: StatementSubmissionDialogProps): JSX.Element
}

class UnifiedTimeline {
    --
    + UnifiedTimeline(props: UnifiedTimelineProps): JSX.Element
}

class submitHearingStatement {
    --
    + submitHearingStatement(hearingId: string, input: object): Promise<any>
}

class askHearingQuestion {
    --
    + askHearingQuestion(hearingId: string, input: object): Promise<any>
}

class answerHearingQuestion {
    --
    + answerHearingQuestion(hearingId: string, questionId: string, answer: string): Promise<any>
}

class cancelHearingQuestion {
    --
    + cancelHearingQuestion(hearingId: string, questionId: string): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class HearingController {
    - hearingService: HearingService
    --
    + submitStatement(hearingId: string, dto: SubmitHearingStatementDto, user: UserEntity): Promise<any>
    + askQuestion(hearingId: string, dto: AskHearingQuestionDto, user: UserEntity): Promise<any>
    + answerQuestion(hearingId: string, questionId: string, dto: AnswerHearingQuestionDto, user: UserEntity): Promise<any>
    + cancelQuestion(hearingId: string, questionId: string, user: UserEntity): Promise<any>
}

class HearingService {
    - statementRepository: Repository<HearingStatementEntity>
    - questionRepository: Repository<HearingQuestionEntity>
    - participantRepository: Repository<HearingParticipantEntity>
    --
    + submitHearingStatement(input: SubmitHearingStatementDto, userId: string): Promise<any>
    + askHearingQuestion(input: AskHearingQuestionDto, userId: string): Promise<any>
    + answerHearingQuestion(hearingId: string, questionId: string, answer: string, userId: string): Promise<any>
    + cancelHearingQuestion(hearingId: string, questionId: string, cancelledById: string): Promise<any>
    + getHearingStatements(hearingId: string, user: UserEntity, options?: object): Promise<HearingStatementSummary[]>
    + getHearingQuestions(hearingId: string, user: UserEntity): Promise<HearingQuestionSummary[]>
    ...
}

class HearingStatementEntity {
    + id: string
    + hearingId: string
    + participantId: string
    + type: HearingStatementType
    + content: string
    + status: HearingStatementStatus
    + createdAt: Date
    --
}

class HearingQuestionEntity {
    + id: string
    + hearingId: string
    + askedById: string
    + targetUserId: string
    + question: string
    + answer?: string | null
    + status: HearingQuestionStatus
    + createdAt: Date
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    --
}

HearingRoom ..> MessageComposer
HearingRoom ..> StatementSubmissionDialog
HearingRoom ..> UnifiedTimeline

HearingRoom ..> submitHearingStatement
HearingRoom ..> askHearingQuestion
HearingRoom ..> answerHearingQuestion
HearingRoom ..> cancelHearingQuestion

MessageComposer ..> askHearingQuestion
StatementSubmissionDialog ..> submitHearingStatement
UnifiedTimeline ..> answerHearingQuestion
UnifiedTimeline ..> cancelHearingQuestion

submitHearingStatement ..> ApiClient
askHearingQuestion ..> ApiClient
answerHearingQuestion ..> ApiClient
cancelHearingQuestion ..> ApiClient

ApiClient ..> HearingController
HearingController --> HearingService
HearingController ..> UserEntity

HearingService ..> UserEntity
HearingService ..> HearingStatementEntity
HearingService ..> HearingQuestionEntity

@enduml
