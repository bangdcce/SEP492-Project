@startuml Report_Dispute_Class_Diagram
title Report Dispute - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class DisputeDetailHub {
    - disputeId?: string
    - requestDialogMode: "impact-review" | "support-escalation" | "admin-oversight" | "neutral-panel" | null
    - reviewReason: string
    - reviewImpactSummary: string
    - reviewDialogOpen: boolean
    - reviewSubmitting: boolean
    --
    + DisputeDetailHub(props: DisputeDetailHubProps): JSX.Element
    + handleReviewRequestSubmit(): Promise<void>
}

class submitDisputeReviewRequest {
    --
    + submitDisputeReviewRequest(disputeId: string, input: object): Promise<any>
}

class submitDisputeEscalationRequest {
    --
    + submitDisputeEscalationRequest(disputeId: string, input: object): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + submitReviewRequest(id: string, dto: ReviewRequestDto, user: UserEntity): Promise<any>
    + submitEscalationRequest(id: string, dto: RequestEscalationDto, user: UserEntity): Promise<any>
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    - noteRepo: Repository<DisputeNoteEntity>
    --
    + submitReviewRequest(userId: string, userRole: UserRole, disputeId: string, dto: ReviewRequestDto): Promise<DisputeNoteEntity>
    + submitEscalationRequest(userId: string, userRole: UserRole, disputeId: string, dto: RequestEscalationDto): Promise<DisputeNoteEntity>
    + assertDisputeAccess(dispute: DisputeEntity, userId: string, userRole: UserRole): Promise<void>
    ...
}

class ReviewRequestDto {
    + reason: string
    + impactSummary?: string
    + evidenceIds?: string[]
    --
}

class RequestEscalationDto {
    + kind: DisputeEscalationRequestKind
    + reason: string
    + impactSummary?: string
    + evidenceIds?: string[]
    --
}

class DisputeEntity {
    + id: string
    + projectId: string
    + raisedById: string
    + defendantId: string
    + assignedStaffId?: string
    + escalatedToAdminId?: string
    + status: DisputeStatus
    --
}

class DisputeNoteEntity {
    + id: string
    + disputeId: string
    + authorId: string
    + authorRole: UserRole
    + content: string
    + isInternal: boolean
    + noteType: string
    + attachments: string[]
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    + fullName: string
    + email: string
    --
}

DisputeDetailHub ..> submitDisputeReviewRequest
DisputeDetailHub ..> submitDisputeEscalationRequest
submitDisputeReviewRequest ..> ApiClient
submitDisputeEscalationRequest ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService
DisputesController ..> ReviewRequestDto
DisputesController ..> RequestEscalationDto
DisputesController ..> UserEntity

DisputesService ..> ReviewRequestDto
DisputesService ..> RequestEscalationDto
DisputesService ..> DisputeEntity
DisputesService ..> DisputeNoteEntity

@enduml
