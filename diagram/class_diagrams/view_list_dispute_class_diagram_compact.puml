@startuml View_List_Dispute_Class_Diagram
title View List Dispute - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffCaseloadPage {
    --
    + StaffCaseloadPage(): JSX.Element
}

class StaffCaseloadBoard {
    --
    + StaffCaseloadBoard(): JSX.Element
}

class StaffDisputeBoard {
    - disputes: DisputeSummary[]
    - loading: boolean
    - searchValue: string
    - viewFilter: ViewFilter
    - page: number
    --
    + StaffDisputeBoard(props: StaffDisputeBoardProps): JSX.Element
    + loadDisputes(): Promise<void>
}

class getCaseloadDisputes {
    --
    + getCaseloadDisputes(filters?: DisputeFilters, options?: CacheOptions): Promise<PaginatedDisputesResponse>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + getCaseloadDisputes(user: UserEntity, filters: DisputeFilterDto): Promise<PaginatedDisputesResponse>
    + createDisputes(@GetUser()
    + getListDisputes(@GetUser()
    + getMyDisputes(@GetUser()
    + getDisputeStats()
    + getQueueCount(@GetUser()
    + getQueueDisputes(@GetUser()
    + getSchedulingWorklist(@GetUser()
    + getDisputeActionCatalog()
    + getProjectionDiagnostics(@Query('disputeId')
    ...
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    --
    + getCaseloadDisputes(filters?: DisputeFilterDto): Promise<PaginatedDisputesResponse>
    + getAll(filters?: DisputeFilterDto): Promise<PaginatedDisputesResponse>
    + applyFiltersAndPaginate(qb: any, filters: DisputeFilterDto, context?: object): Promise<PaginatedDisputesResponse>
    + getVerdict(disputeId: string, userId: string, userRole: UserRole)
    - buildVerdictAcceptanceKey(disputeId: string, verdictId: string): string
    + getPublicRecord(disputeId: string)
    - sanitizePublicText(value: string | null | undefined): string | null
    - toPublicRoleAlias(role: UserRole | null | undefined): string
    - buildPublicCaseNumber(disputeId: string): string
    - ensureLegacyFlowAllowed(disputeId: string): Promise<void>
    ...
}

class DisputeFilterDto {
    + page?: number
    + limit?: number
    + sortBy?: string
    + sortOrder?: string
    + statusIn?: string[]
    + priority?: string
    + category?: string
    + assignedStaffId?: string
    --
}

class DisputeSummary {
    + id: string
    + displayCode?: string
    + displayTitle?: string
    + status: DisputeStatus
    + caseStage?: string
    + isAppealed?: boolean
    + project?: object
    + latestHearing?: object
    + projectId: string
    + milestoneId: string
    ...
    --
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + priority?: DisputePriority
    + category: DisputeCategory
    + assignedStaffId?: string | null
    + projectId: string
    + updatedAt: Date
    + milestoneId: string
    + raisedById: string
    + defendantId: string
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ProjectEntity {
    + id: string
    + title: string
    + clientId: string
    + freelancerId?: string | null
    + brokerId?: string | null
    + requestId: string
    + brokerId: string
    + freelancerId: string
    + staffId: string | null
    + staffInviteStatus: ProjectStaffInviteStatus | null
    ...
    --
}

StaffCaseloadPage ..> StaffCaseloadBoard
StaffCaseloadBoard ..> StaffDisputeBoard
StaffDisputeBoard ..> getCaseloadDisputes
getCaseloadDisputes ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService
DisputesController ..> UserEntity
DisputesController ..> DisputeFilterDto

StaffDisputeBoard ..> DisputeSummary
DisputesService ..> DisputeFilterDto
DisputesService ..> DisputeSummary
DisputesService ..> DisputeEntity
DisputesService ..> UserEntity
DisputesService ..> ProjectEntity

@enduml
