@startuml Make_Request_Private_Class_Diagram
title Make Request Private - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class RequestDetailPage {
    - id: string | undefined
    - request: ProjectRequest | null
    - isUpdatingStatus: boolean
    - showDraftAlert: boolean
    --
    + handleStatusChange(newStatus: RequestStatus): Promise<void>
    + handleRevertToDraft(): Promise<void>
}

class RequestDraftAlert {
    --
    + onCancel(): void
    + onConfirm(): void
}

class UpdateProjectRequestDto {
    + title?: string
    + description?: string
    + budgetRange?: string
    + requestedDeadline?: string
    + intendedTimeline?: string
    + techPreferences?: string
    + status?: string
    + wizardProgressStep?: number
    + attachments?: ProjectRequestAttachment[]
    + answers?: CreateProjectRequestAnswerDto[]
    --
}

class wizardService {
    ...
    --
    + getQuestions(): Promise<WizardQuestion[]>
    + submitRequest(data: CreateProjectRequestDto): Promise<any>
    + uploadFiles(files: File[], category: "requirements" | "attachments"): Promise<UploadProjectRequestFilesResult>
    + updateRequest(id: string, data: Partial<CreateProjectRequestDto>): Promise<any>
    + publishRequest(id: string): Promise<any>
    + getDrafts(): Promise<any>
    + getMatches(requestId: string): Promise<any>
    + getRequests(): Promise<any>
    + getRequestById(id: string): Promise<any>
    + inviteBroker(requestId: string, brokerId: string): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + put<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + delete<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean> | any
}

class RolesGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean>
}

class ProjectRequestsController {
    - projectRequestsService: ProjectRequestsService
    --
    + create(userId: string, createDto: CreateProjectRequestDto, req: RequestContext): Promise<ProjectRequestEntity>
    + getProjectRequests(user: UserEntity, status?: string): Promise<any>
    + findMyDrafts(userId: string): Promise<ProjectRequestEntity[]>
    + getMyInvitations(user: UserEntity): Promise<any>
    + getFreelancerRequestAccessList(user: UserEntity): Promise<any>
    + findMatches(id: string): Promise<any>
    + getOne(id: string, user: UserEntity): Promise<any>
    + assignBroker(id: string, brokerId: string, req: RequestContext): Promise<any>
    + update(id: string, updateDto: UpdateProjectRequestDto, user: UserEntity, req: RequestContext): Promise<ProjectRequestEntity>
    + publish(id: string, userId: string, req: RequestContext): Promise<any>
    ...
}

class AuditLogsService {
    --
    + logCreate(entityType: string, entityId: string, afterData: Record<string, unknown>, req: RequestContext): Promise<void>
    + logUpdate(entityType: string, entityId: string, beforeData: Record<string, unknown>, afterData: Record<string, unknown>, req: RequestContext): Promise<void>
    + logDelete(entityType: string, entityId: string, beforeData: Record<string, unknown>, req: RequestContext): Promise<void>
    + logLogin(actorId: string, metadata: Record<string, unknown>, req?: RequestContext)
    + logRegistration(actorId: string, metadata: Record<string, unknown>, req?: RequestContext)
    + logLogout(actorId: string, req?: RequestContext)
    + logSystemIncident(input: LogSystemIncidentInput)
    + log(payload: AuditLogPayload, repository?: Repository<AuditLogEntity>)
    + logOrThrow(payload: AuditLogPayload, repository?: Repository<AuditLogEntity>)
    + findAll(queryDto: GetAuditLogsDto)
    ...
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + find(options?: any): Promise<any[]>
    + create(data: any): any
    + save(entity: any): Promise<any>
    + update(criteria: any, partial: any): Promise<any>
    + delete(criteria: any): Promise<any>
}



class ProjectRequestEntity {
    + id: string
    + clientId: string
    + title: string
    + description: string
    + budgetRange: string
    + intendedTimeline: string
    + requestedDeadline: string | null
    + attachments: ProjectRequestAttachmentMetadata[] | null
    + status: RequestStatus
    + brokerId: string
    ...
    --
}

class BrokerProposalEntity {
    + id: string
    + requestId: string
    + brokerId: string
    + status: ProposalStatus
    + coverLetter: string | null
    + createdAt: Date
    + updatedAt: Date
    + request: ProjectRequestEntity
    + broker: UserEntity
    --
}

class ProjectRequestsService {
    - requestRepo: Repository<ProjectRequestEntity>
    - answerRepo: Repository<ProjectRequestAnswerEntity>
    - brokerProposalRepo: Repository<BrokerProposalEntity>
    - freelancerProposalRepo: Repository<ProjectRequestProposalEntity>
    - auditLogsService: AuditLogsService
    - matchingService: MatchingService
    - quotaService: QuotaService
    - notificationsService: NotificationsService
    - contractsService: ContractsService
    - requestChatService: RequestChatService
    ...
    --
    + create(clientId: string, dto: CreateProjectRequestDto, req: RequestContext): Promise<ProjectRequestEntity | null>
    + findAll(status?: RequestStatus): Promise<any[]>
    + update(id: string, dto: UpdateProjectRequestDto, user?: UserEntity, req?: RequestContext): Promise<ProjectRequestEntity>
    + publish(requestId: string, userId: string, req?: RequestContext): Promise<any>
    + findAllByClient(clientId: string): Promise<any[]>
    + findDraftsByClient(clientId: string): Promise<ProjectRequestEntity[]>
    + findOne(id: string, user?: UserEntity): Promise<any>
    + findMatches(id: string, userId?: string): Promise<any>
    + inviteBroker(requestId: string, brokerId: string, message?: string, inviterId?: string): Promise<any>
    + getInvitationsForUser(userId: string, role: UserRole): Promise<any>
    ...
}

RequestDetailPage ..> RequestDraftAlert
RequestDetailPage ..> wizardService
RequestDetailPage ..> RequestStatus

RequestDraftAlert ..> RequestStatus

wizardService ..> ApiClient
wizardService ..> UpdateProjectRequestDto

ProjectRequestsController ..> JwtAuthGuard
ProjectRequestsController ..> RolesGuard
ProjectRequestsController --> ProjectRequestsService
ProjectRequestsController ..> UpdateProjectRequestDto

ProjectRequestsService ..> Repository
ProjectRequestsService ..> AuditLogsService
ProjectRequestsService ..> ProjectRequestEntity
ProjectRequestsService ..> BrokerProposalEntity
ProjectRequestsService ..> RequestStatus
ProjectRequestsService ..> ProposalStatus

ProjectRequestEntity --> RequestStatus
BrokerProposalEntity --> ProposalStatus

@enduml
