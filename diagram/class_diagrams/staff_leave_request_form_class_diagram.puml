@startuml Staff_Leave_Request_Form_Class_Diagram
title Staff Leave Request Form - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffLeavePage {
    - selectedMonth: string
    - startTime: string
    - endTime: string
    - reason: string
    - submitting: boolean
    - timeZone: string
    --
    + StaffLeavePage(): JSX.Element
    + validateLeaveInput(): object | null
    + handleSubmit(): Promise<void>
}

class createLeaveRequest {
    --
    + createLeaveRequest(input: CreateLeaveRequestInput): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class LeaveController {
    - leaveService: LeaveService
    --
    + createLeaveRequest(dto: CreateLeaveRequestDto, user: UserEntity): Promise<any>
}

class LeaveService {
    - leaveRequestRepository: Repository<StaffLeaveRequestEntity>
    - leavePolicyRepository: Repository<StaffLeavePolicyEntity>
    - userRepository: Repository<UserEntity>
    --
    + createLeaveRequest(dto: CreateLeaveRequestDto, requester: UserEntity): Promise<any>
    + ensureStaff(staffId: string): Promise<UserEntity>
    + resolveTimeZone(staff: UserEntity, inputTimeZone?: string): Promise<string>
    + getLeaveBalanceInternal(staffId: string, query: object, timeZone: string): Promise<any>
    ...
}

class CreateLeaveRequestDto {
    + type: LeaveType
    + startTime: string
    + endTime: string
    + reason?: string
    + staffId?: string
    + timeZone?: string
    --
}

class StaffLeaveRequestEntity {
    + id: string
    + staffId: string
    + type: LeaveType
    + status: LeaveStatus
    + startTime: Date
    + endTime: Date
    + durationMinutes: number
    + reason?: string
    + isAutoApproved: boolean
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    + timeZone?: string
    --
}

StaffLeavePage ..> createLeaveRequest
createLeaveRequest ..> ApiClient
ApiClient ..> LeaveController
LeaveController --> LeaveService
LeaveController ..> CreateLeaveRequestDto
LeaveController ..> UserEntity

LeaveService ..> CreateLeaveRequestDto
LeaveService ..> StaffLeaveRequestEntity
LeaveService ..> UserEntity

@enduml
