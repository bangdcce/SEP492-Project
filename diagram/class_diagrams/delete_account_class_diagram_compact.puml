@startuml Delete_Account_Class_Diagram
title Delete Account - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class DeleteAccountDto {
    + password: string
    --
}

class ApiClient {
    - client: AxiosInstance
    --
    + deleteJson(url: string, body: any, withCredentials: boolean): Promise<any>
    + getJson(url: string, withCredentials: boolean): Promise<any>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class ProfilePage {
    --
    + openDeleteAccountModal(): void
}

class DeleteAccountModal {
    - step: number
    - loading: boolean
    - password: string
    --
    + checkDeletionAllowed(): Promise<void>
    + proceed(): void
    + confirmDelete(dto: DeleteAccountDto): Promise<void>
}

class AuthController {
    - authService: AuthService
    - cookiePolicy: AuthCookiePolicy
    --
    + getDeletionObligations(userId: string): any
    + deleteAccount(userId: string, dto: DeleteAccountDto): any
    + verifyEmail(@Query('token')
    + resendVerification(@Body('email')
    + getProfile(@Req()
    + getSession(@Req()
    + forgotPassword(@Body(ValidationPipe)
    + verifyOtp(@Body(ValidationPipe)
    + resetPassword(@Body(ValidationPipe)
    + checkObligations(@Req()
}

class AuthService {
    - userRepo: Repository
    - profileRepo: Repository
    - sessionRepo: Repository
    - projectRepo: Repository
    - walletRepo: Repository
    --
    + getDeletionObligations(userId: string): any
    + deleteAccount(userId: string, dto: DeleteAccountDto): any
    + logout(userId: string, refreshToken?: string): Promise<LogoutResponseDto>
    + validateUser(userId: string): Promise<UserEntity | null>
    + refreshToken(oldRefreshToken: string): Promise<
    - cleanupExpiredSessions(userId: string): Promise<void>
    + forgotPassword(forgotPasswordDto: ForgotPasswordDto): Promise<ForgotPasswordResponseDto>
    + verifyOtp(verifyOtpDto: VerifyOtpDto): Promise<VerifyOtpResponseDto>
    + resetPassword(resetPasswordDto: ResetPasswordDto): Promise<ResetPasswordResponseDto>
    + findUserWithProfile(userId: string): Promise<UserEntity | null>
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + count(options: any): Promise<number>
    + save(entity: any): Promise<any>
    + update(id: any, partial: any): Promise<any>
    + delete(criteria: any): Promise<any>
}

class UserEntity {
    + id: string
    + email: string
    + deletedAt: Date
    + passwordHash: string
    + fullName: string
    + role: UserRole
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ProfileEntity {
    + id: string
    + userId: string
    + avatarUrl: string
    + bio: string
    + companyName: string
    + skills: string[]
    + linkedinUrl: string
    + cvUrl: string
    + bankInfo: Record<string, any>
    + user: any
    --
}

class AuthSessionEntity {
    + id: string
    + userId: string
    + revokedAt: Date
    + refreshTokenHash: string
    + refreshTokenFingerprint: string
    + userAgent: string
    + ipAddress: string
    + isRevoked: boolean
    + expiresAt: Date
    + createdAt: Date
    ...
    --
}

class ProjectEntity {
    + id: string
    + status: string
    + requestId: string
    + clientId: string
    + brokerId: string
    + freelancerId: string
    + title: string
    + description: string
    + totalBudget: number
    + currency: string
    ...
    --
}

class WalletEntity {
    + id: string
    + userId: string
    + balance: number
    + totalDeposited: number
    + totalWithdrawn: number
    + currency: string
    + status: WalletStatus
    + createdAt: Date
    + updatedAt: Date
    + user: any
    --
}

ProfilePage ..> DeleteAccountModal
DeleteAccountModal ..> ApiClient
ApiClient ..> AuthController
AuthController --> AuthService
AuthController ..> DeleteAccountDto
AuthService --> Repository
AuthService ..> UserEntity
AuthService ..> ProfileEntity
AuthService ..> AuthSessionEntity
AuthService ..> ProjectEntity
AuthService ..> WalletEntity

@enduml
