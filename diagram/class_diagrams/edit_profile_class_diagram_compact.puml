@startuml Edit_Profile_Class_Diagram
title Edit Profile - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class UpdateProfileDto {
    + fullName: string
    + phoneNumber: string
    + bio: string
    + avatarBase64: string
    --
}

class ApiClient {
    - client: AxiosInstance
    --
    + patchJson(url: string, body: any, withCredentials: boolean): Promise<any>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    + bootstrapSession(): Promise<
    ...
}

class ProfilePage {
    - saving: boolean
    --
    + enterEditMode(): void
    + validate(dto: UpdateProfileDto): boolean
    + save(dto: UpdateProfileDto): Promise<void>
}

class AuthController {
    - authService: AuthService
    - cookiePolicy: AuthCookiePolicy
    --
    + updateProfile(userId: string, dto: UpdateProfileDto): any
    + verifyEmail(@Query('token')
    + resendVerification(@Body('email')
    + getProfile(@Req()
    + getSession(@Req()
    + forgotPassword(@Body(ValidationPipe)
    + verifyOtp(@Body(ValidationPipe)
    + resetPassword(@Body(ValidationPipe)
    + checkObligations(@Req()
    + googleAuth(@Req()
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean
}

class ValidationPipe {
    --
    + transform(value: any, metadata: any): any
}

class AuthService {
    - userRepo: Repository
    - profileRepo: Repository
    --
    + updateProfile(userId: string, dto: UpdateProfileDto): any
    + logout(userId: string, refreshToken?: string): Promise<LogoutResponseDto>
    + validateUser(userId: string): Promise<UserEntity | null>
    + refreshToken(oldRefreshToken: string): Promise<
    - cleanupExpiredSessions(userId: string): Promise<void>
    + forgotPassword(forgotPasswordDto: ForgotPasswordDto): Promise<ForgotPasswordResponseDto>
    + verifyOtp(verifyOtpDto: VerifyOtpDto): Promise<VerifyOtpResponseDto>
    + resetPassword(resetPasswordDto: ResetPasswordDto): Promise<ResetPasswordResponseDto>
    + findUserWithProfile(userId: string): Promise<UserEntity | null>
    - mapToAuthResponse(user: UserEntity): AuthResponseDto
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
    + update(id: any, partial: any): Promise<any>
}

class UserEntity {
    + id: string
    + fullName: string
    + phoneNumber: string
    + email: string
    + passwordHash: string
    + role: UserRole
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ProfileEntity {
    + id: string
    + userId: string
    + bio: string
    + avatarUrl: string
    + companyName: string
    + skills: string[]
    + linkedinUrl: string
    + cvUrl: string
    + bankInfo: Record<string, any>
    + user: any
    --
}

ProfilePage ..> ApiClient
ApiClient ..> AuthController
AuthController ..> JwtAuthGuard
AuthController ..> ValidationPipe
AuthController --> AuthService
AuthController ..> UpdateProfileDto
AuthService --> Repository
AuthService ..> UserEntity
AuthService ..> ProfileEntity

@enduml
