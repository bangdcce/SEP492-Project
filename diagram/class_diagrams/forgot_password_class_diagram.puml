@startuml Forgot_Password_Class_Diagram
title Forgot Password - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

' ======================
' Client-side
' ======================
class ForgotPasswordPage {
    - step: "phone" | "otp" | "reset"
    - email: string
    - otp: string
    - newPassword: string
    - confirmPassword: string
    - errors: Record<string, string>
    - loading: boolean
    - showNewPassword: boolean
    - showConfirmPassword: boolean
    - resendCountdown: number
    ...
    --
    + validateEmail(email: string): boolean
    + maskEmail(email: string): string
    + handleSendOTP(e: React.FormEvent): Promise<void>
    + handleResendOTP(): Promise<void>
    + handleVerifyOTP(e: React.FormEvent): Promise<void>
    + handleResetPassword(e: React.FormEvent): Promise<void>
    + handleBack(): void
    + renderPhoneStep(): any
    + renderOTPStep(): any
    + renderResetStep(): any
    ...
}

class AuthApi {
    --
    + signIn(data: SignInRequest): Promise<SignInResponse>
    + signUp(data: SignUpRequest): Promise<SignUpResponse>
    + forgotPassword(data: ForgotPasswordRequest): Promise<ForgotPasswordResponse>
    + verifyOtp(data: VerifyOtpRequest): Promise<VerifyOtpResponse>
    + resetPassword(data: ResetPasswordRequest): Promise<ResetPasswordResponse>
    + refreshToken(): Promise<{ message: string; data: Record<string, never> }>
    + signOut(): Promise<void>
    + getProfile(): Promise<any>
    + getSession(): Promise<any>
    + updateProfile(data: any): Promise<any>
    ...
}

class ForgotPasswordRequest {
    + email: string
}

class ForgotPasswordResponse {
    + message: string
    + email: string
}

class VerifyOtpRequest {
    + email: string
    + otp: string
}

class VerifyOtpResponse {
    + message: string
    + data: { message: string; isValid: boolean }
}

class ResetPasswordRequest {
    + email: string
    + otp: string
    + newPassword: string
    + confirmPassword: string
}

class ResetPasswordResponse {
    + message: string
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    --
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + put<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + delete<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

' ======================
' Server-side
' ======================
class AuthController {
    - cookiePolicy: AuthCookiePolicy
    - authService: AuthService
    --
    + login(loginDto: LoginDto, req: Request, response: Response): Promise<{ message: string; data: SecureLoginResponseDto }>
    + logout(req: AuthRequest, response: Response): Promise<{ message: string; data: null }>
    + getProfile(req: AuthRequest): Promise<{ message: string; data: AuthResponseDto }>
    + getSession(req: AuthRequest): Promise<{ message: string; data: AuthResponseDto }>
    + refreshToken(req: Request, response: Response): Promise<{ message: string; data: Record<string, never> }>
    + forgotPassword(forgotPasswordDto: ForgotPasswordDto): Promise<{ message: string; data: ForgotPasswordResponseDto }>
    + verifyOtp(verifyOtpDto: VerifyOtpDto): Promise<{ message: string; data: VerifyOtpResponseDto }>
    + resetPassword(resetPasswordDto: ResetPasswordDto): Promise<{ message: string; data: ResetPasswordResponseDto }>
    + checkObligations(req: AuthRequest): Promise<ActiveObligationsResponseDto>
    + register(registerDto: RegisterDto, ip: string, req: Request): Promise<{ message: string; data: AuthResponseDto }>
    ...
}

class ForgotPasswordDto {
    + email: string
}

class ForgotPasswordResponseDto {
    + message: string
    + email: string
    + expiresIn: number
}

class VerifyOtpDto {
    + email: string
    + otp: string
}

class VerifyOtpResponseDto {
    + message: string
    + isValid: boolean
}

class ResetPasswordDto {
    + email: string
    + otp: string
    + newPassword: string
    + confirmPassword: string
}

class ResetPasswordResponseDto {
    + message: string
}

class AuthService {
    - userRepository: Repository
    - authSessionRepository: Repository
    - emailService: EmailService
    --
    + forgotPassword(forgotPasswordDto: ForgotPasswordDto): Promise<ForgotPasswordResponseDto>
    + verifyOtp(verifyOtpDto: VerifyOtpDto): Promise<VerifyOtpResponseDto>
    + resetPassword(resetPasswordDto: ResetPasswordDto): Promise<ResetPasswordResponseDto>
    + login(loginDto: LoginDto, userAgent?: string, ipAddress?: string, timeZone?: string): Promise<LoginResponseDto>
    + logout(userId: string, refreshToken?: string): Promise<LogoutResponseDto>
    + refreshToken(oldRefreshToken: string): Promise<{ accessToken: string; refreshToken: string }>
    - buildRefreshTokenFingerprint(token: string): string
    - findSessionByRefreshToken(token: string): Promise<AuthSessionEntity | null>
    - createAuthSession(userId: string, refreshToken: string, userAgent?: string, ipAddress?: string): Promise<void>
    - cleanupExpiredSessions(userId: string): Promise<void>
    + findUserWithProfile(userId: string): Promise<UserEntity | null>
    ...
}

class EmailService {
    - logger: Logger
    - transporter: nodemailer.Transporter
    --
    - initializeTransporter()
    + generateOTP(): string
    + sendOTP(email: string, otp: string): Promise<void>
    + sendPlatformNotification(input: any): Promise<void>
    - getOTPEmailTemplate(otp: string, appName: string): string
    + maskEmail(email: string): string
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + find(options: any): Promise<any[]>
    + create(data: any): any
    + save(entity: any): Promise<any>
    + update(criteria: any, partial: any): Promise<any>
    + delete(criteria: any): Promise<any>
    ...
}

class UserEntity {
    + id: string
    + email: string
    + status: UserStatus
    + isBanned: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    + passwordHash: string
    + fullName: string
    + role: UserRole
    + emailVerifiedAt: Date
    ...
}

class AuthSessionEntity {
    + id: string
    + userId: string
    + refreshTokenHash: string
    + refreshTokenFingerprint: string
    + isRevoked: boolean
    + revokedAt: Date
    + userAgent: string
    + ipAddress: string
    + expiresAt: Date
    + lastUsedAt: Date
    ...
}

' ======================
' Relationships
' ======================
ForgotPasswordPage ..> AuthApi : dependency
AuthApi ..> ApiClient : dependency
ApiClient ..> AuthController : dependency

ForgotPasswordPage ..> ForgotPasswordRequest
ForgotPasswordPage ..> VerifyOtpRequest
ForgotPasswordPage ..> ResetPasswordRequest

AuthController --> AuthService
AuthController ..> ForgotPasswordDto
AuthController ..> VerifyOtpDto
AuthController ..> ResetPasswordDto
AuthController ..> ForgotPasswordResponseDto
AuthController ..> VerifyOtpResponseDto
AuthController ..> ResetPasswordResponseDto

AuthService --> Repository
AuthService --> EmailService
AuthService ..> ForgotPasswordDto
AuthService ..> VerifyOtpDto
AuthService ..> ResetPasswordDto
AuthService ..> ForgotPasswordResponseDto
AuthService ..> VerifyOtpResponseDto
AuthService ..> ResetPasswordResponseDto
AuthService ..> UserEntity
AuthService ..> AuthSessionEntity

@enduml
