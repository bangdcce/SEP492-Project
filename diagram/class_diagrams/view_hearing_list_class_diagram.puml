@startuml View_Hearing_List_Class_Diagram
title View Hearing List - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffHearingsPage {
    - hearings: DisputeHearingSummary[]
    - loading: boolean
    - schemaErrorMessage: string | null
    --
    + StaffHearingsPage(props: StaffHearingsPageProps): JSX.Element
    + loadHearings(): Promise<void>
    + handleOpenDispute(disputeId: string): void
    + handleOpenRoom(hearingId: string): void
}

class getMyHearings {
    --
    + getMyHearings(params?: HearingListQuery): Promise<DisputeHearingSummary[]>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class HearingController {
    - hearingService: HearingService
    --
    + listMyHearings(user: UserEntity, statusRaw?: string, fromRaw?: string, toRaw?: string, lifecycleRaw?: string): Promise<any>
}

class HearingService {
    - hearingRepository: Repository<DisputeHearingEntity>
    - participantRepository: Repository<HearingParticipantEntity>
    --
    + getHearingsForUser(user: UserEntity, options?: object): Promise<DisputeHearingSummary[]>
    + mapHearingSummary(hearing: DisputeHearingEntity, confirmationSummaryByHearingId: Map<string, HearingParticipantConfirmationSummary>, docketEntry?: object): DisputeHearingSummary
    + applyLifecycleFilter(hearings: DisputeHearingEntity[], lifecycle?: HearingLifecycleFilter): DisputeHearingEntity[]
    ...
}

class DisputeHearingSummary {
    + id: string
    + disputeId: string
    + status: HearingStatus
    + scheduledAt: string
    + scheduledEndAt?: string | null
    + moderatorId?: string | null
    + agenda?: string | null
    + hearingNumber?: number
    + participants?: HearingParticipantSummary[]
    + dispute?: HearingDisputeSummary
    ...
}

class DisputeHearingEntity {
    + id: string
    + disputeId: string
    + status: HearingStatus
    + scheduledAt: Date
    + scheduledEndAt?: Date | null
    + moderatorId?: string | null
    + agenda?: string | null
    + hearingNumber?: number
    --
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + phase: DisputePhase
    + priority?: string
    + assignedStaffId?: string | null
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    --
}

StaffHearingsPage ..> getMyHearings
getMyHearings ..> ApiClient
ApiClient ..> HearingController
HearingController --> HearingService
HearingController ..> UserEntity

HearingService ..> UserEntity
HearingService ..> DisputeHearingEntity
HearingService ..> DisputeEntity
HearingService ..> DisputeHearingSummary

StaffHearingsPage ..> DisputeHearingSummary

@enduml
