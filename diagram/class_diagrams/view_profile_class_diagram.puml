@startuml View_Profile_Class_Diagram
title View Profile - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ApiClient {
    + getJson(url: string, withCredentials: boolean): Promise<any>
}

class ProfilePage {
    - loading: boolean
    + loadProfile(): Promise<void>
    + renderProfile(): void
}

class AuthController {
    - authService: AuthService
    + getProfile(userId: string): any
}

class JwtAuthGuard {
    + canActivate(context: any): boolean
}

class AuthService {
    - userRepo: Repository
    - profileRepo: Repository
    + getProfile(userId: string): any
}

class Repository {
    + findOne(options: any): Promise<any>
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + isVerified: boolean
}

class ProfileEntity {
    + id: string
    + userId: string
    + phoneNumber: string
    + avatarUrl: string
    + linkedinUrl: string
    + cvUrl: string
}

enum UserRole {
    ADMIN
    STAFF
    BROKER
    CLIENT
    FREELANCER
}

ProfilePage ..> ApiClient
ApiClient ..> AuthController
AuthController ..> JwtAuthGuard
AuthController --> AuthService
AuthService --> Repository
AuthService ..> UserEntity
AuthService ..> ProfileEntity
UserEntity -- UserRole

@enduml
