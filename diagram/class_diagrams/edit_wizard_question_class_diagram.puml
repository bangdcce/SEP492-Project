@startuml Edit_Wizard_Question_Class_Diagram
title Edit Wizard Question - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class UpdateWizardQuestionDto {
    + code: string
    + label: string
    + helpText: string
    + inputType: string
    + isActive: boolean
    + sortOrder: number
    + options: UpdateWizardOptionDto[]
}

class UpdateWizardOptionDto {
    + id: string
    + value: string
    + label: string
    + sortOrder: number
}

class ApiClient {
    + patchJson(url: string, body: any, withCredentials: boolean): Promise<any>
}

class AdminWizardQuestionsPage {
    + openEdit(id: string): void
    + save(dto: UpdateWizardQuestionDto): Promise<void>
}

class WizardAdminController {
    - wizardService: WizardService
    + updateQuestion(id: string, dto: UpdateWizardQuestionDto): any
}

class JwtAuthGuard {
    + canActivate(context: any): boolean
}

class RolesGuard {
    + canActivate(context: any): boolean
}

class WizardService {
    - questionRepo: Repository
    - optionRepo: Repository
    + updateQuestion(id: string, dto: UpdateWizardQuestionDto): any
}

class Repository {
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
    + delete(criteria: any): Promise<any>
}

class WizardQuestionEntity {
    + id: string
    + code: string
    + label: string
    + helpText: string
    + inputType: string
    + isActive: boolean
    + sortOrder: number
}

class WizardOptionEntity {
    + id: string
    + questionId: string
    + value: string
    + label: string
    + sortOrder: number
}

AdminWizardQuestionsPage ..> ApiClient
ApiClient ..> WizardAdminController
WizardAdminController ..> JwtAuthGuard
WizardAdminController ..> RolesGuard
WizardAdminController --> WizardService
WizardAdminController ..> UpdateWizardQuestionDto
WizardService --> Repository
WizardService ..> WizardQuestionEntity
WizardService ..> WizardOptionEntity
UpdateWizardQuestionDto *-- UpdateWizardOptionDto

@enduml
