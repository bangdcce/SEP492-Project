@startuml Delete_Wizard_Question_Class_Diagram
title Delete Wizard Question - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ApiClient {
    - client: AxiosInstance
    --
    + delete(url: string): Promise<any>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    + bootstrapSession(): Promise<
    ...
}

class AdminWizardQuestionsPage {
    --
    + deleteQuestion(id: string): Promise<void>
}

class WizardAdminController {
    - wizardService: WizardService
    --
    + deleteQuestion(id: string): any
    + createQuestion(@Body()
    + getAllQuestions()
    + getQuestionDetail(@Param('id', ParseIntPipe)
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean
}

class RolesGuard {
    --
    + canActivate(context: any): boolean
}

class WizardService {
    - questionRepo: Repository
    - optionRepo: Repository
    --
    + deleteQuestion(id: string): any
    + getWizardData()
    + createQuestion(createDto: CreateWizardQuestionDto)
    + getAllQuestionsForAdmin()
    + getQuestionDetailForAdmin(id: number)
    + updateQuestion(id: number, updateDto: UpdateWizardQuestionDto)
}

class Repository {
    --
    + findOne(options: any): Promise<any>
    + save(entity: any): Promise<any>
}

class WizardQuestionEntity {
    + id: string
    + isActive: boolean
    + code: string
    + label: string
    + helpText: string
    + inputType: string
    + sortOrder: number
    + createdAt: Date
    + options: WizardOptionEntity[]
    + answers: ProjectRequestAnswerEntity[]
    --
}

AdminWizardQuestionsPage ..> ApiClient
ApiClient ..> WizardAdminController
WizardAdminController ..> JwtAuthGuard
WizardAdminController ..> RolesGuard
WizardAdminController --> WizardService
WizardService --> Repository
WizardService ..> WizardQuestionEntity

@enduml
