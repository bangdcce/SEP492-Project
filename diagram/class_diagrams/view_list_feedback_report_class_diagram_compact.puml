@startuml View_List_Feedback_Report_Class_Diagram
title View List Feedback Report - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class AdminReportInboxPage {
    - reportPage: PaginatedAdminReviewReports | null
    - searchQuery: string
    - loading: boolean
    --
    + AdminReportInboxPage(): JSX.Element
    + loadReports(): Promise<void>
}

class getPendingReports {
    --
    + getPendingReports(filters?: { page?: number; limit?: number }): Promise<PaginatedAdminReviewReports>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class ReportController {
    - reportService: ReportService
    --
    + findPending(page: number, limit: number): Promise<any>
    + create(@Body()
    + findOne(@Param('id')
}

class ReportService {
    - reportRepo: Repository<ReportEntity>
    - reviewRepo: Repository<ReviewEntity>
    --
    + findPending(page?: number, limit?: number): Promise<any>
    + toBoundedPositiveInt(value: number, fallback: number, max: number): number
    + create(reporterId: string, dto: CreateReportDto)
    + resolve(reportId: string, dto: ResolveReportDto, adminId: string)
    + findOne(reportId: string)
}

class PaginatedAdminReviewReports {
    + data: AdminReviewReport[]
    + total: number
    + page: number
    + limit: number
    + totalPages: number
    --
}

class AdminReviewReport {
    + id: string
    + reason: ReportReason
    + description?: string
    + status: ReviewReportStatus
    + createdAt: string
    + reporter?: ReviewReportActor | null
    + review: ReviewReportReviewSummary
    --
}

class ReportEntity {
    + id: string
    + reporterId: string
    + reviewId: string
    + reason: ReportReason
    + description?: string
    + status: ReportStatus
    + createdAt: Date
    + description: string
    + resolvedBy: string
    + adminNote: string
    ...
    --
}

class ReviewEntity {
    + id: string
    + reviewerId: string
    + comment: string
    + rating: number
    + status: ReviewStatus
    + projectId: string
    + targetUserId: string
    + weight: number
    + createdAt: Date
    + updatedAt: Date
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

AdminReportInboxPage ..> getPendingReports
AdminReportInboxPage ..> PaginatedAdminReviewReports
AdminReportInboxPage ..> AdminReviewReport

getPendingReports ..> ApiClient
ApiClient ..> ReportController
ReportController --> ReportService

ReportService ..> ReportEntity
ReportService ..> ReviewEntity
ReportService ..> UserEntity
ReportService ..> PaginatedAdminReviewReports
ReportService ..> AdminReviewReport

@enduml
