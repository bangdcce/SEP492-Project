@startuml View_List_Of_Active_Dispute_Class_Diagram
title View List Of Active Dispute - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ParticipantDisputesPage {
    - disputes: DisputeSummary[]
    - loading: boolean
    - group: "active" | "appeals" | "closed"
    --
    + ParticipantDisputesPage(): JSX.Element
    + loadDisputes(): Promise<void>
}

class getMyDisputes {
    --
    + getMyDisputes(filters?: DisputeFilters, options?: CacheOptions): Promise<PaginatedDisputesResponse>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + getMyDisputes(user: UserEntity, filters: DisputeFilterDto): Promise<PaginatedDisputesResponse>
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    --
    + getMyDisputes(userId: string, userRole: UserRole, filters?: DisputeFilterDto): Promise<PaginatedDisputesResponse>
    ...
}

class DisputeFilterDto {
    + page?: number
    + limit?: number
    + sortBy?: string
    + sortOrder?: string
    + asRaiser?: boolean
    + asDefendant?: boolean
    + asInvolved?: boolean
    --
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + reason: string
    + updatedAt: Date
    + appealDeadline: Date | null
    + projectId: string
    + raisedById: string
    + defendantId: string
    --
}

class ProjectEntity {
    + id: string
    + title: string
    + clientId: string
    + brokerId: string | null
    + freelancerId: string | null
    --
}

class UserEntity {
    + id: string
    + fullName: string
    + email: string
    + role: UserRole
    --
}

ParticipantDisputesPage ..> getMyDisputes
getMyDisputes ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService
DisputesController ..> DisputeFilterDto

DisputesService ..> DisputeFilterDto
DisputesService ..> DisputeEntity
DisputesService ..> ProjectEntity
DisputesService ..> UserEntity

@enduml
