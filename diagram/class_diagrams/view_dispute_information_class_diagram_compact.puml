@startuml View_Dispute_Information_Class_Diagram
title View Dispute Information - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ParticipantDisputeDetailPage {
    --
    + ParticipantDisputeDetailPage(): JSX.Element
}

class DisputeDetailHub {
    - disputeId?: string
    - dispute: DisputeSummary | null
    - dossier: DisputeDossier | null
    - loading: boolean
    --
    + DisputeDetailHub(props: DisputeDetailHubProps): JSX.Element
    + fetchDetail(preferCache?: boolean): Promise<void>
    + fetchDossier(): Promise<void>
}

class getDisputeDetail {
    --
    + getDisputeDetail(disputeId: string, options?: CacheOptions): Promise<DisputeSummary>
}

class getDisputeDossier {
    --
    + getDisputeDossier(disputeId: string): Promise<DisputeDossier>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class DisputesController {
    - disputesService: DisputesService
    --
    + getDetailDisputes(id: string, user: UserEntity): Promise<any>
    + getDisputeDossier(id: string, user: UserEntity): Promise<any>
    + createDisputes(@GetUser()
    + getListDisputes(@GetUser()
    + getMyDisputes(@GetUser()
    + getDisputeStats()
    + getQueueCount(@GetUser()
    + getQueueDisputes(@GetUser()
    + getCaseloadDisputes(@GetUser()
    + getSchedulingWorklist(@GetUser()
    ...
}

class DisputesService {
    - disputeRepo: Repository<DisputeEntity>
    - contractRepo: Repository<ContractEntity>
    --
    + getDetail(disputeId: string, userId: string, userRole: UserRole): Promise<any>
    + getDisputeDossier(disputeId: string, userId: string, userRole: UserRole): Promise<any>
    + assertDisputeAccess(dispute: DisputeEntity, userId: string, userRole: UserRole): Promise<void>
    + getVerdict(disputeId: string, userId: string, userRole: UserRole)
    - buildVerdictAcceptanceKey(disputeId: string, verdictId: string): string
    + getPublicRecord(disputeId: string)
    - sanitizePublicText(value: string | null | undefined): string | null
    - toPublicRoleAlias(role: UserRole | null | undefined): string
    - buildPublicCaseNumber(disputeId: string): string
    - ensureLegacyFlowAllowed(disputeId: string): Promise<void>
    ...
}

class DisputeSummary {
    + id: string
    + projectId: string
    + raisedById: string
    + defendantId: string
    + category: DisputeCategory
    + disputedAmount?: number
    + status: DisputeStatus
    + raiser?: DisputeUserSummary
    + defendant?: DisputeUserSummary
    + project?: DisputeProjectSummary
    ...
    --
}

class DisputeDossier {
    + dispute: object
    + projectContext: object
    + contracts: object[]
    + timeline: object[]
    + contradictionHints: object[]
    + pendingActions: object[]
    + hearings: object[]
    --
}

class DisputeEntity {
    + id: string
    + projectId: string
    + raisedById: string
    + defendantId: string
    + category: DisputeCategory
    + disputedAmount?: number
    + reason: string
    + status: DisputeStatus
    + milestoneId: string
    + priority: DisputePriority
    ...
    --
}

class ProjectEntity {
    + id: string
    + title: string
    + clientId: string
    + brokerId: string | null
    + freelancerId: string | null
    + requestId: string
    + staffId: string | null
    + staffInviteStatus: ProjectStaffInviteStatus | null
    + description: string
    + totalBudget: number
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class ContractEntity {
    + id: string
    + projectId: string
    + title: string
    + contractUrl: string
    + status: ContractStatus
    + createdAt: Date
    + sourceSpecId: string | null
    + archiveStoragePath: string | null
    + archivePersistedAt: Date | null
    + archiveDocumentHash: string | null
    ...
    --
}

ParticipantDisputeDetailPage ..> DisputeDetailHub
DisputeDetailHub ..> getDisputeDetail
DisputeDetailHub ..> getDisputeDossier
getDisputeDetail ..> ApiClient
getDisputeDossier ..> ApiClient
ApiClient ..> DisputesController
DisputesController --> DisputesService

DisputesService ..> DisputeEntity
DisputesService ..> ProjectEntity
DisputesService ..> UserEntity
DisputesService ..> ContractEntity

DisputeDetailHub ..> DisputeSummary
DisputeDetailHub ..> DisputeDossier
DisputesService ..> DisputeSummary
DisputesService ..> DisputeDossier

@enduml
