@startuml View_Statistic_Staff_Class_Diagram
title View Statistic Staff - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class StaffDashboardPage {
    - range: StaffDashboardRange
    - overview: StaffDashboardOverview | null
    - loading: boolean
    - error: string | null
    --
    + StaffDashboardPage(): JSX.Element
}

class useStaffDashboardRealtime {
    --
    + useStaffDashboardRealtime(handlers?: object): void
}

class getStaffDashboardOverview {
    --
    + getStaffDashboardOverview(range?: StaffDashboardRange): Promise<StaffDashboardOverview>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class StaffAssignmentController {
    - staffAssignmentService: StaffAssignmentService
    --
    + getDashboardOverview(range: "7d" | "30d" | "90d" | undefined, user: UserEntity): Promise<any>
    + estimateComplexity(@Param('disputeId', ParseUUIDPipe)
    + estimateComplexityBatch(@Body()
    + getAvailableStaff(@Query('date')
    + autoAssignStaff(@Param('disputeId', ParseUUIDPipe)
    + checkSessionTiming(@Param('eventId', ParseUUIDPipe)
}

class StaffAssignmentService {
    - disputeRepository: Repository<DisputeEntity>
    - staffWorkloadRepository: Repository<StaffWorkloadEntity>
    - performanceRepository: Repository<StaffPerformanceEntity>
    - hearingRepository: Repository<DisputeHearingEntity>
    --
    + getDashboardOverview(range: "7d" | "30d" | "90d", currentUser?: UserEntity): Promise<any>
    + buildStaffDashboardMembers(staffUsers: UserEntity[], performanceRows: object[], workloadRows: object[]): object[]
    - getRangeDays(range: '7d' | '30d' | '90d'): number
    - getMedian(values: number[]): number
    - getPeriodsForRange(start: Date, end: Date): string[]
    - buildDashboardBuckets(range: '7d' | '30d' | '90d', start: Date, end: Date)
    - getCategoryComplexityWeight(category: DisputeCategory): number
    - getEvidenceComplexityWeight(evidenceCount: number): number
    - getDescriptionComplexityWeight(descriptionLength: number): number
    - getAmountComplexityScore(amount: number, currency: string, totalBudget?: number): number
    ...
}

class StaffDashboardOverview {
    + generatedAt: string
    + range: StaffDashboardRange
    + throughput: object
    + sla: object
    + scheduling: object
    + quality: object
    + workload: object
    + riskSignals: object
    + series: object
    + members: object[]
    ...
    --
}

class UserEntity {
    + id: string
    + email: string
    + fullName: string
    + role: UserRole
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

class DisputeEntity {
    + id: string
    + status: DisputeStatus
    + category: DisputeCategory
    + disputedAmount?: number
    + raisedById: string
    + defendantId: string
    + projectId: string
    + milestoneId: string
    + priority: DisputePriority
    + reason: string
    ...
    --
}

class StaffWorkloadEntity {
    + id: string
    + staffId: string
    + totalDisputesPending: number
    + utilizationRate: number
    + isOverloaded: boolean
    + date: Date
    + totalEventsScheduled: number
    + scheduledMinutes: number
    + dailyCapacityMinutes: number
    + canAcceptNewEvent: boolean
    ...
    --
}

class StaffPerformanceEntity {
    + id: string
    + staffId: string
    + resolvedCases: number
    + appealRate: number
    + overturnRate: number
    + avgResolutionTimeHours: number
    + period: string
    + totalDisputesAssigned: number
    + totalDisputesResolved: number
    + totalDisputesPending: number
    ...
    --
}

class DisputeHearingEntity {
    + id: string
    + disputeId: string
    + status: HearingStatus
    + scheduledAt?: Date
    + endedAt?: Date
    + scheduledAt: Date
    + startedAt: Date
    + endedAt: Date
    + externalMeetingLink: string
    + moderatorId: string
    ...
    --
}

class DisputeEvidenceEntity {
    + id: string
    + disputeId: string
    + isFlagged: boolean
    + flagReason?: string
    + uploadedAt: Date
    + uploaderId: string
    + uploaderRole: string
    + storagePath: string
    + fileName: string
    + fileSize: number
    ...
    --
}

StaffDashboardPage ..> useStaffDashboardRealtime
StaffDashboardPage ..> getStaffDashboardOverview
StaffDashboardPage ..> StaffDashboardOverview
getStaffDashboardOverview ..> ApiClient
ApiClient ..> StaffAssignmentController
StaffAssignmentController --> StaffAssignmentService
StaffAssignmentController ..> UserEntity

StaffAssignmentService ..> StaffDashboardOverview
StaffAssignmentService ..> UserEntity
StaffAssignmentService ..> DisputeEntity
StaffAssignmentService ..> StaffWorkloadEntity
StaffAssignmentService ..> StaffPerformanceEntity
StaffAssignmentService ..> DisputeHearingEntity
StaffAssignmentService ..> DisputeEvidenceEntity

@enduml
