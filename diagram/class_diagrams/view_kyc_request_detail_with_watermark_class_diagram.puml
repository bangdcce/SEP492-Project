@startuml View_KYC_Request_Detail_Watermarked_Class_Diagram
title View KYC Request Detail (Watermarked) - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ApiClient {
    + get(url: string): Promise<any>
}

class AdminKYCPage {
    - selectedKyc: any
    - showModal: boolean

    + openReview(kyc: any): Promise<void>
    + closeModal(): void
}

class KYCVerificationModal {
    - selectedImage: string
    - rejectReason: string
    - showRejectInput: boolean
    - rejectError: string

    + handleApprove(): void
    + handleReject(): void
}

class JwtAuthGuard {
    + canActivate(context: any): boolean
}

class RolesGuard {
    + canActivate(context: any): boolean
}

class KycController {
    - kycService: KycService
    + getKycByIdWithWatermark(id: string, user: any, req: any, reason: string, reasonDetails: string): any
}

class Repository {
    + findOne(options: any): Promise<any>
    + create(data: any): any
    + save(entity: any): Promise<any>
}

class KycService {
    - kycRepo: Repository
    - auditLogRepo: Repository

    + getKycByIdWithWatermark(
        id: string,
        reviewerId: string,
        reviewerEmail: string,
        reviewerRole: string,
        ipAddress: string,
        sessionId: string,
        userAgent: string,
        reason: string,
        reasonDetails: string
      ): any
}

class SupabaseStorageUtil {
    + downloadWithWatermark(path: string, options: WatermarkOptions): Promise<Buffer>
}

class WatermarkOptions {
    + reviewerEmail: string
    + reviewerRole: string
    + ipAddress: string
    + sessionId: string
    + timestamp: Date
    + kycId: string
}

class Buffer {
    + length: number
}

class AuditLogEntity {
    + id: string
    + actorId: string
    + action: string
    + entityType: string
    + entityId: string
    + ipAddress: string
    + userAgent: string
    + afterData: any
    + createdAt: Date
}

class KycVerificationEntity {
    + id: string
    + userId: string
    + documentFrontUrl: string
    + documentBackUrl: string
    + selfieUrl: string
    + status: KycStatus
}

enum KycStatus {
    PENDING
    APPROVED
    REJECTED
    EXPIRED
}

AdminKYCPage ..> KYCVerificationModal
AdminKYCPage ..> ApiClient
ApiClient ..> KycController
KycController ..> JwtAuthGuard
KycController ..> RolesGuard
KycController --> KycService
KycService --> Repository
KycService ..> KycVerificationEntity
KycService ..> AuditLogEntity
KycService ..> SupabaseStorageUtil
SupabaseStorageUtil ..> WatermarkOptions
KycVerificationEntity -- KycStatus
@enduml
