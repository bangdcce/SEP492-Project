@startuml View_Invitation_Detail_Class_Diagram
title View Invitation Detail - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class InvitationDetailsPage {
    - kycStatus: string | null
    - invitation: MyInvitationItem | null
    --
    + InvitationDetailsPage(): JSX.Element
}

class useMyInvitationsRealtime {
    - invitations: MyInvitationItem[]
    - isLoading: boolean
    - error: string | null
    --
    + useMyInvitationsRealtime(options?: UseMyInvitationsRealtimeOptions): object
    + refresh(refreshOptions?: { silent?: boolean }): Promise<void>
}

class MyInvitationItem {
    + id: string
    + status?: string | null
    + createdAt?: string
    + coverLetter?: string | null
    + request?: InvitationRequestPreview | null
    --
}

class InvitationRequestPreview {
    + id: string
    + title: string
    + status?: string | null
    + description?: string | null
    + budgetRange?: string | null
    + intendedTimeline?: string | null
    + requestedDeadline?: string | null
    + techPreferences?: string | null
    + requestScopeBaseline?: object | null
    + client?: object | null
    --
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - getAuthErrorCode(error: unknown): string | null
    - shouldAttemptSessionReconcile(error: unknown): boolean
    - reconcileSessionSingleFlight(): Promise<void>
    - handleAuthFailure(suppressRedirect: boolean = false)
    ...
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean> | any
}

class RolesGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean>
}

class ProjectRequestsController {
    - projectRequestsService: ProjectRequestsService
    --
    + getMyInvitations(user: UserEntity): Promise<any>
    + getOne(id: string, user: UserEntity): Promise<any>
    - assertFilesAllowed(files: MulterFile[] = [])
    + seedTestData(@Body('clientId')
    + getProjectRequests(@GetUser()
    + findMyDrafts(@GetUser('id')
    + getFreelancerRequestAccessList(@GetUser()
    + findMatches(@Param('id')
    + uploadFile(@UploadedFiles()
    + approveSpecs(@Param('id')
    ...
}

class ProjectRequestsService {
    - brokerProposalRepo: Repository<BrokerProposalEntity>
    - freelancerProposalRepo: Repository<ProjectRequestProposalEntity>
    --
    + getInvitationsForUser(userId: string, role: UserRole): Promise<any[]>
    + findOne(id: string, user: UserEntity): Promise<any>
    - toUserHandle(user?: Pick<UserEntity, 'email'> | null): string | null
    - getTodayDateInputValue(referenceDate: Date = new Date()
    - normalizeIntendedTimeline(value?: string): string | undefined
    - normalizeRequestedDeadline(value?: string | null): string | undefined
    - safeNormalizeRequestedDeadline(value?: string | null): string | null
    - getDateKeyFromDate(value?: Date | string | null): string | null
    - sanitizePlainText(value?: string | null): string
    - humanizeProductTypeValue(value: string): string
    ...
}

class ProjectRequestProposalEntity {
    + id: string
    + requestId: string
    + freelancerId: string
    + status: string
    + coverLetter: string | null
    + request: ProjectRequestEntity
    + brokerId: string
    + proposedBudget: number
    + estimatedDuration: string
    + createdAt: Date
    ...
    --
}

class BrokerProposalEntity {
    + id: string
    + requestId: string
    + brokerId: string
    + status: ProposalStatus
    + coverLetter: string | null
    + request: ProjectRequestEntity
    + createdAt: Date
    + broker: UserEntity
    --
}

class ProjectRequestEntity {
    + id: string
    + title: string
    + status: RequestStatus
    + description: string | null
    + budgetRange: string | null
    + intendedTimeline: string | null
    + requestedDeadline: string | null
    + techPreferences: string | null
    + client: UserEntity
    + clientId: string
    ...
    --
}

class UserEntity {
    + id: string
    + fullName: string
    + role: UserRole
    + email: string
    + passwordHash: string
    + phoneNumber: string
    + timeZone: string
    + isVerified: boolean
    + resetPasswordOtp: string
    + resetPasswordOtpExpires: Date
    ...
    --
    + badge(): BadgeType
    + warningLevel(): 'NONE' | 'LOW' | 'MEDIUM' | 'HIGH' | 'CRITICAL' | 'SEVERE'
}

InvitationDetailsPage ..> useMyInvitationsRealtime
InvitationDetailsPage ..> MyInvitationItem

useMyInvitationsRealtime ..> ApiClient
useMyInvitationsRealtime ..> MyInvitationItem

MyInvitationItem o-- InvitationRequestPreview

ApiClient ..> ProjectRequestsController

ProjectRequestsController ..> JwtAuthGuard
ProjectRequestsController ..> RolesGuard
ProjectRequestsController --> ProjectRequestsService
ProjectRequestsController ..> UserEntity

ProjectRequestsService ..> ProjectRequestProposalEntity
ProjectRequestsService ..> BrokerProposalEntity
ProjectRequestsService ..> ProjectRequestEntity
ProjectRequestsService ..> UserEntity

ProjectRequestProposalEntity o-- ProjectRequestEntity
BrokerProposalEntity o-- ProjectRequestEntity
ProjectRequestEntity o-- UserEntity

@enduml
