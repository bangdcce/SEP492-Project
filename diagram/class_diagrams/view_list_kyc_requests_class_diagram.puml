@startuml View_List_KYC_Requests_Class_Diagram
title View List KYC Requests - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ApiClient {
    + get(url: string): Promise<any>
}

class AdminKYCPage {
    - kycs: KycVerification[]
    - loading: boolean
    - filter: string
    - selectedKyc: KycVerification
    - showModal: boolean
    - actionLoading: boolean

    + fetchKycs(): Promise<void>
    + openReview(kyc: KycVerification): Promise<void>
    + closeModal(): void
}

class KycVerification {
    + id: string
    + fullNameOnDocument: string
    + documentNumber: string
    + documentType: string
    + dateOfBirth: string
    + documentFrontUrl: string
    + documentBackUrl: string
    + selfieUrl: string
    + status: string
    + rejectionReason: string
    + createdAt: string
    + reviewedAt: string
    + user: any
    + reviewer: any
}

class JwtAuthGuard {
    + canActivate(context: any): boolean
}

class RolesGuard {
    + canActivate(context: any): boolean
}

class KycController {
    - kycService: KycService
    + getAllKyc(status: string, page: number, limit: number): any
}

class Repository {
    + createQueryBuilder(alias: string): any
}

class KycService {
    - kycRepo: Repository
    + getAllKyc(status: KycStatus, page: number, limit: number): any
}

class KycVerificationEntity {
    + id: string
    + userId: string
    + status: KycStatus
    + createdAt: Date
}

enum KycStatus {
    PENDING
    APPROVED
    REJECTED
    EXPIRED
}

class SupabaseStorageUtil {
    + getSignedUrl(path: string, expiresInSeconds: number): Promise<string>
}

AdminKYCPage ..> ApiClient
ApiClient ..> KycController
KycController ..> JwtAuthGuard
KycController ..> RolesGuard
KycController --> KycService
KycService --> Repository
KycService ..> KycVerificationEntity
KycService ..> SupabaseStorageUtil
KycVerificationEntity -- KycStatus
@enduml
