@startuml Apply_To_Public_Request_Class_Diagram
title Apply To Public Request - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class ProjectRequestsPage {
    - requests: ProjectRequest[]
    - loading: boolean
    - kycStatus: string | null
    - upgradeModalData: any
    --
    + ProjectRequestsPage(): JSX.Element
    + fetchRequests(): Promise<void>
    + handleApply(requestId: string, coverLetter: string): Promise<void>
}

class ProjectRequestsTable {
    - proposalModalOpen: boolean
    - selectedRequestId: string | null
    --
    + ProjectRequestsTable(props: ProjectRequestsTableProps): JSX.Element
}

class ProposalModal {
    - letter: string
    --
    + ProposalModal(props: ProposalModalProps): JSX.Element
}

class useKYCStatus {
    --
    + useKYCStatus(): object
    + checkKycStatus(): Promise<string>
}

class KYCBlocker {
    --
    + KYCBlocker(props: KYCBlockerProps): JSX.Element
}

class projectRequestsApi {
    --
    + getAll(params?: GetRequestsParams): Promise<ProjectRequest[]>
    + applyToRequest(id: string, coverLetter: string): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean> | any
}

class RolesGuard {
    --
    + canActivate(context: any): boolean | Promise<boolean>
}

class ProjectRequestsController {
    - projectRequestsService: ProjectRequestsService
    --
    + apply(id: string, brokerId: string, coverLetter: string): Promise<any>
    + getProjectRequests(user: UserEntity, status?: string): Promise<any>
}

class ProjectRequestsService {
    - requestRepo: Repository<ProjectRequestEntity>
    - brokerProposalRepo: Repository<BrokerProposalEntity>
    - quotaService: QuotaService
    - notificationsService: NotificationsService
    --
    + applyToRequest(requestId: string, brokerId: string, coverLetter: string): Promise<any>
    + findAll(status?: RequestStatus): Promise<any[]>
    ...
}

class QuotaService {
    --
    + checkQuota(userId: string, action: QuotaAction, entityId?: string): Promise<void>
    + incrementUsage(userId: string, action: QuotaAction, metadata?: Record<string, any>): Promise<void>
}

class NotificationsService {
    --
    + createMany(inputs: CreateNotificationDto[]): Promise<any>
    ...
}

class ProjectRequest {
    + id: string
    + title: string
    + status: RequestStatus
    + brokerId?: string | null
    + brokerProposals?: object[]
    --
}

class ProjectRequestEntity {
    + id: string
    + title: string
    + status: RequestStatus
    + clientId: string
    + brokerId: string | null
    + brokerProposals: BrokerProposalEntity[]
    --
}

class BrokerProposalEntity {
    + id: string
    + requestId: string
    + brokerId: string
    + coverLetter: string
    + status: ProposalStatus
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    + fullName: string
    --
}

ProjectRequestsPage ..> useKYCStatus
ProjectRequestsPage ..> KYCBlocker
ProjectRequestsPage ..> projectRequestsApi
ProjectRequestsPage ..> ProjectRequestsTable

ProjectRequestsTable ..> ProposalModal
ProjectRequestsTable ..> ProjectRequest
ProjectRequestsPage ..> ProjectRequest

ProposalModal ..> ProjectRequestsPage : submit letter

projectRequestsApi ..> ApiClient
ApiClient ..> ProjectRequestsController

ProjectRequestsController ..> JwtAuthGuard
ProjectRequestsController ..> RolesGuard
ProjectRequestsController ..> UserEntity
ProjectRequestsController --> ProjectRequestsService

ProjectRequestsService ..> ProjectRequestEntity
ProjectRequestsService ..> BrokerProposalEntity
ProjectRequestsService ..> QuotaService
ProjectRequestsService ..> NotificationsService

ProjectRequestEntity o-- BrokerProposalEntity

@enduml
