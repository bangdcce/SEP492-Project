@startuml View_Notification_Class_Diagram
title View Notification - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class NotificationDropdown {
    - open: boolean
    - limit: number
    --
    + NotificationDropdown(props: NotificationDropdownProps): JSX.Element
    + handleOpenChange(nextOpen: boolean): void
    + handleSelect(item: NotificationItem): Promise<void>
    + handleMarkAllRead(): Promise<void>
}

class useNotifications {
    - notifications: NotificationItem[]
    - loading: boolean
    --
    + useNotifications(limit?: number): object
    + refresh(options?: { silent?: boolean }): Promise<void>
    + markOneAsRead(notificationId: string): Promise<void>
    + markAllAsRead(): Promise<void>
}

class getNotifications {
    --
    + getNotifications(input?: object): Promise<NotificationsResponse>
    + markNotificationRead(notificationId: string): Promise<any>
    + markAllNotificationsRead(): Promise<any>
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number
    --
    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class NotificationsController {
    - notificationsService: NotificationsService
    --
    + listNotifications(user: UserEntity, pageRaw?: string, limitRaw?: string, unreadOnlyRaw?: string): Promise<any>
    + markRead(id: string, user: UserEntity): Promise<any>
    + markAllRead(user: UserEntity): Promise<any>
}

class NotificationsService {
    - notificationRepo: Repository<NotificationEntity>
    - eventEmitter: EventEmitter2
    --
    + list(userId: string, options: object): Promise<any>
    + markRead(userId: string, notificationId: string): Promise<NotificationEntity>
    + markAllRead(userId: string): Promise<void>
    + create(input: CreateNotificationInput): Promise<NotificationEntity | null>
    + createMany(inputs: CreateNotificationInput[]): Promise<NotificationEntity[]>
}

class NotificationItem {
    + id: string
    + title: string
    + body: string
    + isRead: boolean
    + readAt?: string | null
    + relatedType?: string | null
    + relatedId?: string | null
    + createdAt: string
    --
}

class NotificationEntity {
    + id: string
    + userId: string
    + title: string
    + body: string
    + isRead: boolean
    + readAt: Date
    + relatedType: string
    + relatedId: string
    + createdAt: Date
    --
}

class UserEntity {
    + id: string
    + role: UserRole
    --
}

NotificationDropdown ..> useNotifications
NotificationDropdown ..> NotificationItem
useNotifications ..> getNotifications
useNotifications ..> NotificationItem
getNotifications ..> ApiClient
ApiClient ..> NotificationsController
NotificationsController --> NotificationsService
NotificationsController ..> UserEntity
NotificationsService ..> NotificationEntity

@enduml
