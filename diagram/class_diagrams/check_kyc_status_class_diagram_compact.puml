@startuml Check_KYC_Status_Class_Diagram
title Check KYC Status - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class KYCData {
    + status: string
    + rejectionReason: string
    + submittedAt: string
    + reviewedAt: string
    + userId: string
    + userName: string
    + userEmail: string
    + userRole: 'sme' | 'broker' | 'freelancer'
    + idCardFront: string
    + idCardBack: string
    --
}

class KYCStatusPage {
    - loading: boolean
    - refreshing: boolean
    - kycData: KYCData
    - baseUrl: string
    --
    + fetchKYCStatus(showRefreshing: boolean): Promise<void>
    + getStatusConfig(status: string): any
}

class WebClient {
    --
    + getJson(url: string, withCredentials: boolean): Promise<any>
}

class JwtAuthGuard {
    --
    + canActivate(context: any): boolean
}

class KycController {
    - kycService: KycService
    --
    + getMyKyc(userId: string): any
    + getKycById(@Param('id', ParseUUIDPipe)
    + approveKyc(@Param('id', ParseUUIDPipe)
}

class Repository {
    --
    + findOne(options: any): Promise<any>
}

enum KycStatus {
    PENDING
    APPROVED
    REJECTED
    EXPIRED
}

class KycVerificationEntity {
    + id: string
    + userId: string
    + status: KycStatus
    + rejectionReason: string
    + documentFrontUrl: string
    + documentBackUrl: string
    + selfieUrl: string
    + createdAt: Date
    + reviewedAt: Date
    + documentType: DocumentType
    --
}

class SupabaseStorageUtil {
    --
    + getSignedUrl(path: string, expiresInSeconds: number): Promise<string>
}

class KycService {
    - kycRepo: Repository
    --
    + getMyKyc(userId: string): any
    + getAllKyc(status?: KycStatus, page = 1, limit = 20)
    + getKycById(id: string)
    + approveKyc(id: string, adminId: string)
    + rejectKyc(id: string, adminId: string, dto: RejectKycDto)
    + hasVerifiedKyc(userId: string): Promise<boolean>
    - normalizeString(str: string | undefined | null): string
    - levenshteinDistance(str1: string, str2: string): number
    - calculateSimilarity(str1: string, str2: string): number
    - normalizeDateString(dateStr: string | undefined | null): string
}

KYCStatusPage *-- KYCData
KYCStatusPage ..> WebClient
WebClient ..> KycController
KycController ..> JwtAuthGuard
KycController --> KycService
KycService --> Repository
KycService ..> KycVerificationEntity
KycService ..> SupabaseStorageUtil
KycVerificationEntity -- KycStatus
@enduml
