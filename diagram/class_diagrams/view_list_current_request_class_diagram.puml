@startuml View_List_Current_Request_Class_Diagram
title View List Current Request - Class Diagram
skinparam backgroundColor white
skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam classBorderColor black
skinparam classFontColor black
skinparam classBackgroundColor white
skinparam stereotypeFontColor black
skinparam linetype polyline
skinparam classAttributeIconSize 0
hide circle

skinparam classHeaderBackgroundColor white
skinparam classHeaderFontColor black

class MyRequestsPage {
    - requests: any[]
    - loading: boolean
    - search: string
    - statusFilter: string
    - specFlowsByRequestId: Record<string, RequestSpecFlow>

    + fetchRequests(): Promise<void>
    + fetchSpecFlows(requestList: any[]): Promise<void>
    + getStatusColor(status: string): string
    + getSpecBadgeClass(status: string): string
}

class wizardService {
    + getQuestions(): Promise<WizardQuestion[]>
    + submitRequest(data: CreateProjectRequestDto): Promise<any>
    + uploadFiles(files: File[], category: "requirements" | "attachments"): Promise<UploadProjectRequestFilesResult>
    + updateRequest(id: string, data: Partial<CreateProjectRequestDto>): Promise<any>
    + publishRequest(id: string): Promise<any>
    + getDrafts(): Promise<any>
    + getMatches(requestId: string): Promise<any>
    + getRequests(): Promise<any>
    + getRequestById(id: string): Promise<any>
    + inviteBroker(requestId: string, brokerId: string): Promise<any>
    ...
}

class projectSpecsApi {
    + createClientSpec(data: CreateClientSpecDTO): Promise<SpecMutationResponse>
    + updateClientSpec(specId: string, data: CreateClientSpecDTO): Promise<SpecMutationResponse>
    + submitForClientReview(specId: string): Promise<ProjectSpec>
    + clientReviewSpec(specId: string, action: "APPROVE" | "REJECT", reason?: string): Promise<ProjectSpec>
    + getClientSpec(requestId: string): Promise<ProjectSpec>
    + getPendingClientReview(): Promise<ProjectSpec[]>
    + createFullSpec(data: CreateProjectSpecDTO): Promise<SpecMutationResponse>
    + updateFullSpec(specId: string, data: CreateProjectSpecDTO): Promise<SpecMutationResponse>
    + submitForFinalReview(specId: string): Promise<ProjectSpec>
    + signSpec(specId: string): Promise<ProjectSpec>
    ...
}

class ApiClient {
    - client: AxiosInstance
    - refreshPromise: Promise<void> | null
    - sessionReconcilePromise: Promise<void> | null
    - isRedirectingToLogin: boolean
    - lastLoginTime: number

    + constructor()
    + get<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    + post<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + put<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + patch<T>(url: string, data?: unknown, config?: AxiosRequestConfig): Promise<T>
    + delete<T>(url: string, config?: AxiosRequestConfig): Promise<T>
    - setupInterceptors()
    - isRefreshEndpoint(url?: string): boolean
    - isPublicAuthEndpoint(url?: string): boolean
    - refreshAccessTokenSingleFlight(): Promise<void>
    ...
}

class JwtAuthGuard {
    + canActivate(context: any): boolean | Promise<boolean> | any
}

class RolesGuard {
    + canActivate(context: any): boolean | Promise<boolean>
}

class ProjectRequestsController {
    - projectRequestsService: ProjectRequestsService

    + create(userId: string, createDto: CreateProjectRequestDto, req: RequestContext): Promise<ProjectRequestEntity>
    + getProjectRequests(user: UserEntity, status?: string): Promise<any>
    + findMyDrafts(userId: string): Promise<ProjectRequestEntity[]>
    + getMyInvitations(user: UserEntity): Promise<any>
    + getFreelancerRequestAccessList(user: UserEntity): Promise<any>
    + findMatches(id: string): Promise<any>
    + getOne(id: string, user: UserEntity): Promise<any>
    + assignBroker(id: string, brokerId: string, req: RequestContext): Promise<any>
    + update(id: string, updateDto: UpdateProjectRequestDto, user: UserEntity, req: RequestContext): Promise<ProjectRequestEntity>
    + publish(id: string, userId: string, req: RequestContext): Promise<any>
    ...
}

class ProjectRequestsService {
    - requestRepo: Repository<ProjectRequestEntity>
    - answerRepo: Repository<ProjectRequestAnswerEntity>
    - auditLogsService: AuditLogsService
    - matchingService: MatchingService
    - quotaService: QuotaService
    - notificationsService: NotificationsService
    - contractsService: ContractsService
    - requestChatService: RequestChatService
    - eventEmitter: EventEmitter2

    + create(clientId: string, dto: CreateProjectRequestDto, req: RequestContext): Promise<ProjectRequestEntity | null>
    + findAll(status?: RequestStatus): Promise<any[]>
    + update(id: string, dto: UpdateProjectRequestDto, user?: UserEntity, req?: RequestContext): Promise<ProjectRequestEntity>
    + publish(requestId: string, userId: string, req?: RequestContext): Promise<any>
    + findAllByClient(clientId: string): Promise<any[]>
    + findDraftsByClient(clientId: string): Promise<ProjectRequestEntity[]>
    + findOne(id: string, user?: UserEntity): Promise<any>
    + findMatches(id: string, userId?: string): Promise<any>
    + inviteBroker(requestId: string, brokerId: string, message?: string, inviterId?: string): Promise<any>
    + getInvitationsForUser(userId: string, role: UserRole): Promise<any>
    ...
}

class ProjectSpecsController {
    - projectSpecsService: ProjectSpecsService

    + getPendingSpecs(): Promise<ProjectSpecEntity[]>
    + getPendingClientReview(user: UserEntity): Promise<ProjectSpecEntity[]>
    + getSpecsInFinalReview(user: UserEntity): Promise<ProjectSpecEntity[]>
    + getSpecsByRequest(user: UserEntity, requestId: string): Promise<ProjectSpecEntity[]>
    + getClientSpec(user: UserEntity, requestId: string): Promise<ProjectSpecEntity | null>
    + getFullSpec(user: UserEntity, parentSpecId: string): Promise<ProjectSpecEntity | null>
    + getSpec(user: UserEntity, id: string): Promise<ProjectSpecEntity>
    + createClientSpec(user: UserEntity, dto: CreateClientSpecDto, req: RequestContext): Promise<ProjectSpecEntity>
    + updateClientSpec(user: UserEntity, specId: string, dto: CreateClientSpecDto, req: RequestContext): Promise<ProjectSpecEntity>
    + submitForClientReview(user: UserEntity, specId: string, req: RequestContext): Promise<ProjectSpecEntity>
    ...
}

class ProjectSpecsService {
    - projectSpecsRepository: Repository<ProjectSpecEntity>
    - requestRepository: Repository<ProjectRequestEntity>
    - milestoneRepository: Repository<ProjectSpecMilestoneEntity>
    - auditLogsService: AuditLogsService
    - notificationsService: NotificationsService
    - eventEmitter: EventEmitter2

    + findOneForUser(user: UserEntity, id: string): Promise<ProjectSpecEntity>
    + findSpecsByRequestIdForUser(user: UserEntity, requestId: string): Promise<ProjectSpecEntity[]>
    + findClientSpec(requestId: string): Promise<ProjectSpecEntity | null>
    + findClientSpecForUser(user: UserEntity, requestId: string): Promise<ProjectSpecEntity | null>
    + findFullSpec(parentSpecId: string): Promise<ProjectSpecEntity | null>
    + findPendingClientReview(clientId: string): Promise<ProjectSpecEntity[]>
    + findPendingSpecs(): Promise<ProjectSpecEntity[]>
    + findSpecsInFinalReview(userId: string): Promise<ProjectSpecEntity[]>
    + createClientSpec(dto: CreateClientSpecDto, brokerId: string, req?: RequestContext): Promise<ProjectSpecEntity>
    + updateClientSpec(specId: string, dto: CreateClientSpecDto, brokerId: string, req?: RequestContext): Promise<ProjectSpecEntity>
    ...
}

class Repository {
    + findOne(options: any): Promise<any>
    + find(options?: any): Promise<any[]>
    + create(data: any): any
    + save(entity: any): Promise<any>
    + update(criteria: any, partial: any): Promise<any>
}

enum RequestStatus {
    PUBLIC_DRAFT
    PRIVATE_DRAFT
    BROKER_ASSIGNED
    SPEC_APPROVED
    CONTRACT_PENDING
    HIRING
    CONVERTED_TO_PROJECT
    IN_PROGRESS
    DRAFT
    PENDING
    ...
}

enum ProjectSpecStatus {
    DRAFT
    CLIENT_REVIEW
    CLIENT_APPROVED
    FINAL_REVIEW
    ALL_SIGNED
    APPROVED
    REJECTED
}

enum SpecPhase {
    CLIENT_SPEC
    FULL_SPEC
}

class ProjectRequestEntity {
    + id: string
    + clientId: string
    + title: string
    + description: string
    + budgetRange: string
    + intendedTimeline: string
    + requestedDeadline: string | null
    + attachments: ProjectRequestAttachmentMetadata[] | null
    + status: RequestStatus
    + brokerId: string
    ...
}

class ProjectSpecEntity {
    + id: string
    + requestId: string
    + specPhase: SpecPhase
    + status: ProjectSpecStatus
    + title: string
    + summary: string | null
    + createdAt: Date
    + updatedAt: Date
}

MyRequestsPage ..> wizardService
MyRequestsPage ..> projectSpecsApi
MyRequestsPage ..> RequestStatus
MyRequestsPage ..> ProjectSpecStatus
MyRequestsPage ..> SpecPhase

wizardService ..> ApiClient
wizardService ..> ProjectRequestEntity

projectSpecsApi ..> ApiClient
projectSpecsApi ..> ProjectSpecEntity

ProjectRequestsController ..> JwtAuthGuard
ProjectRequestsController ..> RolesGuard
ProjectRequestsController --> ProjectRequestsService

ProjectSpecsController ..> JwtAuthGuard
ProjectSpecsController ..> RolesGuard
ProjectSpecsController --> ProjectSpecsService

ProjectRequestsService ..> Repository
ProjectRequestsService ..> ProjectRequestEntity
ProjectRequestsService ..> RequestStatus

ProjectSpecsService ..> Repository
ProjectSpecsService ..> ProjectSpecEntity
ProjectSpecsService ..> ProjectSpecStatus
ProjectSpecsService ..> SpecPhase

ProjectRequestEntity --> RequestStatus
ProjectSpecEntity --> ProjectSpecStatus
ProjectSpecEntity --> SpecPhase

@enduml
