@startuml View_Detail_Wizard_Question_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title View Detail Wizard Question Sequence Diagram

actor Admin
boundary "AdminWizardPage" as Page
participant "apiClient" as API
participant "WizardAdminController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "RolesGuard" as RoleGuard
participant "WizardService" as Service
database "Database" as DB

Admin -> Page : 1. Click "View Details" button
activate Admin
activate Page

Page -> API : 2. Request question detail
activate API

API -> Controller : 3. Send detail request with question ID
activate Controller

Controller -> JWTGuard : 4. Check sign-in session
activate JWTGuard
JWTGuard --> Controller : 5. Return authenticated user
deactivate JWTGuard

Controller -> RoleGuard : 6. Check role (ADMIN only)
activate RoleGuard
RoleGuard --> Controller : 7. Authorize
deactivate RoleGuard

Controller -> Service : 8. Get question details
activate Service

Service -> DB : 9. Load the question and its options\n(sorted by display order)
activate DB
DB --> Service : 10. Return question with options (or null)
deactivate DB

alt [Question Not Found]
    Service --> Controller : 11. Reject request: question not found
    deactivate Service

    Controller --> API : 12. Return 404 error
    deactivate Controller

    API --> Page : 13. Return error response
    deactivate API

    Page --> Admin : 14. Show error toast:\n"Question not found"
    deactivate Page

else [Question Found]
    Service -> Service : 15. Prepare question details\nfor display in the UI

    Service --> Controller : 16. Return question detail
    deactivate Service

    Controller --> API : 17. Return success response
    deactivate Controller

    API --> Page : 18. Return question data
    deactivate API

    Page -> Page : 19. Update state with question detail

    Page --> Admin : 20. Display question detail modal\n- Question info (code, label, help text)\n- Input type configuration\n- Active/Inactive status\n- Sort order\n- Options list with values
    deactivate Page
end

deactivate Admin

@enduml
