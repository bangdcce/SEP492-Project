@startuml
title UC-19 Edit Request Sequence Diagram

skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam sequence {
    ActorFontColor black
    ParticipantFontColor black
    TitleFontColor black
    GroupFontColor black
    GroupBorderColor black
}

actor "Client" as Actor
boundary "Edit Request Page" as Page
participant "ProjectRequestsController" as RequestController
participant "ProjectRequestsService" as RequestService
database "Database" as DB

Actor -> Page : 1. Open an editable request
activate Actor
activate Page

Page -> RequestController : 2. Request current request details
activate RequestController
RequestController -> RequestService : 3. Load request read model
activate RequestService
RequestService -> DB : 4. Fetch request, answers, and current status
activate DB
DB --> RequestService : 5. Return request detail
deactivate DB
RequestService --> RequestController : 6. Return request detail
deactivate RequestService
RequestController --> Page : 7. Return request detail
deactivate RequestController
Page --> Actor : 8. Display current values and editable status

alt [Request is still in draft or pending edit state]
    Actor -> Page : 9. Update request fields and answers
    Actor -> Page : 10. Click Save changes
    Page -> Page : 11. Validate changes and build update payload
    activate Page
    deactivate Page

    Page -> RequestController : 12. Submit request update
    activate RequestController
    RequestController -> RequestService : 13. Update request
    activate RequestService
    RequestService -> DB : 14. Load request and verify actor can update
    activate DB
    DB --> RequestService : 15. Return request
    deactivate DB

    alt [Visibility changes from PUBLIC_DRAFT to PRIVATE_DRAFT]
        RequestService -> DB : 16. Load pending broker proposals for this request
        activate DB
        DB --> RequestService : 17. Return pending proposals
        deactivate DB
        RequestService -> DB : 18. Mark pending broker proposals as REJECTED
        activate DB
        DB --> RequestService : 19. Confirm proposal updates
        deactivate DB
    else [Visibility remains unchanged]
        RequestService -> RequestService : 20. Keep existing broker application states
        activate RequestService
        deactivate RequestService
    end

    RequestService -> DB : 21. Save updated request fields and attachments
    activate DB
    DB --> RequestService : 22. Confirm request update
    deactivate DB

    alt [Updated answers were submitted]
        RequestService -> DB : 23. Replace stored answers with the edited answers
        activate DB
        DB --> RequestService : 24. Confirm answer updates
        deactivate DB
    else [No answer changes were submitted]
        RequestService -> RequestService : 25. Preserve existing answers
        activate RequestService
        deactivate RequestService
    end

    RequestService -> DB : 26. Reload the updated request detail
    activate DB
    DB --> RequestService : 27. Return refreshed request
    deactivate DB
    RequestService --> RequestController : 28. Return updated request
    deactivate RequestService
    RequestController --> Page : 29. Return update response
    deactivate RequestController
    Page --> Actor : 30. Show saved request details

else [Request is locked for editing]
    Page --> Actor : 31. Show read-only state and block the save action
end

deactivate Page
deactivate Actor
@enduml
