@startuml Ban_Unban_User_Account_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Ban/Unban User Account Sequence Diagram

actor "Admin" as Admin
boundary "AdminUsersPage" as Page
participant "apiClient" as API
participant ":UsersController" as Controller
participant ":JwtAuthGuard" as JWTGuard
participant ":RolesGuard" as RoleGuard
participant ":UsersService" as Service
database "Database" as DB

activate Admin

alt [Ban User]
    Admin -> Page : 1. Click "Ban" button
    activate Page

    Page --> Admin : 2. Display ban reason modal

    Admin -> Page : 3. Enter ban reason, click "Confirm"

    activate Page
    Page -> Page : 4. Validate reason is not empty
    deactivate Page

    Page -> API : 5. Send ban request
    activate API

    API -> Controller : 6. Forward request to server
    activate Controller

    Controller -> JWTGuard : 7. Check that the user is signed in
    activate JWTGuard
    JWTGuard --> Controller : 8. Return user information
    deactivate JWTGuard

    Controller -> RoleGuard : 9. Check permission (ADMIN or STAFF)
    activate RoleGuard
    RoleGuard --> Controller : 10. Allow request
    deactivate RoleGuard

    Controller -> Service : 11. Ask system to ban the user
    activate Service

    Service -> DB : 12. Find user record by id
    activate DB
    DB --> Service : 13. Return user record
    deactivate DB

    activate Service
    Service -> Service : 14. Make sure the account is not already banned

    Service -> Service : 15. Update banned status and save reason
    deactivate Service

    Service -> DB : 16. Save changes
    activate DB
    DB --> Service : 17. Confirm saved
    deactivate DB

    Service --> Controller : 18. Return success result
    deactivate Service

    Controller --> API : 19. Return success response
    deactivate Controller

    API --> Page : 20. Return result
    deactivate API

    Page --> Admin : 21. Show success message

    activate Page
    Page -> Page : 22. Close modal and refresh the list
    deactivate Page

    Page --> Admin : 23. User list refreshed
    deactivate Page

else [Unban User]
    Admin -> Page : 24. Click "Unban" button
    activate Page

    Page --> Admin : 25. Display unban reason modal

    Admin -> Page : 26. Enter unban reason, click "Confirm"

    activate Page
    Page -> Page : 27. Validate reason is not empty
    deactivate Page

    Page -> API : 28. Send unban request
    activate API

    API -> Controller : 29. Forward request to server
    activate Controller

    Controller -> JWTGuard : 30. Check that the user is signed in
    activate JWTGuard
    JWTGuard --> Controller : 31. Return user information
    deactivate JWTGuard

    Controller -> RoleGuard : 32. Check permission (ADMIN or STAFF)
    activate RoleGuard
    RoleGuard --> Controller : 33. Allow request
    deactivate RoleGuard

    Controller -> Service : 34. Ask system to unban the user
    activate Service

    Service -> DB : 35. Find user record by id
    activate DB
    DB --> Service : 36. Return user record
    deactivate DB

    activate Service
    Service -> Service : 37. Make sure the account is currently banned

    Service -> Service : 38. Update unbanned status
    deactivate Service

    Service -> DB : 39. Save changes
    activate DB
    DB --> Service : 40. Confirm saved
    deactivate DB

    Service --> Controller : 41. Return success result
    deactivate Service

    Controller --> API : 42. Return success response
    deactivate Controller

    API --> Page : 43. Return result
    deactivate API

    Page --> Admin : 44. Show success message

    activate Page
    Page -> Page : 45. Close modal and refresh the list
    deactivate Page

    Page --> Admin : 46. User list refreshed
    deactivate Page
end

deactivate Admin

@enduml
