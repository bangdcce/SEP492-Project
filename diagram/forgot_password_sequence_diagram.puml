@startuml Forgot_Password_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Forgot Password Sequence Diagram

actor "User" as Actor
boundary "ForgotPasswordPage" as Page
participant ":AuthController" as Controller
participant ":AuthService" as Service
participant ":EmailService" as EmailService
database "Database" as DB

Actor -> Page : 1. Access forgot password page
activate Actor
activate Page

Page -> Page : 2. Render step 1 form (email input)
activate Page
deactivate Page

Page --> Actor : 3. Display forgot password form

Actor -> Page : 4. Enter email and click "Send OTP"

Page -> Page : 5. Validate email format
activate Page
deactivate Page

alt [Invalid Email]
    Page --> Actor : 6. Show validation error
else [Valid Email]
    Page -> Page : 7. Show loading indicator
    activate Page
    deactivate Page

    Page -> Controller : 8. Send forgot password request
    activate Controller

    Controller -> Controller : 9. Validate request body
    activate Controller
    deactivate Controller

    alt [Invalid Payload]
        Controller --> Page : 10. Return validation error
        deactivate Controller
        Page --> Actor : 11. Show invalid email error
    else [Payload Valid]
        Controller -> Service : 12. forgotPassword(email)
        activate Service
        activate Service

        Service -> DB : 13. Find user by email
        activate DB
        DB --> Service : 14. Return user or null
        deactivate DB

        alt [User Not Found / Deleted / Banned]
            Service --> Controller : 15. Reject request
            deactivate Service
            Controller --> Page : 16. Return "Email does not exist"
            deactivate Controller
            Page --> Actor : 17. Show error toast
        else [User Eligible]
            Service -> EmailService : 18. Generate 6-digit OTP
            activate EmailService
            EmailService --> Service : 19. Return OTP
            deactivate EmailService

            Service -> DB : 20. Save OTP and expiration time
            activate DB
            DB --> Service : 21. Return update confirmation
            deactivate DB

            Service -> EmailService : 22. Send OTP email
            activate EmailService

            alt [Email Sent]
                EmailService --> Service : 23. Return send confirmation
            else [Email Send Failed]
                EmailService --> Service : 24. Throw send error
                Service -> Service : 25. Log warning and continue
                activate Service
                deactivate Service
            end
            deactivate EmailService

            Service -> EmailService : 26. Mask email for response
            activate EmailService
            EmailService --> Service : 27. Return masked email
            deactivate EmailService

            Service --> Controller : 28. Return forgot password result
            deactivate Service

            Controller --> Page : 29. Return success response
            deactivate Controller

            Page -> Page : 30. Move to OTP step and start resend countdown
            activate Page
            deactivate Page

            Page --> Actor : 31. Show OTP input step

            Actor -> Page : 32. Enter OTP and click "Verify"

            Page -> Page : 33. Validate OTP length
            activate Page
            deactivate Page

            alt [OTP Length Invalid]
                Page --> Actor : 34. Show OTP validation error
            else [OTP Length Valid]
                Page -> Controller : 35. Send verify OTP request
                activate Controller

                Controller -> Service : 36. verifyOtp(email, otp)
                activate Service

                Service -> DB : 37. Find user by email
                activate DB
                DB --> Service : 38. Return user with OTP data
                deactivate DB

                alt [Missing User / Missing OTP Data]
                    Service --> Controller : 39. Return invalid OTP result
                    deactivate Service
                    Controller --> Page : 40. Return invalid response
                    deactivate Controller
                    Page --> Actor : 41. Show "Invalid OTP code"
                else [User With OTP Data]
                    Service -> Service : 42. Check OTP expiration and value
                    activate Service
                    deactivate Service

                    alt [OTP Expired or Incorrect]
                        Service --> Controller : 43. Return invalid OTP result
                        deactivate Service
                        Controller --> Page : 44. Return invalid response
                        deactivate Controller
                        Page --> Actor : 45. Show OTP error
                    else [OTP Valid]
                        Service --> Controller : 46. Return valid OTP result
                        deactivate Service
                        Controller --> Page : 47. Return success response
                        deactivate Controller

                        Page -> Page : 48. Move to reset password step
                        activate Page
                        deactivate Page

                        Page --> Actor : 49. Show new password form

                        Actor -> Page : 50. Enter new password and confirmation\nClick "Reset Password"

                        Page -> Page : 51. Validate password rules and confirmation
                        activate Page
                        deactivate Page

                        alt [Password Rules Invalid]
                            Page --> Actor : 52. Show password validation errors
                        else [Password Valid]
                            Page -> Page : 53. Show loading indicator
                            activate Page
                            deactivate Page

                            Page -> Controller : 54. Send reset password request
                            activate Controller

                            Controller -> Service : 55. resetPassword(email, otp, newPassword, confirmPassword)
                            activate Service

                            Service -> Service : 56. Validate password confirmation
                            activate Service
                            deactivate Service

                            alt [Password Confirmation Mismatch]
                                Service --> Controller : 57. Reject reset request
                                deactivate Service
                                Controller --> Page : 58. Return reset error
                                deactivate Controller
                                Page --> Actor : 59. Show "Passwords do not match"
                            else [Confirmation Valid]
                                Service -> DB : 60. Find user by email
                                activate DB
                                DB --> Service : 61. Return user with OTP data
                                deactivate DB

                                alt [Invalid User / Missing OTP / Expired OTP / Wrong OTP]
                                    Service --> Controller : 62. Reject reset request
                                    deactivate Service
                                    Controller --> Page : 63. Return reset error
                                    deactivate Controller
                                    Page --> Actor : 64. Show OTP reset error
                                else [OTP Verified]
                                    Service -> Service : 65. Hash new password
                                    activate Service
                                    Service --> Service : 66. Return hashed password
                                    deactivate Service

                                    Service -> DB : 67. Update password and clear OTP
                                    activate DB
                                    DB --> Service : 68. Return update confirmation
                                    deactivate DB

                                    Service -> DB : 69. Revoke active auth sessions
                                    activate DB
                                    DB --> Service : 70. Return revoke confirmation
                                    deactivate DB

                                    Service --> Controller : 71. Return reset success
                                    deactivate Service
                                    Controller --> Page : 72. Return success response
                                    deactivate Controller

                                    Page -> Page : 73. Show success toast
                                    activate Page
                                    deactivate Page

                                    Page --> Actor : 74. Redirect to sign-in page
                                end
                            end
                        end
                    end
                end
            end
        end
        deactivate Service
    end
end

deactivate Page
deactivate Actor

@enduml
