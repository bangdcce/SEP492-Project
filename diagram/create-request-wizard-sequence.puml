@startuml
title Create Request Wizard Sequence Diagram

skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam sequence {
    ActorFontColor black
    ParticipantFontColor black
    TitleFontColor black
    GroupFontColor black
    GroupBorderColor black
}

actor "Client" as Actor
boundary "Wizard Page" as Page
participant "WizardController" as WizardController
participant "WizardService" as WizardService
participant "KycController" as KycController
participant "KycService" as KycService
participant "ProjectRequestsController" as RequestController
participant "ProjectRequestsService" as RequestService
participant "QuotaService" as QuotaService
database "Database" as DB

Actor -> Page : 1. Open Create Request wizard
activate Actor
activate Page

par [Load wizard questions]
    Page -> WizardController : 2. Request active wizard questions
    activate WizardController
    WizardController -> WizardService : 3. Load wizard question data
    activate WizardService
    WizardService -> DB : 4. Fetch active questions and options
    activate DB
    DB --> WizardService : 5. Return ordered question set
    deactivate DB
    WizardService --> WizardController : 6. Return wizard data
    deactivate WizardService
    WizardController --> Page : 7. Return wizard questions
    deactivate WizardController
else [Load KYC status]
    Page -> KycController : 8. Request current KYC status
    activate KycController
    KycController -> KycService : 9. Load latest KYC status
    activate KycService
    KycService -> DB : 10. Query latest KYC submission
    activate DB
    DB --> KycService : 11. Return latest KYC record or no record
    deactivate DB
    KycService --> KycController : 12. Return KYC status
    deactivate KycService
    KycController --> Page : 13. Return KYC status
    deactivate KycController
end

Page --> Actor : 14. Display step 1 and show whether final actions are enabled

Actor -> Page : 15. Select project type
Actor -> Page : 16. Click Next
Page --> Actor : 17. Show industry step

Actor -> Page : 18. Select industry
Actor -> Page : 19. Click Next
Page --> Actor : 20. Show budget and timeline step

Actor -> Page : 21. Enter budget range
Actor -> Page : 22. Enter expected completion date
Actor -> Page : 23. Click Next
Page --> Actor : 24. Show feature preferences step

Actor -> Page : 25. Choose feature preferences
Actor -> Page : 26. Click Next
Page --> Actor : 27. Show title and detailed description step

Actor -> Page : 28. Enter project title
Actor -> Page : 29. Enter detailed description
Actor -> Page : 30. Click Post to Market or Find & Invite

Page -> Page : 31. Validate KYC gate and prepare submission payload
activate Page
deactivate Page

alt [KYC approved and client chooses Post to Market]
    Page -> RequestController : 32. Submit a new public draft request
    activate RequestController
    RequestController -> RequestService : 33. Create request from wizard data
    activate RequestService
    RequestService -> QuotaService : 34. Check whether the client can create another request
    activate QuotaService
    QuotaService -> DB : 35. Count active request usage against plan limits
    activate DB
    DB --> QuotaService : 36. Return quota result
    deactivate DB
    QuotaService --> RequestService : 37. Allow request creation
    deactivate QuotaService
    RequestService -> DB : 38. Save the request and wizard answers as PUBLIC_DRAFT
    activate DB
    DB --> RequestService : 39. Return saved request
    deactivate DB
    RequestService --> RequestController : 40. Return created request
    deactivate RequestService
    RequestController --> Page : 41. Return created request
    deactivate RequestController

    Page -> RequestController : 42. Publish the request to the marketplace
    activate RequestController
    RequestController -> RequestService : 43. Publish the existing request
    activate RequestService
    alt [Request is already PUBLIC_DRAFT]
        RequestService --> RequestController : 44. Return existing public request
    else [Request must be normalized to PUBLIC_DRAFT]
        RequestService -> DB : 45. Update request visibility to PUBLIC_DRAFT
        activate DB
        DB --> RequestService : 46. Confirm publish result
        deactivate DB
        RequestService --> RequestController : 47. Return published request
    end
    deactivate RequestService
    RequestController --> Page : 48. Return publish result
    deactivate RequestController

    Page --> Actor : 49. Show success message and redirect to the client dashboard

else [KYC approved and client chooses Find & Invite]
    Page -> RequestController : 50. Submit a new private draft request
    activate RequestController
    RequestController -> RequestService : 51. Create request from wizard data
    activate RequestService
    RequestService -> QuotaService : 52. Check whether the client can create another request
    activate QuotaService
    QuotaService -> DB : 53. Count active request usage against plan limits
    activate DB
    DB --> QuotaService : 54. Return quota result
    deactivate DB
    QuotaService --> RequestService : 55. Allow request creation
    deactivate QuotaService
    RequestService -> DB : 56. Save the request and wizard answers as PRIVATE_DRAFT
    activate DB
    DB --> RequestService : 57. Return saved request
    deactivate DB
    RequestService --> RequestController : 58. Return created request
    deactivate RequestService
    RequestController --> Page : 59. Return created request
    deactivate RequestController

    Page --> Actor : 60. Show success message and redirect to request detail phase 1

else [KYC not approved]
    Page --> Actor : 61. Keep final actions disabled and show KYC required message
end

deactivate Page
deactivate Actor
@enduml
