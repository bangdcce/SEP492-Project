@startuml Verify_Email_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Verify Email Sequence Diagram

actor "User" as Actor
boundary "VerifyEmailPage" as Page
participant "AuthController" as Controller
participant "EmailVerificationService" as VerifyService
database "Database" as DB

Actor -> Page : 1. Open verification link from email
activate Actor
activate Page

Page -> Page : 2. Read token and pending email from URL
activate Page
deactivate Page

alt [Token Missing, Pending Email Exists]
    Page -> Page : 3. Set pending verification state
    activate Page
    deactivate Page
    Page --> Actor : 4. Show pending message and resend option
else [Token Missing, No Pending Email]
    Page -> Page : 5. Set invalid token error state
    activate Page
    deactivate Page
    Page --> Actor : 6. Show invalid verification link error
else [Token Present]
    Page -> Page : 7. Show loading state
    activate Page
    deactivate Page

    Page -> Controller : 8. Send verify email request with token
    activate Controller

    Controller -> VerifyService : 9. verifyEmail(token)
    activate VerifyService

    VerifyService -> VerifyService : 10. Validate token presence
    activate VerifyService
    deactivate VerifyService

    VerifyService -> DB : 11. Find user by verification token
    activate DB
    DB --> VerifyService : 12. Return matching user or null
    deactivate DB

    alt [Invalid Token]
        VerifyService --> Controller : 13. Reject invalid or expired token
        activate Controller
        Controller --> Page : 14. Return verification error
        deactivate Controller

        Page -> Page : 15. Decide whether the token is expired
        activate Page
        deactivate Page

        alt [Token Expired]
            Page --> Actor : 16. Show expired link state with resend form
        else [Invalid Token]
            Page --> Actor : 17. Show verification failed state
        end
    else [User Found]
        VerifyService -> VerifyService : 18. Check deleted account and current verification state
        activate VerifyService
        deactivate VerifyService

        alt [Deleted Account]
            VerifyService --> Controller : 19. Reject deleted account
            activate Controller
            Controller --> Page : 20. Return deleted account error
            deactivate Controller
            Page --> Actor : 21. Show verification failed state
        else [Already Verified]
            VerifyService --> Controller : 22. Reject already verified email
            activate Controller
            Controller --> Page : 23. Return already verified error
            deactivate Controller
            Page --> Actor : 24. Show already verified message
        else [Verification Token Expired]
            VerifyService --> Controller : 25. Reject expired token
            activate Controller
            Controller --> Page : 26. Return expired token error
            deactivate Controller
            Page --> Actor : 27. Show expired link state with resend form
        else [Token Valid]
            VerifyService -> DB : 28. Mark email as verified and clear token
            activate DB
            DB --> VerifyService : 29. Return update confirmation
            deactivate DB

            VerifyService --> Controller : 30. Return verification success
            activate Controller
            Controller --> Page : 31. Return verified email response
            deactivate Controller

            Page -> Page : 32. Show success state and start redirect timer
            activate Page
            deactivate Page

            Page --> Actor : 33. Show success message
            Page --> Actor : 34. Redirect to login page after delay
        end
    end
end

opt [Expired or Pending State and User Clicks Resend]
    Actor -> Page : 35. Enter email if needed and click "Resend verification email"

    Page -> Page : 36. Validate resend email format
    activate Page
    deactivate Page

    alt [Invalid Email]
        Page --> Actor : 37. Show invalid email error
    else [Valid Email]
        Page -> Page : 38. Show resending state
        activate Page
        deactivate Page

        Page -> Controller : 39. Send resend verification request
        activate Controller
        Controller -> VerifyService : 40. resendVerificationEmail(email)

        VerifyService -> DB : 41. Find user by email
        activate DB
        DB --> VerifyService : 42. Return user or null
        deactivate DB

        alt [User Not Found]
            VerifyService --> Controller : 43. Reject resend request
            activate Controller
            Controller --> Page : 44. Return resend error
            deactivate Controller
            Page --> Actor : 45. Show resend error toast
        else [User Found]
            VerifyService -> VerifyService : 46. Check already verified and resend cooldown
            activate VerifyService
            deactivate VerifyService

            alt [Already Verified or Cooldown Active]
                VerifyService --> Controller : 47. Reject resend request
                activate Controller
                Controller --> Page : 48. Return resend error
                deactivate Controller
                Page --> Actor : 49. Show resend error toast
            else [Resend Allowed]
                VerifyService -> VerifyService : 50. Generate new token and expiry
                activate VerifyService
                deactivate VerifyService

                VerifyService -> DB : 51. Save new verification token
                activate DB
                DB --> VerifyService : 52. Return update confirmation
                deactivate DB

                VerifyService -> VerifyService : 53. Send verification email
                activate VerifyService
                deactivate VerifyService

                VerifyService --> Controller : 54. Return resend success
                activate Controller
                Controller --> Page : 55. Return success response
                deactivate Controller

                Page -> Page : 56. Clear error state and resend input
                activate Page
                deactivate Page

                Page --> Actor : 57. Show resend success toast
            end
        end
    end
end

deactivate VerifyService
deactivate Page
deactivate Actor

@enduml
