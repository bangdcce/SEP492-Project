@startuml Logout_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title User Logout Sequence Diagram

actor "User" as Actor
boundary "Header" as Page
participant "Auth API" as Api
participant "AuthController" as Controller
participant "AuthService" as Service
database "Database" as DB

Actor -> Page : 1. Open user menu
activate Actor
activate Page

Page --> Actor : 2. Display "Logout" action

Actor -> Page : 3. Click "Logout"
Page -> Page : 4. Close dropdown menu
activate Page
deactivate Page

Page -> Api : 5. Call signOut()
activate Api

Api -> Controller : 6. POST /auth/logout\n(with access cookie + optional refresh cookie)
activate Controller

Controller -> Controller : 7. Read authenticated user id\nand refreshToken from cookie
activate Controller
deactivate Controller

Controller -> Service : 8. Logout(userId, refreshToken)
activate Service

alt [Refresh token cookie exists]
    Service -> DB : 9. Find active session by refresh token fingerprint
    activate DB
    DB --> Service : 10. Return direct match or null
    deactivate DB

    alt [Fingerprint Match Found]
        Service -> DB : 11. Revoke the matched session
        activate DB
        DB --> Service : 12. Return update confirmation
        deactivate DB
    else [No Fingerprint Match]
        Service -> DB : 13. Load active sessions for the user
        activate DB
        DB --> Service : 14. Return active sessions
        deactivate DB

        loop 15. Compare provided refresh token with legacy session hashes
            Service -> Service : 16. bcrypt.compare(refreshToken, refreshTokenHash)
            activate Service
            deactivate Service
        end

        alt [Legacy Session Match Found]
            Service -> DB : 17. Save missing refresh token fingerprint
            activate DB
            DB --> Service : 18. Return update confirmation
            deactivate DB

            Service -> DB : 19. Revoke the matched legacy session
            activate DB
            DB --> Service : 20. Return update confirmation
            deactivate DB
        else [No Legacy Session Match]
            Service -> Service : 21. Continue logout without additional session update
            activate Service
            deactivate Service
        end
    end
else [Refresh token cookie missing]
    Service -> DB : 22. Revoke all active sessions of the user
    activate DB
    DB --> Service : 23. Return bulk update confirmation
    deactivate DB
end

Service --> Controller : 24. Return logout success response
deactivate Service

Controller -> Controller : 25. Clear accessToken and refreshToken cookies
activate Controller
Controller --> Controller : 26. Finish clearing cookies
deactivate Controller

Controller --> Api : 27. Return 200 OK with success message
deactivate Controller
Api --> Page : 28. Resolve signOut()
deactivate Api

Page -> Page : 29. Remove user profile from local storage
activate Page
deactivate Page

Page -> Page : 30. Dispatch userDataUpdated event
activate Page
deactivate Page

Page --> Actor : 31. Redirect user to Login Page

deactivate Page
deactivate Actor

@enduml
