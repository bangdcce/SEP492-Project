@startuml UC29_View_List_Freelancer_Recommendation_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-29 View List Freelancer Recommendation Sequence Diagram

actor Client

boundary "RequestDetailPage" as Page

participant "wizardService" as WizardAPI

participant "apiClient" as ApiClient

participant "ProjectRequestsController" as Controller

participant "JwtAuthGuard" as JWTGuard

participant "ProjectRequestsService" as Service

database "Database" as DB

Client -> Page : 1. Open the request detail page and switch to phase 3 "Freelancer Recommendations"

activate Client

activate Page

Page -> WizardAPI : 2. Load request detail

activate WizardAPI

WizardAPI -> ApiClient : 3. Forward HTTP request

activate ApiClient

ApiClient -> Controller : 4. Load request details

activate Controller

Controller -> JWTGuard : 5. Confirm the client is signed in

activate JWTGuard

JWTGuard --> Controller : 6. Return authenticated client identity

deactivate JWTGuard

Controller -> Service : 7. Load request detail and freelancer selection summary

activate Service

Service -> DB : 8. Query request, broker assignment, and freelancer recommendation items

activate DB

DB --> Service : 9. Return request detail with freelancerSelectionSummary

deactivate DB

Service --> Controller : 10. Return request detail response

deactivate Service

Controller --> ApiClient : 11. Return server response

deactivate Controller

ApiClient --> WizardAPI : 12. Return request detail response

deactivate ApiClient

WizardAPI --> Page : 13. Render pending, invited, accepted, and rejected freelancer recommendation cards

deactivate WizardAPI

Page -> Page : 14. Group recommendations by status and show client action buttons where allowed

Page --> Client : 15. Show the list of freelancer recommendations for the request

deactivate Page

deactivate Client

@enduml
