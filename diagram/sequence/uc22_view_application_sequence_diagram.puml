@startuml UC22_View_Application_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}


title UC-22 View Application Sequence Diagram

actor user
boundary "MyInvitationsPage" as ListPage
boundary "InvitationDetailsPage" as DetailPage
participant "discoveryApi" as DiscoveryAPI
participant "apiClient" as ApiClient
participant "ProjectRequestsController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "ProjectRequestsService" as Service
database "Database" as DB

user -> ListPage : 1. Open "My Invitations"
activate user
activate ListPage
ListPage -> ListPage : 2. Show loading state for invitations or applications
ListPage -> DiscoveryAPI : 3. Request the current invitation or application list
activate DiscoveryAPI
DiscoveryAPI -> ApiClient : 4. Forward HTTP request
activate ApiClient
ApiClient -> Controller : 5. Send GET "/project-requests/invitations/my"
activate Controller
Controller -> JWTGuard : 6. Confirm the user is signed in
activate JWTGuard
JWTGuard --> Controller : 7. Return authenticated user identity and role
deactivate JWTGuard
Controller -> Service : 8. Load invitations or applications for the current role
activate Service
Service -> DB : 9. Query linked invitation rows, request data, and client context
activate DB
DB --> Service : 10. Return invitation or application records
deactivate DB
Service --> Controller : 11. Return the current invitation or application list
deactivate Service
Controller --> ApiClient : 12. Return server response
deactivate Controller
ApiClient --> DiscoveryAPI : 13. Return invitation list payload
deactivate ApiClient
DiscoveryAPI --> ListPage : 14. Render invitation or application cards
deactivate DiscoveryAPI
user -> ListPage : 15. Click a selected invitation or application row
ListPage --> DetailPage : 16. Navigate to the detail page
activate DetailPage
DetailPage -> DiscoveryAPI : 17. Reload the list to resolve the selected invitation id
activate DiscoveryAPI
DiscoveryAPI -> ApiClient : 18. Forward HTTP request
activate ApiClient
ApiClient -> Controller : 19. Send GET "/project-requests/invitations/my"
activate Controller
Controller -> Service : 20. Reload invitations for the current role
activate Service
Service -> DB : 21. Query the latest invitation and linked request data
activate DB
DB --> Service : 22. Return current invitation rows
deactivate DB
Service --> Controller : 23. Return invitation detail source data
deactivate Service
Controller --> ApiClient : 24. Return server response
deactivate Controller
ApiClient --> DiscoveryAPI : 25. Return invitation detail payload
deactivate ApiClient
DiscoveryAPI --> DetailPage : 26. Return data for the selected item
deactivate DiscoveryAPI
DetailPage -> DetailPage : 27. Find the selected record and prepare the detail view
DetailPage --> user : 28. Show the application or invitation detail with status and available response actions
deactivate DetailPage
deactivate ListPage
deactivate user

@enduml
