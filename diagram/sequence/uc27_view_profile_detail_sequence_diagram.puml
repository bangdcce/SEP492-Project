@startuml UC27_View_Profile_Detail_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-27 View Profile Detail Sequence Diagram

actor user

boundary "DiscoveryPage" as ListPage

boundary "PartnerProfilePage" as ProfilePage

participant "discoveryApi" as DiscoveryAPI

participant "apiClient" as ApiClient

participant "UsersSearchController" as Controller

participant "JwtAuthGuard" as JWTGuard

participant "UsersSearchService" as Service

database "Database" as DB

user -> ListPage : 1. Open "Find Partners"

activate user

activate ListPage

ListPage -> DiscoveryAPI : 2. Request available brokers or freelancers

activate DiscoveryAPI

DiscoveryAPI -> ApiClient : 3. Forward HTTP request

activate ApiClient

ApiClient -> Controller : 4. Send GET "/discovery/users"

activate Controller

Controller -> JWTGuard : 5. Confirm the signed-in user identity

activate JWTGuard

JWTGuard --> Controller : 6. Return authenticated user identity

Controller -> Service : 7. Search partner profiles using role and keyword filters

activate Service

Service -> DB : 8. Query verified, non-banned brokers/freelancers with profile and skills

activate DB

DB --> Service : 9. Return ranked partner list

deactivate DB

Service --> Controller : 10. Return partner search result

Controller --> ApiClient : 11. Return server response

ApiClient --> DiscoveryAPI : 12. Return partner search response

DiscoveryAPI --> ListPage : 13. Render partner cards with the "View Profile" action

user -> ListPage : 14. Click "View Profile" on a partner card

ListPage --> ProfilePage : 15. Navigate to the public profile page

activate ProfilePage

ProfilePage -> DiscoveryAPI : 16. Request the selected partner profile

DiscoveryAPI -> ApiClient : 17. Forward HTTP request

ApiClient -> Controller : 18. Send GET "/discovery/profile/{userId}"

Controller -> JWTGuard : 19. Confirm the signed-in user identity

JWTGuard --> Controller : 20. Return authenticated user identity

deactivate JWTGuard

Controller -> Service : 21. Load the partner's public profile

Service -> DB : 22. Query user, public profile, and skills

activate DB

DB --> Service : 23. Return public profile data

deactivate DB

Service --> Controller : 24. Return public profile data

deactivate Service

Controller --> ApiClient : 25. Return server response

deactivate Controller

ApiClient --> DiscoveryAPI : 26. Return public profile response

deactivate ApiClient

DiscoveryAPI --> ProfilePage : 27. Render full profile details, trust score, skills, and invite entry

deactivate DiscoveryAPI

ProfilePage --> user : 28. Show the partner profile detail page

deactivate ProfilePage

deactivate ListPage

deactivate user

@enduml
