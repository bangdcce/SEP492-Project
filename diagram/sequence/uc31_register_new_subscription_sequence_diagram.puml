@startuml UC31_Register_New_Subscription_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-31 Register New Subscription Sequence Diagram

actor user

boundary "SubscriptionPage" as SubscriptionPage

boundary "SubscriptionPayPalSetupDialog" as PayPalSetupDialog

boundary "SubscriptionCheckoutPage" as CheckoutPage

boundary "PayPalSubscriptionCheckout" as PayPalCheckout

participant "paymentsApi" as PaymentsAPI

participant "subscriptionsApi" as SubscriptionAPI

participant "apiClient" as ApiClient

participant "PaymentMethodsController" as PaymentController

participant "SubscriptionsController" as SubscriptionController

participant "JwtAuthGuard" as JWTGuard

participant "SubscriptionsService" as SubscriptionService

participant "PayPalCheckoutService" as PayPalService

database "Database" as DB

user -> SubscriptionPage : 1. Open the "Subscription" page

activate user

activate SubscriptionPage

user -> SubscriptionPage : 2. Click "Set Up PayPal First" or "Continue to Purchase"

alt [No PayPal funding method is saved]

    SubscriptionPage -> PayPalSetupDialog : 3. Open the PayPal setup dialog

    activate PayPalSetupDialog

    user -> PayPalSetupDialog : 4. Enter PayPal email and click "Save"

    PayPalSetupDialog -> PaymentsAPI : 5. Call createPaymentMethod()

    activate PaymentsAPI

    PaymentsAPI -> ApiClient : 6. Forward HTTP request

    activate ApiClient

    ApiClient -> PaymentController : 7. Save payment method

    activate PaymentController

    PaymentController -> JWTGuard : 8. Confirm the user is signed in

    activate JWTGuard

    JWTGuard --> PaymentController : 9. Return authenticated user identity

    PaymentController -> DB : 10. Save the PayPal payment method for the user

    activate DB

    DB --> PaymentController : 11. Persist the payment method

    deactivate DB

    PaymentController --> ApiClient : 12. Return server response

    deactivate PaymentController

    ApiClient --> PaymentsAPI : 13. Return saved PayPal method

    PaymentsAPI --> PayPalSetupDialog : 14. Confirm the PayPal method was saved

    deactivate PaymentsAPI

    PayPalSetupDialog --> SubscriptionPage : 15. Close dialog and continue to checkout

    deactivate PayPalSetupDialog

end

SubscriptionPage -> CheckoutPage : 16. Navigate to the "Premium Checkout" page

activate CheckoutPage

CheckoutPage -> SubscriptionAPI : 17. Call getMySubscription(), getSubscriptionPlans(), and getPaymentMethods()

activate SubscriptionAPI

SubscriptionAPI -> ApiClient : 18. Forward HTTP request

ApiClient -> SubscriptionController : 19. Load current subscription and available plans

activate SubscriptionController

SubscriptionController -> JWTGuard : 20. Confirm the user is signed in

JWTGuard --> SubscriptionController : 21. Return authenticated user identity and role

SubscriptionController -> SubscriptionService : 22. Load plans for the user's role and current subscription state

activate SubscriptionService

SubscriptionService -> DB : 23. Query subscription plans, current subscription, and pricing

activate DB

DB --> SubscriptionService : 24. Return checkout data

deactivate DB

SubscriptionService --> SubscriptionController : 25. Return plan list and subscription snapshot

SubscriptionController --> ApiClient : 26. Return server response

ApiClient --> SubscriptionAPI : 27. Return checkout prerequisites

SubscriptionAPI --> CheckoutPage : 28. Return plans, cycle pricing, and subscription state

user -> CheckoutPage : 29. Choose a billing cycle and a premium plan card

CheckoutPage -> PayPalCheckout : 30. Load the embedded PayPal checkout block

activate PayPalCheckout

PayPalCheckout -> SubscriptionAPI : 31. Call getSubscriptionPayPalConfig(planId, billingCycle, paymentMethodId)

SubscriptionAPI -> ApiClient : 32. Forward HTTP request

ApiClient -> SubscriptionController : 33. Load PayPal configuration

SubscriptionController -> JWTGuard : 34. Confirm the user is signed in

JWTGuard --> SubscriptionController : 35. Return authenticated user identity

deactivate JWTGuard

SubscriptionController -> SubscriptionService : 36. Build the PayPal charge quote and buyer context

SubscriptionService -> DB : 37. Load selected plan and saved payment method

activate DB

DB --> SubscriptionService : 38. Return plan and payment method

deactivate DB

SubscriptionService --> SubscriptionController : 39. Return PayPal checkout config

SubscriptionController --> ApiClient : 40. Return server response

ApiClient --> SubscriptionAPI : 41. Return checkout configuration

SubscriptionAPI --> PayPalCheckout : 42. Return PayPal SDK config and quoted amount

user -> PayPalCheckout : 43. Click the PayPal button and approve the order

PayPalCheckout -> SubscriptionAPI : 44. Call createPayPalSubscriptionOrder()

SubscriptionAPI -> ApiClient : 45. Forward HTTP request

ApiClient -> SubscriptionController : 46. Create PayPal order

SubscriptionController -> SubscriptionService : 47. Create a PayPal order for the chosen plan

SubscriptionService -> PayPalService : 48. Request a PayPal order id for the subscription charge

activate PayPalService

PayPalService --> SubscriptionService : 49. Return created PayPal order

SubscriptionService --> SubscriptionController : 50. Return PayPal order data

SubscriptionController --> ApiClient : 51. Return server response

ApiClient --> SubscriptionAPI : 52. Return order id to the browser

SubscriptionAPI --> PayPalCheckout : 53. Return PayPal order id

PayPalCheckout -> SubscriptionAPI : 54. After approval, call subscribeToPlan(planId, billingCycle, paymentMethodId, orderId)

SubscriptionAPI -> ApiClient : 55. Forward HTTP request

ApiClient -> SubscriptionController : 56. Activate subscription

SubscriptionController -> SubscriptionService : 57. Capture the approved PayPal order and activate premium

SubscriptionService -> PayPalService : 58. Capture the approved PayPal order

PayPalService --> SubscriptionService : 59. Return capture result and payer details

deactivate PayPalService

SubscriptionService -> DB : 60. Save the active subscription and update the PayPal method vault metadata

activate DB

DB --> SubscriptionService : 61. Persist subscription and payment updates

deactivate DB

SubscriptionService --> SubscriptionController : 62. Return active subscription summary

deactivate SubscriptionService

SubscriptionController --> ApiClient : 63. Return server response

deactivate SubscriptionController

ApiClient --> SubscriptionAPI : 64. Return success response

deactivate ApiClient

SubscriptionAPI --> PayPalCheckout : 65. Return activated premium subscription

deactivate SubscriptionAPI

PayPalCheckout --> CheckoutPage : 66. Show success and refresh checkout state

deactivate PayPalCheckout

CheckoutPage --> user : 67. Show that premium is active and the purchase completed successfully

deactivate CheckoutPage

deactivate SubscriptionPage

deactivate user

@enduml
