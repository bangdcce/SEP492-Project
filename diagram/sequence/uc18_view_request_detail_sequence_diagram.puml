@startuml UC18_View_Request_Detail_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}


title UC-18 View Request Detail Sequence Diagram

actor user
boundary "Request Detail Page" as Page
participant "wizardService / projectRequestsApi" as RequestAPI
participant "apiClient" as ApiClient
participant "ProjectRequestsController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "ProjectRequestsService" as Service
database "Database" as DB

user -> Page : 1. Open a request detail page from the current list or marketplace
activate user
activate Page
Page -> Page : 2. Show loading state
Page -> RequestAPI : 3. Request request detail by id
activate RequestAPI
RequestAPI -> ApiClient : 4. Forward HTTP request
activate ApiClient
ApiClient -> Controller : 5. Load request details
activate Controller
Controller -> JWTGuard : 6. Confirm the user is signed in
activate JWTGuard
JWTGuard --> Controller : 7. Return authenticated user identity and role
deactivate JWTGuard
Controller -> Service : 8. Load request detail for the current viewer
activate Service
Service -> DB : 9. Query request, answers, proposals, specs, contract summary, and viewer relations
activate DB
DB --> Service : 10. Return request detail data
deactivate DB
Service -> Service : 11. Apply role-based visibility, masking, and viewer permissions
Service --> Controller : 12. Return request detail allowed for the current viewer
deactivate Service
Controller --> ApiClient : 13. Return server response
deactivate Controller
ApiClient --> RequestAPI : 14. Return request detail payload
deactivate ApiClient
RequestAPI --> Page : 15. Return request detail to the page
deactivate RequestAPI
Page --> user : 16. Show request information, workflow state, and the next actions allowed for that role
deactivate Page
deactivate user

@enduml
