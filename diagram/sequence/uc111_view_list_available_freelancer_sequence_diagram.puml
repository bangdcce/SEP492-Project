@startuml UC111_View_List_Available_Freelancer_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-111 View List Available Freelancer Sequence Diagram

actor Broker

boundary "ProjectRequestDetailsPage" as DetailPage

boundary "RequestFreelancerMarketPanel" as FreelancerPanel

participant "wizardService" as WizardService

participant "apiClient" as ApiClient

participant "MatchingController" as Controller

participant "JwtAuthGuard" as JWTGuard

participant "MatchingService" as Service

database "Database" as DB

Broker -> DetailPage : 1. Open a broker-assigned request that has reached freelancer recruitment

activate Broker

activate DetailPage

DetailPage -> DetailPage : 2. Resolve workflow phase and decide to load freelancer matches

DetailPage -> FreelancerPanel : 3. Show the "Freelancer Recruitment" panel

activate FreelancerPanel

Broker -> FreelancerPanel : 4. Click "Quick Match" or "Get AI Suggestion"

alt [Quick Match]

    FreelancerPanel -> WizardService : 5. Call getFreelancerMatchesQuick(requestId, topN)

    activate WizardService

    WizardService -> Controller : 6. Send GET "/matching/{requestId}?role=FREELANCER&enableAi=false"

    activate Controller

else [AI Suggestion]

    FreelancerPanel -> WizardService : 7. Call getFreelancerMatches(requestId, enableAi=true, topN)

    WizardService -> Controller : 8. Send GET "/matching/{requestId}?role=FREELANCER&enableAi=true"

end

Controller -> JWTGuard : 9. Confirm the broker is signed in

activate JWTGuard

JWTGuard --> Controller : 10. Return authenticated broker identity

deactivate JWTGuard

Controller -> Service : 11. Find ranked freelancer matches for the request

activate Service

Service -> DB : 12. Load request detail, current proposals, and eligible freelancer candidates

activate DB

DB --> Service : 13. Return request context and candidate pool

deactivate DB

Service -> Service : 14. Filter, score, and rank freelancer candidates

Service --> Controller : 15. Return ranked freelancer matches

deactivate Service

Controller --> WizardService : 16. Return match list

deactivate Controller

WizardService --> FreelancerPanel : 17. Return ranked freelancer data

deactivate WizardService

FreelancerPanel --> Broker : 18. Show ranked freelancers with "Profile" and "Invite" actions

deactivate FreelancerPanel

deactivate DetailPage

deactivate Broker

@enduml
