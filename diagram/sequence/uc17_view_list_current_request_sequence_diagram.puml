@startuml UC17_View_List_Current_Request_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}


title UC-17 View List Current Request Sequence Diagram

actor user
boundary "Current Requests Page" as Page
participant "wizardService / projectRequestsApi" as RequestAPI
participant "apiClient" as ApiClient
participant "ProjectRequestsController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "ProjectRequestsService" as Service
database "Database" as DB

user -> Page : 1. Open the current-requests page for the signed-in role
activate user
activate Page
Page -> Page : 2. Show loading state, filters, and search controls
Page -> RequestAPI : 3. Request the current request list for the active role
activate RequestAPI
RequestAPI -> ApiClient : 4. Forward HTTP request
activate ApiClient
ApiClient -> Controller : 5. Send the role-specific current-request endpoint
activate Controller
Controller -> JWTGuard : 6. Confirm the user is signed in
activate JWTGuard
JWTGuard --> Controller : 7. Return authenticated user identity and role
deactivate JWTGuard
Controller -> Service : 8. Load the current request list for that role
activate Service
Service -> DB : 9. Query matching requests, invitations, or accessible request rows
activate DB
DB --> Service : 10. Return request records and related workflow state
deactivate DB
Service --> Controller : 11. Return the role-appropriate request list
deactivate Service
Controller --> ApiClient : 12. Return server response
deactivate Controller
ApiClient --> RequestAPI : 13. Return request list payload
deactivate ApiClient
RequestAPI --> Page : 14. Return current requests to the page
deactivate RequestAPI
Page -> Page : 15. Apply search, filters, and role-specific grouping
Page --> user : 16. Show current requests with the available "View Details" or "Open Request" action
deactivate Page
deactivate user

@enduml
