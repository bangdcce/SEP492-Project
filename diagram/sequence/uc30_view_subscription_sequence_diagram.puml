@startuml UC30_View_Subscription_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-30 View Subscription Sequence Diagram

actor user

boundary "SubscriptionPage" as Page

participant "subscriptionsApi" as SubscriptionAPI

participant "paymentsApi" as PaymentsAPI

participant "apiClient" as ApiClient

participant "SubscriptionsController" as SubscriptionController

participant "PaymentMethodsController" as PaymentController

participant "JwtAuthGuard" as JWTGuard

participant "SubscriptionsService" as SubscriptionService

participant "QuotaService" as QuotaService

database "Database" as DB

user -> Page : 1. Open the "Subscription" page

activate user

activate Page

Page -> Page : 2. Show loading state

Page -> SubscriptionAPI : 3. Call getMySubscription()

activate SubscriptionAPI

SubscriptionAPI -> ApiClient : 4. Forward HTTP request

activate ApiClient

ApiClient -> SubscriptionController : 5. Load current subscription

activate SubscriptionController

SubscriptionController -> JWTGuard : 6. Confirm the user is signed in

activate JWTGuard

JWTGuard --> SubscriptionController : 7. Return authenticated user identity and role

SubscriptionController -> SubscriptionService : 8. Load the current subscription snapshot

activate SubscriptionService

SubscriptionService -> DB : 9. Query active subscription, plan perks, and base user state

activate DB

DB --> SubscriptionService : 10. Return subscription snapshot or free-tier state

deactivate DB

SubscriptionController -> QuotaService : 11. Load quota usage summary for the same user

activate QuotaService

QuotaService --> SubscriptionController : 12. Return quota usage data

deactivate QuotaService

SubscriptionService --> SubscriptionController : 13. Return subscription details

deactivate SubscriptionService

SubscriptionController --> ApiClient : 14. Return server response

deactivate SubscriptionController

ApiClient --> SubscriptionAPI : 15. Return success response with subscription data and usage

SubscriptionAPI --> Page : 16. Return current subscription data

deactivate SubscriptionAPI

alt [Account is on free tier]

    Page -> PaymentsAPI : 17. Call getPaymentMethods()

    activate PaymentsAPI

    PaymentsAPI -> ApiClient : 18. Forward HTTP request

    ApiClient -> PaymentController : 19. Load saved payment methods

    activate PaymentController

    PaymentController -> JWTGuard : 20. Confirm the same user is signed in

    JWTGuard --> PaymentController : 21. Return authenticated user identity

    deactivate JWTGuard

    PaymentController -> DB : 22. Load saved payment methods for the account

    activate DB

    DB --> PaymentController : 23. Return payment methods or an empty list

    deactivate DB

    PaymentController --> ApiClient : 24. Return server response

    deactivate PaymentController

    ApiClient --> PaymentsAPI : 25. Return saved payment methods

    deactivate ApiClient

    PaymentsAPI --> Page : 26. Return PayPal method data

    deactivate PaymentsAPI

    Page --> user : 27. Show "Free Plan", usage, and either "Continue to Purchase" or "Set Up PayPal First"

else [Account already has premium]

    Page --> user : 28. Show active premium plan, billing cycle, amount, and the "Cancel Subscription" action

end

deactivate Page

deactivate user

@enduml
