@startuml UC28_Invite_To_Request_Sequence_Diagram

skinparam monochrome true

skinparam defaultFontColor Black

skinparam shadowing false

skinparam sequence {

    ArrowColor Black

    LifeLineBorderColor Black

    LifeLineBackgroundColor White

    ParticipantBorderColor Black

    ParticipantBackgroundColor #DDDDDD

    ParticipantFontColor Black

    ActorBorderColor Black

    ActorBackgroundColor White

    ActorFontColor Black

    GroupHeaderFontColor Black

    GroupHeaderBackgroundColor White

    GroupBodyBackgroundColor White

    GroupBorderColor Black

}

title UC-28 Invite To Request Sequence Diagram

actor user

boundary "PartnerProfilePage" as ProfilePage

boundary "InviteModal" as InviteModal

participant "discoveryApi" as DiscoveryAPI

participant "apiClient" as ApiClient

participant "ProjectRequestsController" as Controller

participant "JwtAuthGuard" as JWTGuard

participant "RolesGuard" as RolesGuard

participant "ProjectRequestsService" as Service

participant "QuotaService" as QuotaService

database "Database" as DB

user -> ProfilePage : 1. Open a partner profile from discovery or request detail

activate user

activate ProfilePage

user -> ProfilePage : 2. Click "Invite to Project"

ProfilePage -> InviteModal : 3. Open the invitation modal

activate InviteModal

InviteModal -> Controller : 4. Request the current user's eligible requests with GET "/project-requests"

activate Controller

Controller -> JWTGuard : 5. Confirm the user is signed in

activate JWTGuard

JWTGuard --> Controller : 6. Return authenticated user identity and role

Controller -> Service : 7. Load requests the inviter can use for invitations

activate Service

Service -> DB : 8. Query eligible requests and current assignment state

activate DB

DB --> Service : 9. Return eligible requests

deactivate DB

Service --> Controller : 10. Return eligible request list

Controller --> InviteModal : 11. Populate the request dropdown

user -> InviteModal : 12. Select a request and click "Send Invitation"

alt [User invites a broker as Client]

    InviteModal -> DiscoveryAPI : 13. Call inviteBroker(requestId, brokerId, message)

    activate DiscoveryAPI

    DiscoveryAPI -> ApiClient : 14. Forward HTTP request

    activate ApiClient

    ApiClient -> Controller : 15. Send POST "/project-requests/{requestId}/invite/broker"

    Controller -> JWTGuard : 16. Confirm the client is signed in

    JWTGuard --> Controller : 17. Return authenticated client identity

    Controller -> Service : 18. Create a broker invitation

    Service -> QuotaService : 19. Check broker-invitation quota

    activate QuotaService

    QuotaService --> Service : 20. Quota is available

    deactivate QuotaService

    Service -> DB : 21. Load request and existing broker proposal state

    activate DB

    DB --> Service : 22. Return request and current proposal data

deactivate DB

    Service -> DB : 23. Save broker proposal with status "INVITED"

    activate DB

    DB --> Service : 24. Persist invited broker proposal

deactivate DB

    Service --> Controller : 25. Return invited broker proposal

    Controller --> ApiClient : 26. Return server response

    ApiClient --> DiscoveryAPI : 27. Return invite success response

    DiscoveryAPI --> InviteModal : 28. Show invitation success

else [User invites a freelancer as Broker]

    InviteModal -> DiscoveryAPI : 29. Call inviteFreelancer(requestId, freelancerId, message)

    DiscoveryAPI -> ApiClient : 30. Forward HTTP request

    ApiClient -> Controller : 31. Send POST "/project-requests/{requestId}/invite/freelancer"

    Controller -> JWTGuard : 32. Confirm the broker is signed in

    JWTGuard --> Controller : 33. Return authenticated broker identity

    deactivate JWTGuard

    Controller -> RolesGuard : 34. Confirm the caller can invite freelancers

    activate RolesGuard

    RolesGuard --> Controller : 35. Role check passed

    deactivate RolesGuard

    Controller -> Service : 36. Create a freelancer recommendation for client review

    Service -> DB : 37. Load request, broker assignment, and existing freelancer proposal state

    activate DB

    DB --> Service : 38. Return request and current proposal data

deactivate DB

    Service -> DB : 39. Save freelancer proposal with status "PENDING_CLIENT_APPROVAL"

    activate DB

    DB --> Service : 40. Persist freelancer recommendation

deactivate DB

    Service --> Controller : 41. Return saved freelancer recommendation

    deactivate Service

    Controller --> ApiClient : 42. Return server response

    deactivate Controller

    ApiClient --> DiscoveryAPI : 43. Return invite success response

    deactivate ApiClient

    DiscoveryAPI --> InviteModal : 44. Show recommendation success

    deactivate DiscoveryAPI

end

InviteModal --> user : 45. Close the modal and show that the invitation has been sent

deactivate InviteModal

deactivate ProfilePage

deactivate user

@enduml
