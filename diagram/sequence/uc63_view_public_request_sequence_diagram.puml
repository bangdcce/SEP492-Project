@startuml UC63_View_Public_Request_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}


title UC-63 View Public Request Sequence Diagram

actor user
boundary "Marketplace Page" as Page
participant "projectRequestsApi" as RequestsAPI
participant "apiClient" as ApiClient
participant "ProjectRequestsController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "ProjectRequestsService" as Service
database "Database" as DB

user -> Page : 1. Open the marketplace page for the current role
activate user
activate Page
Page -> Page : 2. Show loading state, search box, and filter controls
Page -> RequestsAPI : 3. Request the marketplace list for the current role
activate RequestsAPI
RequestsAPI -> ApiClient : 4. Forward HTTP request
activate ApiClient
ApiClient -> Controller : 5. Send the role-specific marketplace endpoint
activate Controller
Controller -> JWTGuard : 6. Confirm the user is signed in
activate JWTGuard
JWTGuard --> Controller : 7. Return authenticated user identity and role
deactivate JWTGuard
Controller -> Service : 8. Load public requests visible to the current role
activate Service
Service -> DB : 9. Query marketplace requests and related application state
activate DB
DB --> Service : 10. Return marketplace request rows
deactivate DB
Service --> Controller : 11. Return the role-appropriate marketplace list
deactivate Service
Controller --> ApiClient : 12. Return server response
deactivate Controller
ApiClient --> RequestsAPI : 13. Return marketplace payload
deactivate ApiClient
RequestsAPI --> Page : 14. Return visible public requests
deactivate RequestsAPI
Page -> Page : 15. Apply search and list filtering
Page --> user : 16. Show public requests with open/detail actions for the current role
deactivate Page
deactivate user

@enduml
