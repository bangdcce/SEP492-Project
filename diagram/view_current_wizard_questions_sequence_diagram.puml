@startuml View_Current_Wizard_Questions_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
	ArrowColor Black
	LifeLineBorderColor Black
	LifeLineBackgroundColor White

	ParticipantBorderColor Black
	ParticipantBackgroundColor #DDDDDD
	ParticipantFontColor Black

	ActorBorderColor Black
	ActorBackgroundColor White
	ActorFontColor Black

	GroupHeaderFontColor Black
	GroupHeaderBackgroundColor White
	GroupBodyBackgroundColor White
	GroupBorderColor Black
}

title View Current Wizard Questions Sequence Diagram

actor Admin
boundary "AdminWizardPage" as Page
participant "apiClient" as API
participant ":WizardAdminController" as Controller
participant ":JwtAuthGuard" as JWTGuard
participant ":RolesGuard" as RoleGuard
participant ":WizardService" as Service
database "Database" as DB

Admin -> Page : 1. Access Admin Wizard Questions page
activate Admin
activate Page

Page -> Page : 2. Load wizard questions

Page -> API : 3. Request wizard questions list
activate API

API -> Controller : 4. Request all questions
activate Controller

Controller -> JWTGuard : 5. Check sign-in session
activate JWTGuard
JWTGuard --> Controller : 6. Return authenticated user
deactivate JWTGuard

Controller -> RoleGuard : 7. Check role (ADMIN only)
activate RoleGuard
RoleGuard --> Controller : 8. Authorize
deactivate RoleGuard

Controller -> Service : 9. Get all wizard questions (admin view)
activate Service

Service -> DB : 10. Load questions and their options\n(sorted by display order)
activate DB
DB --> Service : 11. Return all questions (including inactive)
deactivate DB

Service -> Service : 12. Prepare full question details\n(including inactive questions and options)

Service --> Controller : 13. Return questions with options
deactivate Service

Controller --> API : 14. Return success response with data
deactivate Controller

API --> Page : 15. Return questions list
deactivate API

Page -> Page : 16. Update state with questions data

Page --> Admin : 17. Display questions table\n(Code, Label, Type, Status, Sort Order,\nOptions count, Actions)

deactivate Page

deactivate Admin

@enduml
