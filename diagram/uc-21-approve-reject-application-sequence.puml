@startuml
title UC-21 Approve/Reject Application Sequence Diagram

skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam sequence {
    ActorFontColor black
    ParticipantFontColor black
    TitleFontColor black
    GroupFontColor black
    GroupBorderColor black
}

actor "Client" as Actor
boundary "Request Detail Page" as Page
participant "ProjectRequestsController" as RequestController
participant "ProjectRequestsService" as RequestService
participant "NotificationService" as NotificationService
database "Database" as DB

Actor -> Page : 1. Open request detail and review broker applications
activate Actor
activate Page

Page -> RequestController : 2. Request request detail and candidate list
activate RequestController
RequestController -> RequestService : 3. Load request read model
activate RequestService
RequestService -> DB : 4. Fetch request, broker proposals, and viewer permissions
activate DB
DB --> RequestService : 5. Return request detail
deactivate DB
RequestService --> RequestController : 6. Return request detail
deactivate RequestService
RequestController --> Page : 7. Return request detail
deactivate RequestController
Page --> Actor : 8. Display applications, cover letters, and candidate actions

Actor -> Page : 9. Open broker profile and review the candidate
Page --> Actor : 10. Show broker profile, cover letter, and decision actions

Actor -> Page : 11. Click Approve or Reject candidate
Page -> Page : 12. Determine selected proposal and requested action
activate Page
deactivate Page

alt [Client approves the candidate]
    Page -> RequestController : 13. Submit hire broker request
    activate RequestController
    RequestController -> RequestService : 14. Accept selected broker
    activate RequestService
    RequestService -> DB : 15. Load request and verify client ownership
    activate DB
    DB --> RequestService : 16. Return request and proposal context
    deactivate DB

    RequestService -> DB : 17. Save broker assignment and set status to BROKER_ASSIGNED
    activate DB
    DB --> RequestService : 18. Confirm request update
    deactivate DB

    RequestService -> DB : 19. Mark selected broker proposal as ACCEPTED
    activate DB
    DB --> RequestService : 20. Confirm accepted proposal
    deactivate DB

    RequestService -> DB : 21. Load other pending proposals for the same request
    activate DB
    DB --> RequestService : 22. Return remaining pending proposals
    deactivate DB

    RequestService -> DB : 23. Mark remaining pending proposals as REJECTED
    activate DB
    DB --> RequestService : 24. Confirm proposal rejections
    deactivate DB

    RequestService -> NotificationService : 25. Send selection and rejection notifications
    activate NotificationService
    NotificationService --> RequestService : 26. Confirm notifications
    deactivate NotificationService

    RequestService -> DB : 27. Reload updated request detail
    activate DB
    DB --> RequestService : 28. Return updated request
    deactivate DB

    RequestService --> RequestController : 29. Return updated request detail
    deactivate RequestService
    RequestController --> Page : 30. Return hire broker response
    deactivate RequestController
    Page --> Actor : 31. Show hired broker state and move to spec phase

else [Client rejects the candidate]
    Page -> RequestController : 32. Submit release broker slot request
    activate RequestController
    RequestController -> RequestService : 33. Reject active proposal
    activate RequestService
    RequestService -> DB : 34. Load request and proposal and verify permissions
    activate DB
    DB --> RequestService : 35. Return request and proposal
    deactivate DB

    alt [Proposal is active and no broker is assigned yet]
        RequestService -> DB : 36. Mark proposal as REJECTED
        activate DB
        DB --> RequestService : 37. Confirm proposal rejection
        deactivate DB

        RequestService -> NotificationService : 38. Send rejection notifications
        activate NotificationService
        NotificationService --> RequestService : 39. Confirm notifications
        deactivate NotificationService

        RequestService -> DB : 40. Reload updated request detail
        activate DB
        DB --> RequestService : 41. Return updated request
        deactivate DB

        RequestService --> RequestController : 42. Return updated request detail
        deactivate RequestService
        RequestController --> Page : 43. Return rejection response
        deactivate RequestController
        Page --> Actor : 44. Remove candidate from the active list

    else [Proposal is no longer active or a broker was already assigned]
        RequestService --> RequestController : 45. Return validation error
        deactivate RequestService
        RequestController --> Page : 46. Return error response
        deactivate RequestController
        Page --> Actor : 47. Show candidate can no longer be rejected
    end
end

deactivate Page
deactivate Actor
@enduml
