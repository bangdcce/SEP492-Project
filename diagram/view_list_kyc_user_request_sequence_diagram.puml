@startuml View_List_KYC_User_Request_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White
    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black
    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black
    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title View List KYC User Request Sequence Diagram

actor "Admin" as Admin
boundary "AdminKYCPage" as Page
participant "apiClient" as API
participant ":KycController" as Controller
participant ":JwtAuthGuard" as JWTGuard
participant ":RolesGuard" as RoleGuard
participant ":KycService" as Service
database "Database" as DB
participant ":SupabaseStorage" as Storage

Admin -> Page : 1. Open the KYC management page
activate Admin
activate Page

Page -> Page : 2. Load the list using current filters
activate Page
deactivate Page

Page -> Page : 3. Show loading indicator
activate Page
deactivate Page

Page -> API : 4. Request the KYC request list
activate API

API -> Controller : 5. Forward the request to the server
activate Controller

Controller -> JWTGuard : 6. Verify the session token
activate JWTGuard

JWTGuard -> JWTGuard : 7. Read token from the request
activate JWTGuard
deactivate JWTGuard

JWTGuard -> JWTGuard : 8. Validate the token
activate JWTGuard
deactivate JWTGuard

alt [Not Authenticated]
    JWTGuard --> Controller : 9. Reject request (not signed in)
    Controller --> API : 10. Send authentication error
    API --> Page : 11. Return error response
    Page -> Page : 12. Hide loading indicator
    activate Page
    deactivate Page
    Page --> Admin : 13. Show error and redirect to sign in
else [Authenticated]
    JWTGuard -> JWTGuard : 14. Attach user info to the request
    activate JWTGuard
    deactivate JWTGuard
    
    JWTGuard --> Controller : 15. Allow request
    deactivate JWTGuard

    Controller -> RoleGuard : 16. Check access role
    activate RoleGuard

    RoleGuard -> RoleGuard : 17. Verify role is ADMIN or STAFF
    activate RoleGuard
    deactivate RoleGuard

    alt [Not Authorized]
        RoleGuard --> Controller : 18. Reject request (insufficient permission)
        Controller --> API : 19. Send forbidden error
        API --> Page : 20. Return error response
        Page --> Admin : 21. Show "access denied"
    else [Authorized]
        RoleGuard --> Controller : 22. Allow request
        deactivate RoleGuard

        Controller -> Service : 23. Ask for the KYC request list
        activate Service

        Service -> Service : 24. Build query (user, profile, reviewer)
        activate Service
        deactivate Service

        alt [Status Filter Provided]
            Service -> Service : 25. Apply status filter
            activate Service
            deactivate Service
        end

        Service -> Service : 26. Apply sorting and pagination
        activate Service
        deactivate Service

        Service -> DB : 27. Fetch items and total count
        activate DB
        DB --> Service : 28. Return [items, total]
        deactivate DB

        Service -> Service : 29. Prepare data for display
        activate Service
        deactivate Service

        Service -> Service : 30. Package result (list + pagination)
        activate Service
        deactivate Service

        Service --> Controller : 31. Return KYC request list
        deactivate Service

        Controller --> API : 32. Return success response
        deactivate Controller

        API --> Page : 33. Return list data
        deactivate API

        Page -> Page : 34. Update list and hide loading indicator
        activate Page
        deactivate Page

        Page --> Admin : 35. Show the KYC request list

        alt [Change Filters]
            Admin -> Page : 36. Select filters
            Page -> Page : 37. Update filters
            activate Page
            deactivate Page
            Page -> Page : 38. Reload list with new filters
            activate Page
            deactivate Page
            Page --> Admin : 39. Show updated list
        end
    end
end

deactivate Page
deactivate Admin

@enduml
