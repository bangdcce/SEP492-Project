@startuml
title UC-40 Register New Subscription Sequence Diagram

skinparam monochrome true
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam sequence {
    ActorFontColor black
    ParticipantFontColor black
    TitleFontColor black
    GroupFontColor black
    GroupBorderColor black
}

actor "Client" as Actor
boundary "Subscription Plans Page" as Page
participant "SubscriptionController" as SubscriptionController
participant "SubscriptionService" as SubscriptionService
participant "CheckoutController" as CheckoutController
participant "CheckoutService" as CheckoutService
database "Database" as DB

Actor -> Page : 1. Open Manage Subscription page
activate Actor
activate Page

Page -> SubscriptionController : 2. Request current plan and available plans
activate SubscriptionController
SubscriptionController -> SubscriptionService : 3. Load subscription options
activate SubscriptionService
SubscriptionService -> DB : 4. Fetch current plan, prices, and plan limits
activate DB
DB --> SubscriptionService : 5. Return subscription data
deactivate DB
SubscriptionService --> SubscriptionController : 6. Return subscription options
deactivate SubscriptionService
SubscriptionController --> Page : 7. Return plan list
deactivate SubscriptionController
Page --> Actor : 8. Display current plan and upgrade choices
deactivate Page
deactivate Actor

Actor -> Page : 9. Select a new membership plan
activate Actor
activate Page
Page --> Actor : 10. Show selected plan price, limits, and benefits

Actor -> Page : 11. Confirm the new subscription
Page -> SubscriptionController : 12. Submit plan change request
activate SubscriptionController
SubscriptionController -> SubscriptionService : 13. Validate selected plan and upgrade rules
activate SubscriptionService
SubscriptionService -> DB : 14. Load current subscription context
activate DB
DB --> SubscriptionService : 15. Return current subscription context
deactivate DB

alt [Selected plan requires payment]
    SubscriptionService --> SubscriptionController : 16. Return checkout requirement
    deactivate SubscriptionService
    SubscriptionController --> Page : 17. Return checkout handoff
    deactivate SubscriptionController

    Page -> CheckoutController : 18. Start subscription checkout
    activate CheckoutController
    CheckoutController -> CheckoutService : 19. Process subscription payment
    activate CheckoutService
    CheckoutService -> DB : 20. Record payment attempt and checkout session
    activate DB
    DB --> CheckoutService : 21. Confirm payment record
    deactivate DB

    alt [Payment succeeds]
        CheckoutService -> DB : 22. Activate selected plan and replace previous active plan
        activate DB
        DB --> CheckoutService : 23. Confirm subscription activation
        deactivate DB
        CheckoutService --> CheckoutController : 24. Return checkout success
    else [Payment fails]
        CheckoutService --> CheckoutController : 25. Return payment failure
    end
    deactivate CheckoutService

    CheckoutController --> Page : 26. Return checkout result
    deactivate CheckoutController
    Page --> Actor : 27. Show updated subscription status or payment error

else [Selected plan is free and does not require payment]
    SubscriptionService -> DB : 28. Activate selected free plan immediately
    activate DB
    DB --> SubscriptionService : 29. Confirm plan activation
    deactivate DB
    SubscriptionService --> SubscriptionController : 30. Return updated subscription
    deactivate SubscriptionService
    SubscriptionController --> Page : 31. Return subscription response
    deactivate SubscriptionController
    Page --> Actor : 32. Show updated subscription status
end

deactivate Page
deactivate Actor
@enduml
