@startuml Edit_Wizard_Question_Sequence_Diagram

skinparam monochrome true
skinparam defaultFontColor Black
skinparam shadowing false

skinparam sequence {
    ArrowColor Black
    LifeLineBorderColor Black
    LifeLineBackgroundColor White

    ParticipantBorderColor Black
    ParticipantBackgroundColor #DDDDDD
    ParticipantFontColor Black

    ActorBorderColor Black
    ActorBackgroundColor White
    ActorFontColor Black

    GroupHeaderFontColor Black
    GroupHeaderBackgroundColor White
    GroupBodyBackgroundColor White
    GroupBorderColor Black
}

title Edit Wizard Question Sequence Diagram

actor Admin
boundary "AdminWizardPage" as Page
participant "apiClient" as API
participant "WizardAdminController" as Controller
participant "JwtAuthGuard" as JWTGuard
participant "RolesGuard" as RoleGuard
participant "WizardService" as Service
database "Database" as DB

Admin -> Page : 1. Click "Edit" button
activate Admin
activate Page

Page --> Admin : 2. Display edit modal with current data

Admin -> Page : 3. Modify fields, click "Save"

activate Page
Page -> Page : 4. Validate form data
deactivate Page

Page -> API : 5. Send update request with modified data
activate API

API -> Controller : 6. Send update request
activate Controller

Controller -> JWTGuard : 7. Check sign-in session
activate JWTGuard
JWTGuard --> Controller : 8. Return authenticated user
deactivate JWTGuard

Controller -> RoleGuard : 9. Check role (ADMIN only)
activate RoleGuard
RoleGuard --> Controller : 10. Authorize
deactivate RoleGuard

Controller -> Service : 11. Update the question and its options
activate Service

Service -> DB : 12. Load the question and current options
activate DB
DB --> Service : 13. Return question with options
deactivate DB

activate Service
Service -> Service : 14. Validate question exists

Service -> Service : 15. Update question fields:\n- code, label, helpText\n- inputType, isActive, sortOrder
deactivate Service

Service -> DB : 16. Save question changes
activate DB
DB --> Service : 17. Return saved question
deactivate DB

alt [Has Options Updates]
    activate Service
    Service -> Service : 18. Compare current options\nwith the updated list

    Service -> Service : 19. Identify options to remove
    deactivate Service

    Service -> DB : 20. Delete removed options
    activate DB
    DB --> Service : 21. Return deletion confirmation
    deactivate DB

    loop [For each option in updateDto.options]
        alt [Option has ID - Update existing]
            activate Service
            Service -> Service : 22. Find the existing option

            Service -> Service : 23. Update option details\n(value, label, order)
            deactivate Service

            Service -> DB : 24. Save the option changes
            activate DB
            DB --> Service : 25. Return saved option
            deactivate DB

        else [Option without ID - Create new]
            activate Service
            Service -> Service : 26. Create a new option\nfor this question
            deactivate Service

            Service -> DB : 27. Save the new option
            activate DB
            DB --> Service : 28. Return saved option
            deactivate DB
        end
    end
end

activate Service
Service -> Service : 29. Reload the updated question details
deactivate Service

Service --> Controller : 30. Return updated question with options
deactivate Service

Controller --> API : 31. Return success response
deactivate Controller

API --> Page : 32. Return updated question data
deactivate API

Page --> Admin : 33. Show success toast:\n"Question updated successfully"

activate Page
Page -> Page : 34. Refresh questions list
deactivate Page

Page --> Admin : 35. Display updated data
deactivate Page

deactivate Admin

@enduml
