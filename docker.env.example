# Registry images for shared team deployment
# Example:
# SERVER_IMAGE=ghcr.io/your-org/interdev-server:v1.0.0
# CLIENT_IMAGE=ghcr.io/your-org/interdev-client:v1.0.0
SERVER_IMAGE=interdev/server:local
CLIENT_IMAGE=interdev/client:local

# Redis password used by interdev-redis and server REDIS_URL
REDIS_PASSWORD=redis123

# Frontend build-time variables (used when building images with docker-compose.build.yml)
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key
VITE_APP_NAME=InterDev
VITE_APP_VERSION=1.0.0
VITE_ENV=production
VITE_RECAPTCHA_SITE_KEY=
