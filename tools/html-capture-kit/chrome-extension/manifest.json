{
  "manifest_version": 3,
  "name": "HTML Capture Kit",
  "version": "0.3.3",
  "description": "Capture the current web page into a Figma-importable .figcap.json file.",
  "permissions": ["downloads", "tabs", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "HTML Capture Kit",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
